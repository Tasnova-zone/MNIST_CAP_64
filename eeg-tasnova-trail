    "    ),\n",
    "    batch_size=256,\n",
    "    shuffle=False\n",
    ")\n",
    "\n",
    "all_true = []\n",
    "all_pred = []\n",
    "all_conf = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for xb, yb in test_loader_eval:\n",
    "        xb = xb.to(DEVICE)\n",
    "        logits = best_eeg_model(xb)\n",
    "        probs = torch.softmax(logits, dim=1)\n",
    "\n",
    "        pred = probs.argmax(dim=1)\n",
    "        conf = probs.max(dim=1).values\n",
    "\n",
    "        all_true.append(yb.cpu())\n",
