    "        target_conf = probs[:, d]\n",
    "\n",
    "        best_idx = target_conf.argmax()\n",
    "\n",
    "        best_digit_images.append(imgs[best_idx].detach().cpu())\n",
    "        best_digit_conf.append(float(target_conf[best_idx].item()))\n",
