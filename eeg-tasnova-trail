    "]\n",
    "\n",
    "eeg_vals = [\n",
    "    metrics_eeg_pred[\"Oracle Accuracy vs True Label\"],\n",
    "    metrics_eeg_pred[\"Mean SSIM\"],\n",
    "    metrics_eeg_pred[\"Mean Perceptual Score\"]\n",
    "]\n",
    "\n",
    "x = np.arange(len(plot_names))\n",
    "w = 0.35\n",
    "\n",
    "plt.figure(figsize=(9, 4.8))\n",
    "plt.bar(x - w/2, upper_vals, width=w, label=\"True-label generation\")\n",
