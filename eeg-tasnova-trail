    "# ============================================================\n",
    "# Cell 8 — CustomCap64 raw EEG classification comparison\n",
    "# ============================================================\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "CAP_EPOCHS = 60\n",
    "CAP_BATCH = 64\n",
    "CAP_FS = 200\n",
    "\n",
    "idx_cap = np.arange(len(y_cap))\n",
    "\n",
    "cap_train_idx, cap_test_idx = train_test_split(\n",
    "    idx_cap,\n",
    "    test_size=0.15,\n",
    "    random_state=SEED,\n",
    "    stratify=y_cap\n",
    ")\n",
    "\n",
    "def preprocess_cap_zscore_only(X_input):\n",
    "    mean = X_input.mean(axis=-1, keepdims=True)\n",
    "    std = X_input.std(axis=-1, keepdims=True) + 1e-6\n",
    "    return ((X_input - mean) / std).astype(np.float32)\n",
    "\n",
    "def preprocess_cap_bandpass(X_input):\n",
    "    b, a = butter(N=4, Wn=[0.5, 40], btype=\"bandpass\", fs=CAP_FS)\n",
    "    X_f = filtfilt(b, a, X_input, axis=-1).astype(np.float32)\n",
    "    return preprocess_cap_zscore_only(X_f)\n",
    "\n",
    "def train_cap_eegnet(X_data, y_data, input_name):\n",
    "    X_train = X_data[cap_train_idx]\n",
    "    y_train = y_data[cap_train_idx]\n",
    "    X_test = X_data[cap_test_idx]\n",
    "    y_test = y_data[cap_test_idx]\n",
    "\n",
    "    train_ds = TensorDataset(\n",
    "        torch.tensor(X_train, dtype=torch.float32),\n",
    "        torch.tensor(y_train, dtype=torch.long)\n",
    "    )\n",
    "    test_ds = TensorDataset(\n",
    "        torch.tensor(X_test, dtype=torch.float32),\n",
    "        torch.tensor(y_test, dtype=torch.long)\n",
    "    )\n",
    "\n",
    "    train_loader = DataLoader(train_ds, batch_size=CAP_BATCH, shuffle=True, num_workers=2, pin_memory=True)\n",
    "    test_loader = DataLoader(test_ds, batch_size=CAP_BATCH, shuffle=False, num_workers=2, pin_memory=True)\n",
    "\n",
    "    model = EEGNetClassifier(n_channels=64, n_times=400, n_classes=10).to(DEVICE)\n",
    "    optimizer = torch.optim.AdamW(model.parameters(), lr=7e-4, weight_decay=1e-4)\n",
    "    criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "    best_acc = 0.0\n",
    "    best_bal = 0.0\n",
    "    best_f1 = 0.0\n",
    "    best_state = None\n",
    "    best_epoch = 0\n",
    "\n",
    "    for epoch in range(1, CAP_EPOCHS + 1):\n",
    "        model.train()\n",
    "\n",
    "        for xb, yb in train_loader:\n",
    "            xb = xb.to(DEVICE, non_blocking=True)\n",
    "            yb = yb.to(DEVICE, non_blocking=True)\n",
    "\n",
    "            optimizer.zero_grad()\n",
    "            loss = criterion(model(xb), yb)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "\n",
    "        acc, bal, f1 = evaluate_classifier(model, test_loader)\n",
    "\n",
    "        if acc > best_acc:\n",
    "            best_acc = acc\n",
    "            best_bal = bal\n",
    "            best_f1 = f1\n",
    "            best_epoch = epoch\n",
    "            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}\n",
    "\n",
    "        if epoch == 1 or epoch % 10 == 0:\n",
    "            print(f\"{input_name} | Epoch {epoch:03d}/{CAP_EPOCHS} | Test Acc: {acc:.4f} | Best: {best_acc:.4f}\")\n",
    "\n",
    "    model.load_state_dict(best_state)\n",
    "\n",
    "    return {\n",
    "        \"Dataset\": \"CustomCap64\",\n",
    "        \"Input\": input_name,\n",
    "        \"Split\": \"Stratified 85/15\",\n",
    "        \"Feature/Representation\": \"Raw time-series\",\n",
    "        \"Model\": \"64-channel EEGNet\",\n",
    "        \"Accuracy\": best_acc,\n",
    "        \"Balanced Accuracy\": best_bal,\n",
    "        \"Macro F1\": best_f1,\n",
    "        \"Chance Baseline\": 1 / N_CLASSES,\n",
    "        \"Best Epoch\": best_epoch\n",
    "    }\n",
    "\n",
    "X_cap_z = preprocess_cap_zscore_only(X_cap_raw)\n",
    "X_cap_bp = preprocess_cap_bandpass(X_cap_raw)\n",
    "\n",
    "cap_results = []\n",
    "\n",
    "cap_results.append(train_cap_eegnet(X_cap_z, y_cap, \"Z-score EEG\"))\n",
    "cap_results.append(train_cap_eegnet(X_cap_bp, y_cap, \"Bandpass + Z-score EEG\"))\n",
    "\n",
    "cap_results = pd.DataFrame(cap_results)\n",
    "\n",
    "classification_results = pd.concat(\n",
    "    [classification_results, cap_results.drop(columns=[\"Best Epoch\"])],\n",
    "    ignore_index=True\n",
    ")\n",
    "\n",
    "print(\"\\n========== CustomCap64 Raw EEG Results ==========\")\n",
    "display(cap_results)\n",
    "\n",
    "print(\"\\n========== Updated Classification Result Table ==========\")\n",
    "display(classification_results)"
   ]
