   batch_size=DEVICE_BATCH,\n        shuffle=False,\n        num_workers=2,\n        pin_memory=True\n    )\n\n    n_channels = X_data.shape[1]\n    n_times = X_data.shape[2]\n\n    model = EEGNetClassifier(\n        n_channels=n_channels,\n        n_times=n_times,\n        n_classes=N_CLASSES\n    ).to(DEVICE)\n\n    optimizer = torch.optim.AdamW(model.parameters(), lr=7e-4, weight_decay=1e-4)\n    criterion = nn.CrossEntropyLoss()\n\n    best_acc = 0.0\n    best_bal = 0.0\n    best_f1 = 0.0\n    best_epoch = 0\n    best_state = None\n\n    for epoch in range(1, DEVICE_EPOCHS + 1):\n        model.train()\n\n        for xb, yb in train_loader:\n            xb = xb.to(DEVICE, non_blocking=True)\n            yb = yb.to(DEVICE, non_blocking=True)\n\n            optimizer.zero_grad()\n            loss = criterion(model(xb), yb)\n            loss.backward()\n            optimizer.step()\n\n        acc, bal, f1 = evaluate_classifier(model, test_loader)\n\n        if acc > best_acc:\n            best_acc = acc\n            best_bal = bal\n            best_f1 = f1\n            best_epoch = epoch\n            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}\n\n        if epoch == 1 or epoch % 10 == 0:\n            print(\n                f\"{device_name} | Epoch {epoch:03d}/{DEVICE_EPOCHS} | \"\n                f\"Test Acc: {acc:.4f} | Best: {best_acc:.4f}\"\n            )\n\n    model.load_state_dict(best_state)\n\n    return {\n        \"Dataset\": f\"1.2M-{device_name}\",\n        \"Input\": f\"{device_name} EEG\",\n        \"Split\": \"Stratified 85/15\",\n        \"Feature/Representation\": \"Raw time-series\",\n        \"Model\": f\"{n_channels}-channel EEGNet\",\n        \"Accuracy\": best_acc,\n        \"Balanced Accuracy\": best_bal,\n        \"Macro F1\": best_f1,\n        \"Chance Baseline\": 1 / N_CLASSES\n    }\n\n\ndevice_results = []\n\nfor device_name in [\"IN\", \"MU\", \"MW\"]:\n    print(f\"\\nTraining {device_name} EEGNet.