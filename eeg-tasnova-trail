    "# ============================================================\n",
    "# Cell 11 — IN, MU, MW EEGNet classification comparison\n",
    "# ============================================================\n",
    "\n",
    "DEVICE_EPOCHS = 50\n",
    "DEVICE_BATCH = 256\n",
    "\n",
    "def zscore_eeg(X_input):\n",
    "    mean = X_input.mean(axis=-1, keepdims=True)\n",
    "    std = X_input.std(axis=-1, keepdims=True) + 1e-6\n",
    "    return ((X_input - mean) / std).astype(np.float32)\n",
    "\n",
    "\n",
    "def train_device_eegnet(device_name, X_data, y_data):\n",
    "    X_data = zscore_eeg(X_data)\n",
    "\n",
    "    idx = np.arange(len(y_data))\n",
    "    train_idx, test_idx = train_test_split(\n",
    "        idx,\n",
    "        test_size=0.15,\n",
    "        random_state=SEED,\n",
    "        stratify=y_data\n",
    "    )\n",
    "\n",
    "    X_train = X_data[train_idx]\n",
    "    y_train = y_data[train_idx]\n",
    "    X_test = X_data[test_idx]\n",
    "    y_test = y_data[test_idx]\n",
    "\n",
    "    train_ds = TensorDataset(\n",
    "        torch.tensor(X_train, dtype=torch.float32),\n",
    "        torch.tensor(y_train, dtype=torch.long)\n",
    "    )\n",
    "    test_ds = TensorDataset(\n",
    "        torch.tensor(X_test, dtype=torch.float32),\n",
    "        torch.tensor(y_test, dtype=torch.long)\n",
    "    )\n",
    "\n",
    "    train_loader = DataLoader(\n",
    "        train_ds,\n",
    "        batch_size=DEVICE_BATCH,\n",
    "        shuffle=True,\n",
    "        num_workers=2,\n",
    "        pin_memory=True\n",
    "    )\n",
    "\n",
    "    test_loader = DataLoader(\n",
    "        test_ds,\n",
    "        batch_size=DEVICE_BATCH,\n",
    "        shuffle=False,\n",
    "        num_workers=2,\n",
    "        pin_memory=True\n",
    "    )\n",
    "\n",
    "    n_channels = X_data.shape[1]\n",
    "    n_times = X_data.shape[2]\n",
    "\n",
    "    model = EEGNetClassifier(\n",
    "        n_channels=n_channels,\n",
    "        n_times=n_times,\n",
    "        n_classes=N_CLASSES\n",
    "    ).to(DEVICE)\n",
    "\n",
    "    optimizer = torch.optim.AdamW(model.parameters(), lr=7e-4, weight_decay=1e-4)\n",
    "    criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "    best_acc = 0.0\n",
    "    best_bal = 0.0\n",
    "    best_f1 = 0.0\n",
    "    best_epoch = 0\n",
    "    best_state = None\n",
    "\n",
    "    for epoch in range(1, DEVICE_EPOCHS + 1):\n",
    "        model.train()\n",
    "\n",
    "        for xb, yb in train_loader:\n",
    "            xb = xb.to(DEVICE, non_blocking=True)\n",
    "            yb = yb.to(DEVICE, non_blocking=True)\n",
    "\n",
    "            optimizer.zero_grad()\n",
    "            loss = criterion(model(xb), yb)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "\n",
    "        acc, bal, f1 = evaluate_classifier(model, test_loader)\n",
    "\n",
    "        if acc > best_acc:\n",
    "            best_acc = acc\n",
    "            best_bal = bal\n",
    "            best_f1 = f1\n",
    "            best_epoch = epoch\n",
    "            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}\n",
    "\n",
    "        if epoch == 1 or epoch % 10 == 0:\n",
    "            print(\n",
    "                f\"{device_name} | Epoch {epoch:03d}/{DEVICE_EPOCHS} | \"\n",
    "                f\"Test Acc: {acc:.4f} | Best: {best_acc:.4f}\"\n",
    "            )\n",
    "\n",
    "    model.load_state_dict(best_state)\n",
    "\n",
    "    return {\n",
    "        \"Dataset\": f\"1.2M-{device_name}\",\n",
    "        \"Input\": f\"{device_name} EEG\",\n",
    "        \"Split\": \"Stratified 85/15\",\n",
    "        \"Feature/Representation\": \"Raw time-series\",\n",
    "        \"Model\": f\"{n_channels}-channel EEGNet\",\n",
    "        \"Accuracy\": best_acc,\n",
    "        \"Balanced Accuracy\": best_bal,\n",
    "        \"Macro F1\": best_f1,\n",
    "        \"Chance Baseline\": 1 / N_CLASSES\n",
    "    }\n",
    "\n",
    "\n",
    "device_results = []\n",
    "\n",
    "for device_name in [\"IN\", \"MU\", \"MW\"]:\n",
    "    print(f\"\\nTraining {device_name} EEGNet...\")\n",
    "    result = train_device_eegnet(\n",
    "        device_name=device_name,\n",
    "        X_data=device_data[device_name][\"X\"],\n",
    "        y_data=device_data[device_name][\"y\"]\n",
    "    )\n",
    "    device_results.append(result)\n",
    "\n",
    "device_results = pd.DataFrame(device_results)\n",
    "\n",
    "classification_results = pd.concat(\n",
    "    [classification_results, device_results],\n",
    "    ignore_index=True\n",
    ")\n",
    "\n",
    "print(\"\\n========== IN/MU/MW EEGNet Results ==========\")\n",
    "display(device_results)\n",
    "\n",
    "print(\"\\n========== Updated Full Classification Result Table ==========\")\n",
    "display(classification_results)"
