    "# ============================================================\n",
    "# Cell 18B — Confusion-matrix based True → Predicted → Generated examples\n",
    "# ============================================================\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import confusion_matrix\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Required from Cell 18:\n",
    "# all_true, all_pred, all_conf, best_digit_images\n",
    "# ------------------------------------------------------------\n",
    "required_vars = [\"all_true\", \"all_pred\", \"all_conf\", \"best_digit_images\", \"N_CLASSES\"]\n",
    "missing = [v for v in required_vars if v not in globals()]\n",
    "\n",
    "if len(missing) > 0:\n",
    "    raise RuntimeError(f\"Run Cell 18 first. Missing variables: {missing}\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Confusion matrix\n",
    "# ------------------------------------------------------------\n",
    "cm = confusion_matrix(all_true, all_pred, labels=list(range(N_CLASSES)))\n",
    "\n",
    "selected_indices = []\n",
    "selected_rows = []\n",
    "\n",
    "for true_digit in range(N_CLASSES):\n",
    "\n",
    "    # most frequent prediction for this true class\n",
    "    predicted_digit = int(np.argmax(cm[true_digit]))\n",
    "\n",
    "    # find samples where true=true_digit and pred=predicted_digit\n",
    "    candidate_idx = np.where((all_true == true_digit) & (all_pred == predicted_digit))[0]\n",
    "\n",
    "    # if no sample found, fallback: any sample of this true digit\n",
    "    if len(candidate_idx) == 0:\n",
    "        candidate_idx = np.where(all_true == true_digit)[0]\n",
    "\n",
    "    # choose the highest-confidence sample among candidates\n",
    "    best_local = candidate_idx[np.argmax(all_conf[candidate_idx])]\n",
    "\n",
    "    selected_indices.append(best_local)\n",
    "\n",
    "    selected_rows.append({\n",
    "        \"True EEG Label\": int(all_true[best_local]),\n",
    "        \"Most Frequent EEG Prediction\": int(all_pred[best_local]),\n",
    "        \"EEG Prediction Confidence\": float(all_conf[best_local]),\n",
    "        \"Generated Label\": int(all_pred[best_local]),\n",
    "        \"Confusion Matrix Count\": int(cm[true_digit, int(all_pred[best_local])])\n",
    "    })\n",
    "\n",
    "confusion_generation_table = pd.DataFrame(selected_rows)\n",
    "\n",
    "print(\"========== True Label → EEG Prediction → Generated Label ==========\")\n",
    "display(confusion_generation_table)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Plot: one generated image for each true digit class\n",
    "# ------------------------------------------------------------\n",
    "plt.figure(figsize=(16, 5))\n",
    "\n",
    "for i, idx in enumerate(selected_indices):\n",
    "\n",
    "    true_label = int(all_true[idx])\n",
    "    pred_label = int(all_pred[idx])\n",
    "    conf = float(all_conf[idx])\n",
    "\n",
    "    plt.subplot(2, 5, i + 1)\n",
    "    plt.imshow(best_digit_images[pred_label, 0], cmap=\"gray\")\n",
    "    plt.title(\n",
    "        f\"True={true_label}\\nPred={pred_label}, Conf={conf:.2f}\\nGenerated={pred_label}\",\n",
    "        fontsize=10\n",
    "    )\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "plt.suptitle(\n",
    "    \"Confusion-Matrix Based EEG-to-Image Examples: True Label, EEG Prediction, and Generated Digit\",\n",
    "    fontsize=14\n",
    ")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/confusion_based_true_pred_generated_examples.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Save table\n",
    "# ------------------------------------------------------------\n",
    "confusion_generation_table.to_csv(\n",
    "    \"/kaggle/working/confusion_based_true_pred_generated_table.csv\",\n",
    "    index=False\n",
    ")\n",
    "\n",
    "print(\"Saved:\")\n",
    "print(\"/kaggle/working/confusion_based_true_pred_generated_examples.png\")\n",
    "print(\"/kaggle/working/confusion_based_true_pred_generated_table.csv\")"
