    "# ============================================================\n",
    "# Cell 16C — Compare standard MNIST true-label generation\n",
    "#           vs EEG-predicted generation + perceptual score\n",
    "# ============================================================\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from IPython.display import display\n",
    "from sklearn.metrics import accuracy_score\n",
    "\n",
    "torch.cuda.empty_cache()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 0) Basic checks\n",
    "# ------------------------------------------------------------\n",
    "required_vars = [\"gen\", \"oracle\", \"mnist_prototypes\", \"Xte_t\", \"yte_t\", \"DEVICE\", \"N_CLASSES\", \"Z_DIM\"]\n",
    "missing = [v for v in required_vars if v not in globals()]\n",
    "if len(missing) > 0:\n",
    "    raise RuntimeError(f\"Run previous cells first. Missing: {missing}\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1) Automatically find trained EEG classifier\n",
    "# ------------------------------------------------------------\n",
    "eeg_model = None\n",
    "eeg_model_name = None\n",
    "\n",
    "for name in [\"best_eeg_model\", \"tuned_model\", \"final_eeg_model\", \"eeg_model\", \"model\", \"model_best\"]:\n",
    "    if name in globals() and isinstance(globals()[name], nn.Module):\n",
    "        candidate = globals()[name].to(DEVICE)\n",
    "        candidate.eval()\n",
    "\n",
    "        try:\n",
    "            xb_test = torch.tensor(Xte_t[:2], dtype=torch.float32).to(DEVICE)\n",
    "            with torch.no_grad():\n",
    "                out = candidate(xb_test)\n",
    "\n",
    "            if out.ndim == 2 and out.shape[1] == N_CLASSES:\n",
    "                eeg_model = candidate\n",
    "                eeg_model_name = name\n",
    "                break\n",
    "        except:\n",
    "            pass\n",
    "\n",
    "if eeg_model is None:\n",
    "    raise RuntimeError(\"No trained EEG classifier found. Please run the EEGNet training/evaluation cell first.\")\n",
    "\n",
    "print(\"Using EEG classifier:\", eeg_model_name)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2) Helper functions\n",
    "# ------------------------------------------------------------\n",
    "def simple_ssim_batch(x, y):\n",
    "    C1 = 0.01 ** 2\n",
    "    C2 = 0.03 ** 2\n",
    "\n",
    "    mu_x = x.mean(dim=(1, 2, 3))\n",
    "    mu_y = y.mean(dim=(1, 2, 3))\n",
    "\n",
    "    var_x = ((x - mu_x.view(-1, 1, 1, 1)) ** 2).mean(dim=(1, 2, 3))\n",
    "    var_y = ((y - mu_y.view(-1, 1, 1, 1)) ** 2).mean(dim=(1, 2, 3))\n",
    "\n",
    "    cov_xy = (\n",
    "        (x - mu_x.view(-1, 1, 1, 1)) *\n",
    "        (y - mu_y.view(-1, 1, 1, 1))\n",
    "    ).mean(dim=(1, 2, 3))\n",
    "\n",
    "    ssim = (\n",
    "        ((2 * mu_x * mu_y + C1) * (2 * cov_xy + C2)) /\n",
    "        ((mu_x ** 2 + mu_y ** 2 + C1) * (var_x + var_y + C2))\n",
    "    )\n",
    "\n",
    "    return ssim\n",
    "\n",
    "def oracle_features(x):\n",
    "    # Penultimate feature of the MNIST oracle\n",
    "    x = oracle.net[0](x)\n",
    "    x = oracle.net[1](x)\n",
    "    x = oracle.net[2](x)\n",
    "\n",
    "    x = oracle.net[3](x)\n",
    "    x = oracle.net[4](x)\n",
    "    x = oracle.net[5](x)\n",
    "\n",
    "    x = oracle.net[6](x)   # Flatten\n",
    "    x = oracle.net[7](x)   # Linear\n",
    "    x = oracle.net[8](x)   # ReLU\n",
    "    return x\n",
    "\n",
    "def evaluate_generated_set(gen_imgs_cpu, target_labels_cpu, ref_imgs_cpu, batch_size=256):\n",
    "    oracle_accs = []\n",
    "    target_confs = []\n",
    "    psnr_vals = []\n",
    "    ssim_vals = []\n",
    "    percept_vals = []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for start in range(0, len(gen_imgs_cpu), batch_size):\n",
    "            end = start + batch_size\n",
    "\n",
    "            imgs = gen_imgs_cpu[start:end].to(DEVICE)\n",
    "            labels = target_labels_cpu[start:end].to(DEVICE)\n",
    "            refs = ref_imgs_cpu[start:end].to(DEVICE)\n",
    "\n",
    "            # Oracle semantic evaluation\n",
    "            logits = oracle(imgs)\n",
    "            probs = torch.softmax(logits, dim=1)\n",
    "            pred = probs.argmax(dim=1)\n",
    "            target_conf = probs.gather(1, labels.view(-1, 1)).squeeze(1)\n",
    "\n",
    "            oracle_accs.append((pred == labels).float().cpu())\n",
    "            target_confs.append(target_conf.cpu())\n",
    "\n",
    "            # PSNR\n",
    "            mse = torch.mean((imgs - refs) ** 2, dim=(1, 2, 3))\n",
    "            psnr = 10 * torch.log10(1.0 / (mse + 1e-8))\n",
    "            psnr_vals.append(psnr.cpu())\n",
    "\n",
    "            # SSIM\n",
    "            ssim = simple_ssim_batch(imgs, refs)\n",
    "            ssim_vals.append(ssim.cpu())\n",
    "\n",
    "            # Perceptual score from oracle feature similarity\n",
    "            feat_img = F.normalize(oracle_features(imgs), dim=1)\n",
    "            feat_ref = F.normalize(oracle_features(refs), dim=1)\n",
    "            feat_dist = torch.norm(feat_img - feat_ref, dim=1)\n",
    "            percept_score = 1.0 / (1.0 + feat_dist)\n",
    "            percept_vals.append(percept_score.cpu())\n",
    "\n",
    "    oracle_accs = torch.cat(oracle_accs).mean().item()\n",
    "    target_confs = torch.cat(target_confs).mean().item()\n",
    "    psnr_vals = torch.cat(psnr_vals).mean().item()\n",
    "    ssim_vals = torch.cat(ssim_vals).mean().item()\n",
    "    percept_vals = torch.cat(percept_vals).mean().item()\n",
    "\n",
    "    return {\n",
    "        \"Oracle Accuracy vs True Label\": oracle_accs,\n",
    "        \"Mean Oracle Confidence vs True Label\": target_confs,\n",
    "        \"Mean PSNR\": psnr_vals,\n",
    "        \"Mean SSIM\": ssim_vals,\n",
    "        \"Mean Perceptual Score\": percept_vals\n",
    "    }\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3) Build one clean generated template per digit\n",
    "#    (best one selected by oracle confidence)\n",
    "# ------------------------------------------------------------\n",
    "gen.eval()\n",
    "oracle.eval()\n",
    "\n",
    "TEMPLATE_CANDIDATES = 128\n",
    "\n",
    "class_templates = []\n",
    "class_template_conf = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for d in range(N_CLASSES):\n",
    "        labels = torch.full((TEMPLATE_CANDIDATES,), d, dtype=torch.long, device=DEVICE)\n",
    "        z = torch.randn(TEMPLATE_CANDIDATES, Z_DIM, device=DEVICE)\n",
    "\n",
    "        imgs = gen(z, labels)\n",
    "        imgs = ((imgs + 1.0) / 2.0).clamp(0, 1)\n",
    "\n",
    "        probs = torch.softmax(oracle(imgs), dim=1)\n",
    "        conf = probs[:, d]\n",
    "\n",
    "        best_idx = conf.argmax()\n",
    "\n",
    "        class_templates.append(imgs[best_idx].detach().cpu())\n",
    "        class_template_conf.append(float(conf[best_idx].item()))\n",
    "\n",
    "class_templates = torch.stack(class_templates)          # [10, 1, 28, 28]\n",
    "mnist_proto_cpu = mnist_prototypes.detach().cpu()      # [10, 1, 28, 28]\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 4) Full EEG test prediction\n",
    "# ------------------------------------------------------------\n",
    "X_eval = torch.tensor(Xte_t, dtype=torch.float32)\n",
    "y_eval = torch.tensor(yte_t, dtype=torch.long)\n",
    "\n",
    "all_true = []\n",
    "all_pred = []\n",
    "all_eeg_conf = []\n",
    "\n",
    "eeg_model.eval()\n",
    "\n",
    "with torch.no_grad():\n",
    "    for start in range(0, len(X_eval), 256):\n",
    "        end = start + 256\n",
    "        xb = X_eval[start:end].to(DEVICE)\n",
    "\n",
    "        logits = eeg_model(xb)\n",
    "        probs = torch.softmax(logits, dim=1)\n",
    "\n",
    "        pred = probs.argmax(dim=1).cpu()\n",
    "        conf = probs.max(dim=1).values.cpu()\n",
    "\n",
    "        all_true.append(y_eval[start:end].cpu())\n",
    "        all_pred.append(pred)\n",
    "        all_eeg_conf.append(conf)\n",
    "\n",
    "all_true = torch.cat(all_true)\n",
    "all_pred = torch.cat(all_pred)\n",
    "all_eeg_conf = torch.cat(all_eeg_conf)\n",
    "\n",
    "full_eeg_acc = accuracy_score(all_true.numpy(), all_pred.numpy())\n",
    "\n",
    "print(\"Full test EEG accuracy:\", round(full_eeg_acc, 4))\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 5) Build two compared image sets\n",
    "#    A) Standard MNIST true-label conditioned generation\n",
    "#    B) EEG-predicted conditioned generation\n",
    "#\n",
    "# Reference for both:\n",
    "#    MNIST class prototype of the TRUE label\n",
    "# ------------------------------------------------------------\n",
    "true_label_generated_imgs = class_templates[all_true]   # upper-bound image generation\n",
    "eeg_pred_generated_imgs   = class_templates[all_pred]   # actual EEG pipeline\n",
    "reference_imgs            = mnist_proto_cpu[all_true]   # target/reference digit prototype\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 6) Evaluate both sets\n",
    "# ------------------------------------------------------------\n",
    "metrics_true_label = evaluate_generated_set(\n",
    "    gen_imgs_cpu=true_label_generated_imgs,\n",
    "    target_labels_cpu=all_true,\n",
    "    ref_imgs_cpu=reference_imgs,\n",
    "    batch_size=256\n",
    ")\n",
    "\n",
    "metrics_eeg_pred = evaluate_generated_set(\n",
    "    gen_imgs_cpu=eeg_pred_generated_imgs,\n",
    "    target_labels_cpu=all_true,      # compare against TRUE intended class\n",
    "    ref_imgs_cpu=reference_imgs,\n",
    "    batch_size=256\n",
    ")\n",
    "\n",
    "comparison_df = pd.DataFrame([\n",
    "    {\n",
    "        \"Model\": \"Standard MNIST True-Label Generation\",\n",
    "        \"Conditioning\": \"True label\",\n",
    "        \"EEG Accuracy\": np.nan,\n",
    "        **metrics_true_label\n",
    "    },\n",
    "    {\n",
    "        \"Model\": \"Proposed EEG-to-Image Generation\",\n",
    "        \"Conditioning\": \"EEG-predicted label\",\n",
    "        \"EEG Accuracy\": full_eeg_acc,\n",
    "        **metrics_eeg_pred\n",
    "    }\n",
    "])\n",
    "\n",
    "print(\"\\n========== Cell 16C: Standard Image Model vs Proposed EEG Model ==========\")\n",
    "display(comparison_df)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 7) Visual comparison figure\n",
    "# ------------------------------------------------------------\n",
    "demo_indices = []\n",
    "for d in range(N_CLASSES):\n",
    "    idx = np.where(all_true.numpy() == d)[0]\n",
    "    if len(idx) > 0:\n",
    "        demo_indices.append(idx[0])\n",
    "\n",
    "plt.figure(figsize=(16, 5.6))\n",
    "\n",
    "for col, idx in enumerate(demo_indices):\n",
    "    t = int(all_true[idx].item())\n",
    "    p = int(all_pred[idx].item())\n",
    "\n",
    "    # Row 1: reference MNIST prototype\n",
    "    plt.subplot(3, N_CLASSES, col + 1)\n",
    "    plt.imshow(reference_imgs[idx, 0], cmap=\"gray\")\n",
    "    plt.title(f\"Ref {t}\", fontsize=10)\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "    # Row 2: standard true-label generation\n",
    "    plt.subplot(3, N_CLASSES, col + 1 + N_CLASSES)\n",
    "    plt.imshow(true_label_generated_imgs[idx, 0], cmap=\"gray\")\n",
    "    plt.title(f\"TrueGen {t}\", fontsize=10)\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "    # Row 3: proposed EEG generation\n",
    "    plt.subplot(3, N_CLASSES, col + 1 + 2 * N_CLASSES)\n",
    "    plt.imshow(eeg_pred_generated_imgs[idx, 0], cmap=\"gray\")\n",
    "    plt.title(f\"EEGGen P={p}\", fontsize=10)\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "plt.suptitle(\n",
    "    \"Comparison: Standard MNIST True-Label Generation vs Proposed EEG-Predicted Generation\",\n",
    "    fontsize=14\n",
    ")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/cell16c_true_vs_eeg_generation_comparison.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 8) Small metric bar chart\n",
    "# ------------------------------------------------------------\n",
    "plot_names = [\n",
    "    \"Oracle Accuracy vs True Label\",\n",
