    "# ============================================================\n",
    "# Cell 16 — Evaluate generated digits using MNIST oracle + PSNR/SSIM\n",
    "# ============================================================\n",
    "\n",
    "torch.cuda.empty_cache()\n",
    "\n",
    "ORACLE_BATCH = 256\n",
    "ORACLE_EPOCHS = 3\n",
    "SAMPLES_PER_DIGIT = 64\n",
    "\n",
    "# -----------------------------\n",
    "# MNIST oracle classifier\n",
    "# -----------------------------\n",
    "oracle_transform = transforms.ToTensor()\n",
    "\n",
    "oracle_train_ds = datasets.MNIST(\n",
    "    root=MNIST_ROOT,\n",
    "    train=True,\n",
    "    download=True,\n",
    "    transform=oracle_transform\n",
    ")\n",
    "\n",
    "oracle_test_ds = datasets.MNIST(\n",
    "    root=MNIST_ROOT,\n",
    "    train=False,\n",
    "    download=True,\n",
    "    transform=oracle_transform\n",
    ")\n",
    "\n",
    "oracle_train_loader = DataLoader(\n",
    "    oracle_train_ds,\n",
    "    batch_size=ORACLE_BATCH,\n",
    "    shuffle=True,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "oracle_test_loader = DataLoader(\n",
    "    oracle_test_ds,\n",
    "    batch_size=ORACLE_BATCH,\n",
    "    shuffle=False,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "class MNISTOracleCNN(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Conv2d(1, 32, 3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2),\n",
    "\n",
    "            nn.Conv2d(32, 64, 3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2),\n",
    "\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(64 * 7 * 7, 128),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(128, 10)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.net(x)\n",
    "\n",
    "oracle = MNISTOracleCNN().to(DEVICE)\n",
    "opt_oracle = torch.optim.Adam(oracle.parameters(), lr=1e-3)\n",
    "ce_loss = nn.CrossEntropyLoss()\n",
    "\n",
    "for ep in range(1, ORACLE_EPOCHS + 1):\n",
    "    oracle.train()\n",
    "\n",
    "    for xb, yb in oracle_train_loader:\n",
    "        xb = xb.to(DEVICE, non_blocking=True)\n",
    "        yb = yb.to(DEVICE, non_blocking=True)\n",
    "\n",
    "        opt_oracle.zero_grad()\n",
    "        loss = ce_loss(oracle(xb), yb)\n",
    "        loss.backward()\n",
    "        opt_oracle.step()\n",
    "\n",
    "    oracle.eval()\n",
    "    correct = 0\n",
    "    total = 0\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for xb, yb in oracle_test_loader:\n",
    "            xb = xb.to(DEVICE, non_blocking=True)\n",
    "            yb = yb.to(DEVICE, non_blocking=True)\n",
    "\n",
    "            pred = oracle(xb).argmax(dim=1)\n",
    "            correct += (pred == yb).sum().item()\n",
    "            total += yb.size(0)\n",
    "\n",
    "    print(f\"Oracle Epoch {ep}/{ORACLE_EPOCHS} | Test Accuracy: {correct / total:.4f}\")\n",
    "\n",
    "oracle.eval()\n",
    "\n",
    "\n",
    "# -----------------------------\n",
    "# Build MNIST class prototypes\n",
    "# -----------------------------\n",
    "proto_sum = torch.zeros(N_CLASSES, 1, 28, 28, device=DEVICE)\n",
    "proto_count = torch.zeros(N_CLASSES, device=DEVICE)\n",
    "\n",
    "with torch.no_grad():\n",
    "    for xb, yb in oracle_train_loader:\n",
    "        xb = xb.to(DEVICE, non_blocking=True)\n",
    "        yb = yb.to(DEVICE, non_blocking=True)\n",
    "\n",
    "        for d in range(N_CLASSES):\n",
    "            mask = yb == d\n",
    "            if mask.sum() > 0:\n",
    "                proto_sum[d] += xb[mask].sum(dim=0)\n",
    "                proto_count[d] += mask.sum()\n",
    "\n",
    "mnist_prototypes = proto_sum / proto_count.view(-1, 1, 1, 1)\n",
    "\n",
    "\n",
    "# -----------------------------\n",
    "# Generate multiple samples per digit\n",
    "# -----------------------------\n",
    "gen.eval()\n",
    "\n",
    "all_labels = torch.arange(N_CLASSES, device=DEVICE).repeat_interleave(SAMPLES_PER_DIGIT)\n",
    "z = torch.randn(len(all_labels), Z_DIM, device=DEVICE)\n",
    "\n",
    "with torch.no_grad():\n",
    "    generated = gen(z, all_labels)\n",
    "    generated = ((generated + 1.0) / 2.0).clamp(0, 1)\n",
    "\n",
    "    logits = oracle(generated)\n",
    "    probs = torch.softmax(logits, dim=1)\n",
    "    pred = probs.argmax(dim=1)\n",
    "    target_conf = probs.gather(1, all_labels.view(-1, 1)).squeeze(1)\n",
    "\n",
    "\n",
    "# -----------------------------\n",
    "# PSNR and simple SSIM vs prototype\n",
    "# -----------------------------\n",
    "target_proto = mnist_prototypes[all_labels]\n",
    "\n",
    "mse = torch.mean((generated - target_proto) ** 2, dim=(1, 2, 3))\n",
    "psnr = 10 * torch.log10(1.0 / (mse + 1e-8))\n",
    "\n",
    "def simple_ssim_batch(x, y):\n",
    "    C1 = 0.01 ** 2\n",
    "    C2 = 0.03 ** 2\n",
    "\n",
    "    mu_x = x.mean(dim=(1, 2, 3))\n",
    "    mu_y = y.mean(dim=(1, 2, 3))\n",
    "\n",
    "    var_x = ((x - mu_x.view(-1, 1, 1, 1)) ** 2).mean(dim=(1, 2, 3))\n",
    "    var_y = ((y - mu_y.view(-1, 1, 1, 1)) ** 2).mean(dim=(1, 2, 3))\n",
    "\n",
    "    cov_xy = (\n",
    "        (x - mu_x.view(-1, 1, 1, 1)) *\n",
    "        (y - mu_y.view(-1, 1, 1, 1))\n",
    "    ).mean(dim=(1, 2, 3))\n",
    "\n",
    "    ssim = (\n",
    "        ((2 * mu_x * mu_y + C1) * (2 * cov_xy + C2)) /\n",
    "        ((mu_x ** 2 + mu_y ** 2 + C1) * (var_x + var_y + C2))\n",
    "    )\n",
    "\n",
    "    return ssim\n",
    "\n",
    "ssim = simple_ssim_batch(generated, target_proto)\n",
    "\n",
    "\n",
    "# -----------------------------\n",
    "# Summary table\n",
    "# -----------------------------\n",
    "rows = []\n",
    "\n",
    "for d in range(N_CLASSES):\n",
    "    mask = all_labels == d\n",
    "\n",
    "    rows.append({\n",
    "        \"Digit\": d,\n",
    "        \"Oracle Accuracy\": float((pred[mask] == all_labels[mask]).float().mean().item()),\n",
    "        \"Mean Oracle Confidence\": float(target_conf[mask].mean().item()),\n",
    "        \"Mean PSNR\": float(psnr[mask].mean().item()),\n",
    "        \"Mean SSIM\": float(ssim[mask].mean().item())\n",
    "    })\n",
    "\n",
    "generation_metrics = pd.DataFrame(rows)\n",
    "\n",
    "overall_row = pd.DataFrame([{\n",
    "    \"Digit\": \"Overall\",\n",
    "    \"Oracle Accuracy\": float((pred == all_labels).float().mean().item()),\n",
    "    \"Mean Oracle Confidence\": float(target_conf.mean().item()),\n",
    "    \"Mean PSNR\": float(psnr.mean().item()),\n",
    "    \"Mean SSIM\": float(ssim.mean().item())\n",
    "}])\n",
    "\n",
    "generation_metrics_full = pd.concat([generation_metrics, overall_row], ignore_index=True)\n",
    "\n",
    "print(\"\\n========== Generated Digit Quality Metrics ==========\")\n",
    "display(generation_metrics_full)\n",
    "\n",
    "generation_metrics_full.to_csv(\n",
    "    \"/kaggle/working/generated_digit_quality_metrics.csv\",\n",
    "    index=False\n",
    ")\n",
    "\n",
    "\n",
    "# -----------------------------\n",
    "# Best sample per digit by oracle confidence\n",
    "# -----------------------------\n",
    "best_imgs = []\n",
    "best_confs = []\n",
    "\n",
    "for d in range(N_CLASSES):\n",
    "    mask_idx = torch.where(all_labels == d)[0]\n",
    "    best_local = torch.argmax(target_conf[mask_idx])\n",
    "    best_idx = mask_idx[best_local]\n",
    "\n",
    "    best_imgs.append(generated[best_idx].detach().cpu())\n",
    "    best_confs.append(float(target_conf[best_idx].item()))\n",
    "\n",
    "plt.figure(figsize=(10, 2.4))\n",
    "\n",
    "for d in range(N_CLASSES):\n",
    "    plt.subplot(1, N_CLASSES, d + 1)\n",
    "    plt.imshow(best_imgs[d][0], cmap=\"gray\")\n",
    "    plt.title(f\"{d}\\nC={best_confs[d]:.2f}\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "plt.suptitle(\"Best Generated Digit per Class Selected by MNIST Oracle\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/best_generated_digits_by_oracle.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "torch.save(gen.state_dict(), \"/kaggle/working/final_digit_generator.pth\")\n",
    "\n",
    "print(\"Saved:\")\n",
    "print(\"/kaggle/working/generated_digit_quality_metrics.csv\")\n",
    "print(\"/kaggle/working/best_generated_digits_by_oracle.png\")\n",
    "print(\"/kaggle/working/final_digit_generator.pth\")"
   ]
  },
