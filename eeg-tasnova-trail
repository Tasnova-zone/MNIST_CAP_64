    "    plt.title(f\"P={int(y_pred_demo[i])}\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "plt.suptitle(\"EEG-to-Image Generation: True-Label Upper Bound vs EEG-Predicted Pipeline\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/eeg_to_image_true_vs_predicted_generation.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Summary\n",
    "# ------------------------------------------------------------\n",
    "demo_eeg_acc = (y_pred_demo == y_true_demo).float().mean().item()\n",
    "true_gen_acc = (true_gen_oracle_pred == y_true_demo).float().mean().item()\n",
    "pred_gen_acc = (pred_gen_oracle_pred == y_pred_demo).float().mean().item()\n",
    "\n",
    "print(\"\\n========== Demo Summary ==========\")\n",
    "print(f\"Demo EEG classification accuracy              : {demo_eeg_acc:.4f}\")\n",
    "print(f\"True-label generation oracle consistency      : {true_gen_acc:.4f}\")\n",
    "print(f\"EEG-predicted generation oracle consistency   : {pred_gen_acc:.4f}\")\n",
    "\n",
    "print(\"\\nSaved:\")\n",
    "print(\"/kaggle/working/eeg_to_image_demo_table.csv\")\n",
    "print(\"/kaggle/working/eeg_to_image_true_vs_predicted_generation.png\")"
