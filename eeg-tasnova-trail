    "\n",
    "class ConditionalGenerator(nn.Module):\n",
    "    def __init__(self, latent_dim=LATENT_DIM, n_classes=N_CLASSES):\n",
    "        super().__init__()\n",
    "\n",
    "        self.label_emb = nn.Embedding(n_classes, LABEL_EMB_DIM)\n",
    "\n",
    "        input_dim = latent_dim + LABEL_EMB_DIM\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(input_dim, 256),\n",
    "            nn.BatchNorm1d(256),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "\n",
    "            nn.Linear(256, 512),\n",
    "            nn.BatchNorm1d(512),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "\n",
    "            nn.Linear(512, 1024),\n",
    "            nn.BatchNorm1d(1024),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "\n",
    "            nn.Linear(1024, IMG_CHANNELS * IMG_SIZE * IMG_SIZE),\n",
    "            nn.Tanh()\n",
    "        )\n",
    "\n",
    "    def forward(self, z, labels):\n",
    "        label_vec = self.label_emb(labels)\n",
    "        x = torch.cat([z, label_vec], dim=1)\n",
    "        img = self.net(x)\n",
    "        img = img.view(-1, IMG_CHANNELS, IMG_SIZE, IMG_SIZE)\n",
    "        return img\n",
    "\n",
    "\n",
    "class ConditionalDiscriminator(nn.Module):\n",
    "    def __init__(self, n_classes=N_CLASSES):\n",
    "        super().__init__()\n",
    "\n",
    "        self.label_emb = nn.Embedding(n_classes, IMG_SIZE * IMG_SIZE)\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(IMG_CHANNELS * IMG_SIZE * IMG_SIZE * 2, 512),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "            nn.Dropout(0.3),\n",
    "\n",
    "            nn.Linear(512, 256),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "            nn.Dropout(0.3),\n",
    "\n",
    "            nn.Linear(256, 1),\n",
    "            nn.Sigmoid()\n",
    "        )\n",
    "\n",
    "    def forward(self, img, labels):\n",
    "        img_flat = img.view(img.size(0), -1)\n",
    "        label_map = self.label_emb(labels)\n",
    "        x = torch.cat([img_flat, label_map], dim=1)\n",
    "        validity = self.net(x)\n",
    "        return validity\n",
    "\n",
    "\n",
    "G = ConditionalGenerator().to(DEVICE)\n",
    "D = ConditionalDiscriminator().to(DEVICE)\n",
    "\n",
    "fixed_noise = torch.randn(N_CLASSES, LATENT_DIM, device=DEVICE)\n",
    "fixed_labels = torch.arange(N_CLASSES, device=DEVICE)\n",
    "\n",
    "def count_params(model):\n",
    "    return sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "\n",
    "print(\"Conditional GAN ready.\")\n",
    "print(\"Generator parameters    :\", count_params(G))\n",
    "print(\"Discriminator parameters:\", count_params(D))\n",
    "print(\"Fixed labels:\", fixed_labels.detach().cpu().numpy())"
   ]
