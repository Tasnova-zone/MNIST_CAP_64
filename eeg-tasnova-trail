    "        f\"D Loss: {avg_d_loss:.4f} | \"\n",
    "        f\"G Loss: {avg_g_loss:.4f}\"\n",
    "    )\n",
    "\n",
    "    if epoch == 1 or epoch % 10 == 0 or epoch == GAN_EPOCHS:\n",
    "        show_fixed_generated(epoch)\n",
    "\n",
    "\n",
    "torch.save(G.state_dict(), \"/kaggle/working/conditional_gan_generator.pth\")\n",
    "torch.save(D.state_dict(), \"/kaggle/working/conditional_gan_discriminator.pth\")\n",
