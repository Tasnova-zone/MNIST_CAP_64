ILE, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n    for line in tqdm(f, desc=\"Indexing Morlet images\"):\n        parts = line.strip().split(\",\")\n\n        if len(parts) < 3:\n            continue\n\n        split_tag = parts[0]\n        origin = int(parts[1])\n        label = int(parts[2])\n\n        if label < 0 or label > 9:\n            continue\n\n        pair_key = (origin, label)\n        if pair_key in seen_pairs:\n            continue\n        seen_pairs.add(pair_key)\n\n        img_path = os.path.join(\n            MORLET_ROOT,\n            f\"MindBigData64_Mnist2022_{split_tag}_{origin:05d}_{label}.png\"\n        )\n\n        if os.path.exists(img_path):\n            morlet_paths.append(img_path)\n            morlet_labels.append(label)\n\nX_morlet = []\n\nfor p in tqdm(morlet_paths, desc=\"Loading Morlet images\"):\n    img = Image.open(p).convert(\"L\")\n    img = img.resize((MORLET_SIZE, MORLET_SIZE))\n    img = np.array(img, dtype=np.float32) / 255.0\n    X_morlet.append(img)\n\nX_morlet = np.stack(X_morlet)[:, None, :, :].astype(np.float32)\ny_morlet = np.array(morlet_labels, dtype=np.int64)\n\nprint(\"X_morlet shape:\", X_morlet.shape)\nprint(\"y_morlet shape:\", y_morlet.shape)\nprint(\"Class counts  :\", Counter(y_morlet))\n\n\nidx_morlet = np.arange(len(y_morlet))\n\nmorlet_train_idx, morlet_test_idx = train_test_split(\n    idx_morlet,\n    test_size=0.15,\n    random_state=SEED,\n    stratify=y_morlet\n)\n\ntrain_ds = TensorDataset(\n    torch.tensor(X_morlet[morlet_train_idx], dtype=torch.float32),\n    torch.tensor(y_morlet[morlet_train_idx], dtype=torch.long)\n)\n\ntest_ds = TensorDataset(\n    torch.tensor(X_morlet[morlet_test_idx], dtype=torch.float32),\n    torch.tensor(y_morlet[morlet_test_idx], dtype=torch.long)\n)\n\ntrain_loader = DataLoader(train_ds, batch_size=MORLET_BATCH, shuffle=True, num_workers=2, pin_memory=True)\ntest_loader = DataLoader(test_ds, batch_size=MORLET_BATCH, shuffle=False, num_workers=2, pin_memory=True)\n\n\nclass MorletCNN(nn.Module):\n    def __init__(self):\n        super().__init__()\n\n        self.net = nn.Sequential(\n            nn.Conv2d(1, 16, 3, padding=1),\n            nn.BatchNorm2d(16),\n            nn.ReLU(),\n            nn.MaxPool2d(2),\n\n            nn.Conv2d(16, 32, 3, padding=1),\n            nn.BatchNorm2d(32),\n            nn.ReLU(),\n            nn.MaxPool2d(2),\n\n            nn.Conv2d(32, 64, 3, padding=1),\n            nn.BatchNorm2d(64),\n            nn.ReLU(),\n            nn.MaxPool2d(2),\n\n            nn.Flatten(),\n            nn.Dropout(0.4),\n            nn.Linear(64 * 12 * 12, 128),\n            nn.ReLU(),\n            nn.Dropout(0.3),\n            nn.Linear(128, 10)\n        )\n\n    def forward(self, x):\n        return self.net(x)\n\n\nmorlet_model = MorletCNN().to(DEVICE)\noptimizer = torch.optim.AdamW(morlet_model.parameters(), lr=7e-4, weight_decay=1e-4)\ncriterion = nn.CrossEntropyLoss()\n\nbest_acc = 0.0\nbest_bal = 0.0\nbest_f1 = 0.0\nbest_epoch = 0\nbest_state = None\n\nfor epoch in range(1, MORLET_EPOCHS + 1):\n    morlet_model.train()\n\n    for xb, yb in train_loader:\n        xb = xb.to(DEVICE, non_blocking=True)\n        yb = yb.to(DEVICE, non_blocking=True)\n\n        optimizer.zero_grad()\n        loss = criterion(morlet_model(xb), yb)\n        loss.backward()\n        optimizer.step()\n\n    acc, bal, f1 = evaluate_classifier(morlet_model, test_loader)\n\n    if acc > best_acc:\n        best_acc = acc\n        best_bal = bal\n        best_f1 = f1\n        best_epoch = epoch\n        best_state = {k: v.detach().cpu().clone() for k, v in morlet_model.state_dict().items()}\n\n    if epoch == 1 or epoch % 10 == 0:\n        print(f\"Epoch {epoch:03d}/{MORLET_EPOCHS} | Test Acc: {acc:.4f} | Best: {best_acc:.4f}\")\n\nmorlet_model.load_state_dict(best_state)\n\nmorlet_result = pd.DataFrame([\n    {\n        \"Dataset\": \"CustomCap64\",\n        \"Input\": \"Morlet image\",\n        \"Split\": \"Stratified 85/15\",\n        \"Feature/Representation\": \"Morlet scalogram\",\n        \"Model\": \"Morlet CNN\",\n        \"Accuracy\": best_acc,\n        \"Balanced Accuracy\": best_bal,\n        \"Macro F1\": best_f1,\n        \"Chance Baseline\": 1 / N_CLASSES\n    }\n])\n\nclassification_results = pd.concat(\n    [classification_results, morlet_result],\n    ignore_index=True\n)\n\nprint(\"\\n========== CustomCap64 Morlet CNN Result ==========\")\ndisplay(morlet_result)\n\nprint(\"\\n========== Updated Classification Result Table ==========\")\ndisplay(classification_results)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T14:16:50.93108Z","iopub.execute_input":"2026-06-09T14:16:50.932005Z","iopub.status.idle":"2026-06-09T14:18:46.642189Z","shell.execute_reply.started":"2026-06-09T14:16:50.931971Z","shell.execute_reply":"2026-06-09T14:18:46.641328Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Indexing Morlet images: 0it [00:00, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"d61091c30ff94a48a182b8a5fbe2b97b"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Loading Morlet images:   0%|          | 0/1161 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"68e85f2c40284bff98d149f090c8e8ae"}},"metadata":{}},{"name":"stdout","text":"X_morlet shape: (1161, 1, 96, 96)\ny_morlet shape: (1161,)\nClass counts  : Counter({np.int64(1): 139, np.int64(7): 138, np.int64(4): 120, np.int64(9): 115, np.int64(0): 114, np.int64(2): 114, np.int64(3): 109, np.int64(6): 106, np.int64(5): 104, np.int64(8): 102})\nEpoch 001/50 | Test Acc: 0.0971 | Best: 0.0971\nEpoch 010/50 | Test Acc: 0.0971 | Best: 0.0971\nEpoch 020/50 | Test Acc: 0.1200 | Best: 0.1200\nEpoch 030/50 | Test Acc: 0.1200 | Best: 0.1200\nEpoch 040/50 | Test Acc: 0.1200 | Best: 0.1200\nEpoch 050/50 | Test Acc: 0.1200 | Best: 0.1200\n\n========== CustomCap64 Morlet 