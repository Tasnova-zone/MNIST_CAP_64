    "# ============================================================\n",
    "# Cell 3 — EEG preprocessing + random and leak-safe temporal split\n",
    "# ============================================================\n",
    "\n",
    "FS = 128\n",
    "TEST_SIZE = 0.15\n",
    "\n",
    "def bandpass_filter_eeg(X_input, fs=FS):\n",
    "    b, a = butter(\n",
    "        N=4,\n",
    "        Wn=[0.5, 40],\n",
    "        btype=\"bandpass\",\n",
    "        fs=fs\n",
    "    )\n",
    "    return filtfilt(b, a, X_input, axis=-1).astype(np.float32)\n",
    "\n",
    "\n",
    "def zscore_per_trial_channel(X_input):\n",
    "    mean = X_input.mean(axis=-1, keepdims=True)\n",
    "    std = X_input.std(axis=-1, keepdims=True) + 1e-6\n",
    "    return ((X_input - mean) / std).astype(np.float32)\n",
    "\n",
    "\n",
    "# Main processed EEG used for sir-style baseline\n",
    "X_filt = bandpass_filter_eeg(X_raw)\n",
    "X = zscore_per_trial_channel(X_filt)\n",
    "\n",
    "# Random split\n",
    "def split_random():\n",
    "    idx = np.arange(len(y))\n",
    "    rng = np.random.default_rng(SEED)\n",
    "    rng.shuffle(idx)\n",
    "\n",
    "    n_test = int(len(idx) * TEST_SIZE)\n",
    "    test_idx = idx[:n_test]\n",
    "    train_idx = idx[n_test:]\n",
    "\n",
    "    return (\n",
    "        X[train_idx], y[train_idx],\n",
    "        X[test_idx], y[test_idx],\n",
    "        train_idx, test_idx\n",
    "    )\n",
    "\n",
    "\n",
    "# Leak-safe temporal split using event order\n",
    "def split_temporal():\n",
    "    sorted_idx = np.argsort(event_ids)\n",
    "\n",
    "    n_test = int(len(sorted_idx) * TEST_SIZE)\n",
    "    train_idx = sorted_idx[:-n_test]\n",
    "    test_idx = sorted_idx[-n_test:]\n",
    "\n",
    "    return (\n",
    "        X[train_idx], y[train_idx],\n",
    "        X[test_idx], y[test_idx],\n",
    "        train_idx, test_idx\n",
    "    )\n",
    "\n",
    "\n",
    "Xtr_r, ytr_r, Xte_r, yte_r, tr_idx_r, te_idx_r = split_random()\n",
    "Xtr_t, ytr_t, Xte_t, yte_t, tr_idx_t, te_idx_t = split_temporal()\n",
    "\n",
    "print(\"Processed EEG shape:\", X.shape)\n",
    "print(\"Random split:\")\n",
    "print(\"  Train:\", Xtr_r.shape, Counter(ytr_r))\n",
    "print(\"  Test :\", Xte_r.shape, Counter(yte_r))\n",
