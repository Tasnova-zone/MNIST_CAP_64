    "# ============================================================\n",
    "# Cell 18C — Full True Label × Predicted Label × Generated Digit Grid\n",
    "# ============================================================\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import confusion_matrix\n",
    "\n",
    "required_vars = [\"all_true\", \"all_pred\", \"all_conf\", \"best_digit_images\", \"N_CLASSES\"]\n",
    "missing = [v for v in required_vars if v not in globals()]\n",
    "\n",
    "if len(missing) > 0:\n",
    "    raise RuntimeError(f\"Run Cell 18 first. Missing variables: {missing}\")\n",
    "\n",
    "# Convert to numpy if needed\n",
    "all_true_np = np.array(all_true)\n",
    "all_pred_np = np.array(all_pred)\n",
    "all_conf_np = np.array(all_conf)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1) Confusion matrix count table\n",
    "# ------------------------------------------------------------\n",
    "cm = confusion_matrix(\n",
    "    all_true_np,\n",
    "    all_pred_np,\n",
    "    labels=list(range(N_CLASSES))\n",
    ")\n",
    "\n",
    "cm_df = pd.DataFrame(\n",
    "    cm,\n",
    "    index=[f\"True {i}\" for i in range(N_CLASSES)],\n",
    "    columns=[f\"Pred {i}\" for i in range(N_CLASSES)]\n",
    ")\n",
    "\n",
    "print(\"========== Full Confusion Matrix Count Table ==========\")\n",
    "display(cm_df)\n",
    "\n",
    "cm_df.to_csv(\"/kaggle/working/full_true_pred_confusion_matrix_counts.csv\")\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2) Heatmap with all True 0–9 and Predicted 0–9\n",
    "# ------------------------------------------------------------\n",
    "plt.figure(figsize=(9, 7))\n",
    "plt.imshow(cm, cmap=\"Blues\")\n",
    "\n",
    "plt.xticks(range(N_CLASSES), [f\"P{i}\" for i in range(N_CLASSES)])\n",
    "plt.yticks(range(N_CLASSES), [f\"T{i}\" for i in range(N_CLASSES)])\n",
    "\n",
    "plt.xlabel(\"EEG Predicted Label\")\n",
    "plt.ylabel(\"True EEG Label\")\n",
    "plt.title(\"Full Confusion Matrix: True Label vs EEG Predicted Label\")\n",
    "\n",
    "for i in range(N_CLASSES):\n",
    "    for j in range(N_CLASSES):\n",
    "        plt.text(\n",
    "            j, i, str(cm[i, j]),\n",
    "            ha=\"center\",\n",
    "            va=\"center\",\n",
    "            fontsize=9\n",
    "        )\n",
    "\n",
    "plt.colorbar(label=\"Number of Samples\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/full_true_pred_confusion_matrix_heatmap.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3) Full True × Predicted × Generated digit grid\n",
    "#    If count > 0: show generated image for predicted label\n",
    "#    If count = 0: blank cell\n",
    "# ------------------------------------------------------------\n",
    "fig, axes = plt.subplots(\n",
    "    N_CLASSES,\n",
    "    N_CLASSES,\n",
    "    figsize=(16, 16)\n",
    ")\n",
    "\n",
    "for true_label in range(N_CLASSES):\n",
    "    for pred_label in range(N_CLASSES):\n",
    "\n",
    "        ax = axes[true_label, pred_label]\n",
    "        count = cm[true_label, pred_label]\n",
    "\n",
    "        if count > 0:\n",
    "            ax.imshow(best_digit_images[pred_label, 0], cmap=\"gray\")\n",
    "            ax.set_title(f\"n={count}\", fontsize=7)\n",
    "        else:\n",
    "            ax.imshow(np.zeros((28, 28)), cmap=\"gray\")\n",
    "            ax.set_title(\"0\", fontsize=7)\n",
    "\n",
    "        ax.axis(\"off\")\n",
    "\n",
    "        # Column header\n",
    "        if true_label == 0:\n",
    "            ax.text(\n",
    "                0.5, 1.25,\n",
    "                f\"Pred {pred_label}\",\n",
    "                transform=ax.transAxes,\n",
    "                ha=\"center\",\n",
    "                va=\"bottom\",\n",
    "                fontsize=9,\n",
    "                fontweight=\"bold\"\n",
    "            )\n",
    "\n",
    "        # Row header\n",
    "        if pred_label == 0:\n",
    "            ax.text(\n",
    "                -0.35, 0.5,\n",
    "                f\"True {true_label}\",\n",
    "                transform=ax.transAxes,\n",
    "                ha=\"right\",\n",
    "                va=\"center\",\n",
    "                fontsize=9,\n",
    "                fontweight=\"bold\",\n",
    "                rotation=90\n",
    "            )\n",
    "\n",
    "plt.suptitle(\n",
    "    \"Full True Label vs EEG Prediction vs Generated Digit Grid\",\n",
    "    fontsize=16,\n",
    "    y=0.92\n",
    ")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/full_true_pred_generated_digit_grid.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 4) Compact supervisor-friendly table:\n",
    "#    Most frequent prediction per true class\n",
    "# ------------------------------------------------------------\n",
    "summary_rows = []\n",
    "\n",
    "for true_label in range(N_CLASSES):\n",
    "    most_pred = int(np.argmax(cm[true_label]))\n",
    "    count = int(cm[true_label, most_pred])\n",
    "    total = int(cm[true_label].sum())\n",
    "\n",
    "    summary_rows.append({\n",
    "        \"True EEG Label\": true_label,\n",
    "        \"Most Frequent Predicted Label\": most_pred,\n",
    "        \"Generated Label\": most_pred,\n",
    "        \"Count\": count,\n",
    "        \"Total True Samples\": total,\n",
    "        \"Percentage\": count / total if total > 0 else 0\n",
    "    })\n",
    "\n",
    "summary_df = pd.DataFrame(summary_rows)\n",
    "\n",
    "print(\"========== Compact Summary: True → Most Frequent Prediction → Generated ==========\")\n",
    "display(summary_df)\n",
    "\n",
    "summary_df.to_csv(\n",
    "    \"/kaggle/working/compact_true_most_pred_generated_summary.csv\",\n",
    "    index=False\n",
    ")\n",
    "\n",
    "print(\"Saved:\")\n",
    "print(\"/kaggle/working/full_true_pred_confusion_matrix_counts.csv\")\n",
    "print(\"/kaggle/working/full_true_pred_confusion_matrix_heatmap.png\")\n",
    "print(\"/kaggle/working/full_true_pred_generated_digit_grid.png\")\n",
    "print(\"/kaggle/working/compact_true_most_pred_generated_summary.csv\")"
   ]
  },
