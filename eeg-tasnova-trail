    "# ============================================================\n",
    "# Cell 18 — Full test-set EEG-to-image evaluation summary\n",
    "# ============================================================\n",
    "\n",
    "torch.cuda.empty_cache()\n",
    "\n",
    "best_eeg_model.eval()\n",
    "gen.eval()\n",
    "oracle.eval()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1) Predict EEG labels on full test set\n",
    "# ------------------------------------------------------------\n",
    "test_loader_eval = DataLoader(\n",
    "    TensorDataset(\n",
    "        torch.tensor(Xte_t, dtype=torch.float32),\n",
    "        torch.tensor(yte_t, dtype=torch.long)\n",
    "    ),\n",
    "    batch_size=256,\n",
    "    shuffle=False\n",
    ")\n",
    "\n",
    "all_true = []\n",
    "all_pred = []\n",
    "all_conf = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for xb, yb in test_loader_eval:\n",
    "        xb = xb.to(DEVICE)\n",
    "        logits = best_eeg_model(xb)\n",
    "        probs = torch.softmax(logits, dim=1)\n",
    "\n",
    "        pred = probs.argmax(dim=1)\n",
    "        conf = probs.max(dim=1).values\n",
    "\n",
    "        all_true.append(yb.cpu())\n",
    "        all_pred.append(pred.cpu())\n",
    "        all_conf.append(conf.cpu())\n",
    "\n",
    "all_true = torch.cat(all_true).numpy()\n",
    "all_pred = torch.cat(all_pred).numpy()\n",
    "all_conf = torch.cat(all_conf).numpy()\n",
    "\n",
    "full_eeg_acc = accuracy_score(all_true, all_pred)\n",
    "full_eeg_bal = balanced_accuracy_score(all_true, all_pred)\n",
    "full_eeg_f1 = f1_score(all_true, all_pred, average=\"macro\")\n",
    "\n",
    "print(\"Full test EEG classification:\")\n",
    "print(\"Accuracy          :\", round(full_eeg_acc, 4))\n",
    "print(\"Balanced Accuracy :\", round(full_eeg_bal, 4))\n",
    "print(\"Macro F1          :\", round(full_eeg_f1, 4))\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2) Build one clean oracle-selected generated image per digit\n",
    "# ------------------------------------------------------------\n",
    "SAMPLES_PER_DIGIT = 128\n",
    "\n",
    "best_digit_images = []\n",
    "best_digit_conf = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for d in range(N_CLASSES):\n",
    "        labels = torch.full((SAMPLES_PER_DIGIT,), d, dtype=torch.long, device=DEVICE)\n",
    "        z = torch.randn(SAMPLES_PER_DIGIT, Z_DIM, device=DEVICE)\n",
    "\n",
    "        imgs = gen(z, labels)\n",
    "        imgs = ((imgs + 1.0) / 2.0).clamp(0, 1)\n",
    "\n",
    "        probs = torch.softmax(oracle(imgs), dim=1)\n",
    "        target_conf = probs[:, d]\n",
    "\n",
    "        best_idx = target_conf.argmax()\n",
    "\n",
    "        best_digit_images.append(imgs[best_idx].detach().cpu())\n",
    "        best_digit_conf.append(float(target_conf[best_idx].item()))\n",
    "\n",
    "best_digit_images = torch.stack(best_digit_images)\n",
    "\n",
    "plt.figure(figsize=(10, 2.4))\n",
    "for d in range(N_CLASSES):\n",
    "    plt.subplot(1, N_CLASSES, d + 1)\n",
    "    plt.imshow(best_digit_images[d, 0], cmap=\"gray\")\n",
    "    plt.title(f\"{d}\\nC={best_digit_conf[d]:.2f}\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "plt.suptitle(\"Final Oracle-selected Generated Digit Template per Class\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/final_oracle_selected_generated_digits.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3) End-to-end EEG-to-image consistency\n",
    "# ------------------------------------------------------------\n",
    "pred_tensor = torch.tensor(all_pred, dtype=torch.long)\n",
    "generated_from_pred = best_digit_images[pred_tensor].to(DEVICE)\n",
    "\n",
    "with torch.no_grad():\n",
    "    oracle_logits = oracle(generated_from_pred)\n",
    "    oracle_probs = torch.softmax(oracle_logits, dim=1)\n",
