    "    gen_oracle_conf = oracle_probs.max(dim=1).values.cpu().numpy()\n",
    "\n",
    "generation_follows_pred_acc = accuracy_score(all_pred, gen_oracle_pred)\n",
    "end_to_end_true_acc = accuracy_score(all_true, gen_oracle_pred)\n",
