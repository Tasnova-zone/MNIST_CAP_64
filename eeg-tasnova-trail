    "# ============================================================\n",
    "# Cell 14D — MNIST oracle classifier + class prototypes\n",
    "# ============================================================\n",
    "\n",
    "torch.cuda.empty_cache()\n",
    "\n",
    "ORACLE_BATCH = 256\n",
    "ORACLE_EPOCHS = 3\n",
    "\n",
    "oracle_transform = transforms.ToTensor()\n",
    "\n",
    "mnist_oracle_train = datasets.MNIST(\n",
    "    root=MNIST_ROOT,\n",
    "    train=True,\n",
    "    download=True,\n",
    "    transform=oracle_transform\n",
    ")\n",
    "\n",
    "mnist_oracle_test = datasets.MNIST(\n",
    "    root=MNIST_ROOT,\n",
    "    train=False,\n",
    "    download=True,\n",
    "    transform=oracle_transform\n",
    ")\n",
    "\n",
    "oracle_train_loader = DataLoader(\n",
    "    mnist_oracle_train,\n",
    "    batch_size=ORACLE_BATCH,\n",
    "    shuffle=True,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "oracle_test_loader = DataLoader(\n",
    "    mnist_oracle_test,\n",
    "    batch_size=ORACLE_BATCH,\n",
    "    shuffle=False,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "\n",
    "class MNISTOracleCNN(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "\n",
    "        self.features = nn.Sequential(\n",
    "            nn.Conv2d(1, 32, 3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.Conv2d(32, 64, 3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2),\n",
    "\n",
    "            nn.Conv2d(64, 128, 3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2)\n",
    "        )\n",
    "\n",
    "        self.classifier = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(128 * 7 * 7, 256),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.25),\n",
    "            nn.Linear(256, 10)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.classifier(self.features(x))\n",
    "\n",
    "\n",
    "oracle_model = MNISTOracleCNN().to(DEVICE)\n",
    "optimizer = torch.optim.Adam(oracle_model.parameters(), lr=1e-3)\n",
    "criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "for epoch in range(1, ORACLE_EPOCHS + 1):\n",
    "    oracle_model.train()\n",
    "\n",
    "    for xb, yb in oracle_train_loader:\n",
    "        xb = xb.to(DEVICE, non_blocking=True)\n",
    "        yb = yb.to(DEVICE, non_blocking=True)\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "        loss = criterion(oracle_model(xb), yb)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "\n",
    "    oracle_model.eval()\n",
    "    correct = 0\n",
    "    total = 0\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for xb, yb in oracle_test_loader:\n",
    "            xb = xb.to(DEVICE, non_blocking=True)\n",
    "            yb = yb.to(DEVICE, non_blocking=True)\n",
    "\n",
    "            pred = oracle_model(xb).argmax(dim=1)\n",
    "            correct += (pred == yb).sum().item()\n",
    "            total += yb.size(0)\n",
    "\n",
    "    print(f\"Oracle Epoch {epoch}/{ORACLE_EPOCHS} | Test Acc: {correct / total:.4f}\")\n",
    "\n",
    "oracle_model.eval()\n",
    "for p in oracle_model.parameters():\n",
    "    p.requires_grad = False\n",
    "\n",
    "\n",
    "# Build class prototype images from normalized MNIST loader [-1, 1]\n",
    "prototype_sum = torch.zeros(N_CLASSES, 1, 28, 28)\n",
    "prototype_count = torch.zeros(N_CLASSES)\n",
    "\n",
    "for imgs, labels in mnist_loader:\n",
    "    for d in range(N_CLASSES):\n",
    "        mask = labels == d\n",
    "        if mask.sum() > 0:\n",
    "            prototype_sum[d] += imgs[mask].sum(dim=0)\n",
    "            prototype_count[d] += mask.sum()\n",
    "\n",
    "mnist_class_prototypes = prototype_sum / prototype_count.view(-1, 1, 1, 1)\n",
    "mnist_class_prototypes = mnist_class_prototypes.to(DEVICE)\n",
    "\n",
    "plt.figure(figsize=(10, 2))\n",
    "for d in range(N_CLASSES):\n",
    "    img = mnist_class_prototypes[d, 0].detach().cpu().numpy()\n",
    "    img = (img + 1) / 2\n",
    "\n",
    "    plt.subplot(1, 10, d + 1)\n",
    "    plt.imshow(img, cmap=\"gray\")\n",
    "    plt.title(str(d))\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "plt.suptitle(\"MNIST Class Prototypes for Structure-Guided Generation\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Oracle and class prototypes ready.\")"
