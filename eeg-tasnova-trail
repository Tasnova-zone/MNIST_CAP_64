    "# ============================================================\n",
    "# Cell 14B — Better Conditional DCGAN model definition\n",
    "# ============================================================\n",
    "\n",
    "LATENT_DIM = 100\n",
    "IMG_SIZE = 28\n",
    "IMG_CHANNELS = 1\n",
    "LABEL_EMB_DIM = 50\n",
    "\n",
    "class BetterConditionalGenerator(nn.Module):\n",
    "    def __init__(self, latent_dim=LATENT_DIM, n_classes=N_CLASSES):\n",
    "        super().__init__()\n",
    "        \n",
    "        self.label_emb = nn.Embedding(n_classes, LABEL_EMB_DIM)\n",
    "        \n",
    "        self.fc = nn.Sequential(\n",
    "            nn.Linear(latent_dim + LABEL_EMB_DIM, 128 * 7 * 7),\n",
    "            nn.BatchNorm1d(128 * 7 * 7),\n",
    "            nn.ReLU(True)\n",
    "        )\n",
    "        \n",
    "        self.conv = nn.Sequential(\n",
    "            nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1),\n",
    "            nn.BatchNorm2d(64),\n",
    "            nn.ReLU(True),\n",
    "            \n",
    "            nn.ConvTranspose2d(64, 32, kernel_size=4, stride=2, padding=1),\n",
    "            nn.BatchNorm2d(32),\n",
    "            nn.ReLU(True),\n",
    "            \n",
    "            nn.Conv2d(32, 1, kernel_size=3, stride=1, padding=1),\n",
    "            nn.Tanh()\n",
    "        )\n",
    "        \n",
    "    def forward(self, z, labels):\n",
    "        label_vec = self.label_emb(labels)\n",
    "        x = torch.cat([z, label_vec], dim=1)\n",
    "        x = self.fc(x)\n",
    "        x = x.view(x.size(0), 128, 7, 7)\n",
    "        img = self.conv(x)\n",
    "        return img\n",
    "\n",
    "\n",
    "class BetterConditionalDiscriminator(nn.Module):\n",
    "    def __init__(self, n_classes=N_CLASSES):\n",
    "        super().__init__()\n",
    "        \n",
    "        self.label_emb = nn.Embedding(n_classes, IMG_SIZE * IMG_SIZE)\n",
    "        \n",
    "        self.conv = nn.Sequential(\n",
    "            nn.Conv2d(2, 64, kernel_size=4, stride=2, padding=1),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "            nn.Dropout2d(0.25),\n",
    "            \n",
    "            nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1),\n",
    "            nn.BatchNorm2d(128),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "            nn.Dropout2d(0.25)\n",
    "        )\n",
    "        \n",
    "        self.fc = nn.Linear(128 * 7 * 7, 1)\n",
    "        \n",
    "    def forward(self, img, labels):\n",
    "        label_map = self.label_emb(labels)\n",
    "        label_map = label_map.view(labels.size(0), 1, IMG_SIZE, IMG_SIZE)\n",
    "        \n",
    "        x = torch.cat([img, label_map], dim=1)\n",
    "        x = self.conv(x)\n",
    "        x = x.view(x.size(0), -1)\n",
    "        out = self.fc(x)\n",
    "        return out\n",
    "\n",
    "\n",
    "G = BetterConditionalGenerator().to(DEVICE)\n",
    "D = BetterConditionalDiscriminator().to(DEVICE)\n",
    "\n",
    "fixed_noise = torch.randn(N_CLASSES, LATENT_DIM, device=DEVICE)\n",
    "fixed_labels = torch.arange(N_CLASSES, device=DEVICE)\n",
    "\n",
    "def count_params(model):\n",
    "    return sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
