","source":"# Cell 15 Final  Conditional DCGAN for MNIST digit generation","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 15 Final — Sir-style Conditional DCGAN for MNIST digit generation\n# ============================================================\n\ntorch.cuda.empty_cache()\n\nZ_DIM = 100\nGAN_EPOCHS = 30\nGAN_BATCH = 128\n\nclass SirStyleGenerator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.emb = nn.Embedding(N_CLASSES, N_CLASSES)\n\n        self.fc = nn.Linear(Z_DIM + N_CLASSES, 128 * 7 * 7)\n\n        self.net = nn.Sequential(\n            nn.BatchNorm2d(128),\n            nn.ReLU(True),\n\n            nn.ConvTranspose2d(128, 64, 4, 2, 1),\n            nn.BatchNorm2d(64),\n            nn.ReLU(True),\n\n            nn.ConvTranspose2d(64, 1, 4, 2, 1),\n            nn.Tanh()\n        )\n\n    def forward(self, z, labels):\n        x = torch.cat([z, self.emb(labels)], dim=1)\n        x = self.fc(x)\n        x = x.view(-1, 128, 7, 7)\n        return self.net(x)\n\n\nclass SirStyleDiscriminator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.emb = nn.Embedding(N_CLASSES, 28 * 28)\n\n        self.net = nn.Sequential(\n            nn.Conv2d(2, 64, 4, 2, 1),\n            nn.LeakyReLU(0.2, True),\n\n            nn.Conv2d(64, 128, 4, 2, 1),\n            nn.BatchNorm2d(128),\n            nn.LeakyReLU(0.2, True),\n\n            nn.Flatten(),\n            nn.Linear(128 * 7 * 7, 1)\n        )\n\n    def forward(self, img, labels):\n        label_map = self.emb(labels).view(-1, 1, 28, 28)\n        x = torch.cat([img, label_map], dim=1)\n        return self.net(x)\n\n\ngen = SirStyleGenerator().to(DEVICE)\ndis = SirStyleDiscriminator().to(DEVICE)\n\nopt_G = torch.optim.Adam(gen.parameters(), lr=2e-4, betas=(0.5, 0.999))\nopt_D = torch.optim.Adam(dis.parameters(), lr=2e-4, betas=(0.5, 0.999))\n\nbce = nn.BCEWithLogitsLoss()\n\nfixed_z = torch.randn(N_CLASSES, Z_DIM, device=DEVICE)\nfixed_labels = torch.arange(N_CLASSES, device=DEVICE)\n\ndef show_generated_digits(epoch):\n    gen.eval()\n    with torch.no_grad():\n        samples = gen(fixed_z, fixed_labels)\n        samples = (samples + 1) / 2\n        samples = samples.detach().cpu()\n\n    plt.figure(figsize=(10, 2))\n    for d in range(N_CLASSES):\n        plt.subplot(1, N_CLASSES, d + 1)\n        plt.imshow(samples[d, 0], cmap=\"gray\")\n        plt.title(str(d))\n        plt.axis(\"off\")\n\n    plt.suptitle(f\"Sir-style Conditional DCGAN | Epoch {epoch}\")\n    plt.tight_layout()\n    plt.show()\n    gen.train()\n\n\nG_losses = []\nD_losses = []\n\nfor ep in range(1, GAN_EPOCHS + 1):\n    gen.train()\n    dis.train()\n\n    total_g_loss = 0.0\n    total_d_loss = 0.0\n    total_batches = 0\n\n    for real, labels in mnist_loader:\n        real = real.to(DEVICE, non_blocking=True)\n        labels = labels.to(DEVICE, non_blocking=True)\n\n        bs = real.size(0)\n\n        ones = torch.ones(bs, 1, device=DEVICE)\n        zeros = torch.zeros(bs, 1, device=DEVICE)\n\n        # Train Discriminator\n        z = torch.randn(bs, Z_DIM, device=DEVICE)\n        fake = gen(z, labels)\n\n        d_real = bce(dis(real, labels), ones)\n        d_fake = bce(dis(fake.detach(), labels), zeros)\n        d_loss = d_real + d_fake\n\n        opt_D.zero_grad()\n        d_loss.backward()\n        opt_D.step()\n\n        # Train Generator\n        g_loss = bce(dis(fake, labels), ones)\n\n        opt_G.zero_grad()\n        g_loss.backward()\n        opt_G.step()\n\n        total_d_loss += d_loss.item()\n        total_g_loss += g_loss.item()\n        total_batches += 1\n\n    avg_d = total_d_loss / total_batches\n    avg_g = total_g_loss / total_batches\n\n    D_losses.append(avg_d)\n    G_losses.append(avg_g)\n\n    print(f\"Epoch {ep:03d}/{GAN_EPOCHS} | D Loss: {avg_d:.4f} | G Loss: {avg_g:.4f}\")\n\n    if ep == 1 or ep % 5 == 0 or ep == GAN_EPOCHS:\n        show_generated_digits(ep)\n\n\ntorch.save(gen.state_dict(), \"/kaggle/working/sir_style_conditional_dcgan_generator.pth\")\ntorch.save(dis.state_dict(), \"/kaggle/working/sir_style_conditional_dcgan_discriminator.pth\")\n\nplt.figure(figsize=(7, 4))\nplt.plot(G_losses, label=\"Generator Loss\")\nplt.plot(D_losses, label=\"Discriminator Loss\")\nplt.xlabel(\"Epoch\")\nplt.ylabel(\"Loss\")\nplt.title(\" Conditional DCGAN Training Loss\")\nplt.legend()\nplt.tight_layout()\nplt.savefig(\"/kaggle/working/sir_style_conditional_dcgan_loss.png\", dpi=300)\nplt.show()\n\nprint(\"Saved:\")\nprint(\"/kaggle/working/sir_style_conditional_dcgan_generator.pth\")\nprint(\"/kaggle/working/sir_style_conditional_dcgan_discriminator.pth\")\nprint(\"/kaggle/working/sir_style_conditional_dcgan_loss.png\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T16:31:17.828013Z","iopub.execute_input":"2026-06-09T16:31:17.828554Z","iopub.status.idle":"2026-06-09T16:35:51.220592Z","shell.execute_reply.started":"2026-06-09T16:31:17.828508Z","shell.execute_reply":"2026-06-09T16:35:51.219667Z"}},"outputs":[{"name":"stdout","text":"Epoch 001/30 | D Loss: 0.7559 | G Loss: 1.4627\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x200 with 10 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Epoch 002/30 | D Loss: 0.6355 | G Loss: 1.6400\nEpoch 003/30 | D Loss: 0.6132 | G Loss: 1.7974\nEpoch 004/30 | D Loss: 0.7277 | G Loss: 1.6148\nEpoch 005/30 | D Loss: 0.7967 | G Loss: 1.4995\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x200 with 10 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Epoch 006/30 | D Loss: 0.8424 | G Loss: 1.4430\nEpoch 007/30 | D Loss: 0.8768 | G Loss: 1.4072\nEpoch 008/30 | D Loss: 0.8901 | G Loss: 1.3948\nEpoch 009/30 | D Loss: 0.9114 | G Loss: 1.3759\nEpoch 010/30 | D Loss: 0.9207 | G Loss: 1.3669\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x200 with 10 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Epoch 011/30 | D Loss: 0.9333 | G Loss: 1.3603\nEpoch 012/30 | D Loss: 0.9373 | G Loss: 1.3562\nEpoch 013/30 | D Loss: 0.9448 | G Loss: 1.3476\nEpoch 014/30 | D Loss: 0.9401 | G Loss: 1.3500\nEpoch 015/30 | D Loss: 0.9531 | G Loss: 1.3504\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x200 with 10 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Epoch 016/30 | D Loss: 0.9498 | G Loss: 1.3531\nEpoch 017/30 | D Loss: 0.9484 | G Loss: 1.3633\nEpoch 018/30 | D Loss: 0.9474 | G Loss: 1.3605\nEpoch 019/30 | D Loss: 0.9415 | G Loss: 1.3724\nEpoch 020/30 | D Loss: 0.9527 | G Loss: 1.3713\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x200 with 10 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Epoch 021/30 | D Loss: 0.9428 | G Loss: 1.3841\nEpoch 022/30 | D Loss: 0.9494 | G Loss: 1.3811\nEpoch 023/30 | D Loss: 0.9436 | G Loss: 1.3912\nEpoch 024/30 | D Loss: 0.9452 | G Loss: 1.3958\nEpoch 025/30 | D Loss: 0.9438 | G Loss: 1.3996\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x200 with 10 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Epoch 026/30 | D Loss: 0.9467 | G Loss: 1.3996\nEpoch 027/30 | D Loss: 0.9446 | G Loss: 1.4061\nEpoch 028/30 | D Loss: 0.9421 | G Loss: 1.4115\nEpoch 029/30 | D Loss: 0.9463 | G Loss: 1.4203\nEpoch 030/30 | D Loss: 0.9425 | G Loss: 1.4128\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x200 with 10 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 700x400 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved:\n/kaggle/working/sir_style_conditional_dcgan_generator.pth\n/kaggle/working/sir_style_conditional_dcgan_discriminator.pth\n/kaggle/working/sir_style_conditional_dcgan_loss.png\n","output_type":"stream"}],"execution_count":27},{"cell_type":"markdown","source":"# Cell 16 — Evaluate generated digits using MNIST oracle + PSNR/SSIM","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 16 — Evaluate generated digits using MNIST oracle + PSNR/SSIM\n# ============================================================\n\ntorch.cuda.empty_cache()\n\nORACLE_BATCH = 256\nORACLE_EPOCHS = 3\nSAMPLES_PER_DIGIT = 64\n\n# -----------------------------\n# MNIST oracle classifier\n# -----------------------------\noracle_transform = transforms.ToTensor()\n\noracle_train_ds = datasets.MNIST(\n    root=MNIST_ROOT,\n    train=True,\n    download=True,\n    transform=oracle_transform\n)\n\noracle_test_ds = datasets.MNIST(\n    root=MNIST_ROOT,\n    train=False,\n    download=True,\n    transform=oracle_transform\n)\n\noracle_train_loader = DataLoader(\n    oracle_train_ds,\n    batch_size=ORACLE_BATCH,\n    shuffle=True,\n    num_workers=2,\n    pin_memory=True\n)\n\noracle_test_loader = DataLoader(\n    oracle_test_ds,\n    batch_size=ORACLE_BATCH,\n    shuffle=False,\n    num_workers=2,\n    pin_memory=True\n)\n\nclass MNISTOracleCNN(nn.Module):\n    def __init__(self):\n        super().__init__()\n\n        self.net = nn.Sequential(\n            nn.Conv2d(1, 32, 3, padding=1),\n            nn.ReLU(),\n            nn.MaxPool2d(2),\n\n            nn.Conv2d(32, 64, 3, padding=1),\n            nn.ReLU(),\n            nn.MaxPool2d(2),\n\n            nn.Flatten(),\n            nn.Linear(64 * 7 * 7, 128),\n            nn.ReLU(),\n            nn.Linear(128, 10)\n        )\n\n    def forward(self, x):\n        return self.net(x)\n\noracle = MNISTOracleCNN().to(DEVICE)\nopt_oracle = torch.optim.Adam(oracle.parameters(), lr=1e-3)\nce_loss = nn.CrossEntropyLoss()\n\nfor ep in range(1, ORACLE_EPOCHS + 1):\n    oracle.train()\n\n    for xb, yb in oracle_train_loader:\n        xb = xb.to(DEVICE, non_blocking=True)\n        yb = yb.to(DEVICE, non_blocking=True)\n\n        opt_oracle.zero_grad()\n        loss = ce_loss(oracle(xb), yb)\n        loss.backward()\n        opt_oracle.step()\n\n    oracle.eval()\n    correct = 0\n    total = 0\n\n    with torch.no_grad():\n        for xb, yb in oracle_test_loader:\n            xb = xb.to(DEVICE, non_blocking=True)\n            yb = yb.to(DEVICE, non_blocking=True)\n\n            pred = oracle(xb).argmax(dim=1)\n            correct += (pred == yb).sum().item()\n            total += yb.size(0)\n\n    print(f\"Oracle Epoch {ep}/{ORACLE_EPOCHS} | Test Accuracy: {correct / total:.4f}\")\n\noracle.eval()\n\n\n# -----------------------------\n# Build MNIST class prototypes\n# -----------------------------\nproto_sum = torch.zeros(N_CLASSES, 1, 28, 28, device=DEVICE)\nproto_count = torch.zeros(N_CLASSES, device=DEVICE)\n\nwith torch.no_grad():\n    for xb, yb in oracle_train_loader:\n        xb = xb.to(DEVICE, non_blocking=True)\n        yb = yb.to(DEVICE, non_blocking=True)\n\n        for d in range(N_CLASSES):\n            mask = yb == d\n            if mask.sum() > 0:\n                proto_sum[d] += xb[mask].sum(dim=0)\n                proto_count[d] += mask.sum()\n\nmnist_prototypes = proto_sum / proto_count.view(-1, 1, 1, 1)\n\n\n# -----------------------------\n# Generate multiple samples per digit\n# -----------------------------\ngen.eval()\n\nall_labels = torch.arange(N_CLASSES, device=DEVICE).repeat_interleave(SAMPLES_PER_DIGIT)\nz = torch.randn(len(all_labels), Z_DIM, device=DEVICE)\n\nwith torch.no_grad():\n    generated = gen(z, all_labels)\n    generated = ((generated + 1.0) / 2.0).clamp(0, 1)\n\n    logits = oracle(generated)\n    probs = torch.softmax(logits, dim=1)\n    pred = probs.argmax(dim=1)\n    target_conf = probs.gather(1, all_labels.view(-1, 1)).squeeze(1)\n\n\n# -----------------------------\n# PSNR and simple SSIM vs prototype\n# -----------------------------\ntarget_proto = mnist_prototypes[all_labels]\n\nmse = torch.mean((generated - target_proto) ** 2, dim=(1, 2, 3))\npsnr = 10 * torch.log10(1.0 / (mse + 1e-8))\n\ndef simple_ssim_batch(x, y):\n    C1 = 0.01 ** 2\n    C2 = 0.03 ** 2\n\n    mu_x = x.mean(dim=(1, 2, 3))\n    mu_y = y.mean(dim=(1, 2, 3))\n\n    var_x = ((x - mu_x.view(-1, 1, 1, 1)) ** 2).mean(dim=(1, 2, 3))\n    var_y = ((y - mu_y.view(-1, 1, 1, 1)) ** 2).mean(dim=(1, 2, 3))\n\n    cov_xy = (\n        (x - mu_x.view(-1, 1, 1, 1)) *\n        (y - mu_y.view(-1, 1, 1, 1))\n    ).mean(dim=(1, 2, 3))\n\n    ssim = (\n        ((2 * mu_x * mu_y + C1) * (2 * cov_xy + C2)) /\n        ((mu_x ** 2 + mu_y ** 2 + C1) * (var_x + var_y + C2))\n    )\n\n    return ssim\n\nssim = simple_ssim_batch(generated, target_proto)\n\n\n# -----------------------------\n# Summary table\n# -----------------------------\nrows = []\n\nfor d in range(N_CLASSES):\n    mask = all_labels == d\n\n    rows.append({\n        \"Digit\": d,\n        \"Oracle Accuracy\": float((pred[mask] == all_labels[mask]).float().mean().item()),\n        \"Mean Oracle Confidence\": float(target_conf[mask].mean().item()),\n        \"Mean PSNR\": float(psnr[mask].mean().item()),\n        \"Mean SSIM\": float(ssim[mask].mean().item())\n    })\n\ngeneration_metrics = pd.DataFrame(rows)\n\noverall_row = pd.DataFrame([{\n    \"Digit\": \"Overall\",\n    \"Oracle Accuracy\": float((pred == all_labels).float().mean().item()),\n    \"Mean Oracle Confidence\": float(target_conf.mean().item()),\n    \"Mean PSNR\": float(psnr.mean().item()),\n    \"Mean SSIM\": float(ssim.mean().item())\n}])\n\ngeneration_metrics_full = pd.concat([generation_metrics, overall_row], ignore_index=True)\n\nprint(\"\\n========== Generated Digit Quality Metrics ==========\")\ndisplay(generation_metrics_full)\n\ngeneration_metrics_full.to_csv(\n    \"/kaggle/working/generated_digit_quality_metrics.csv\",\n    index=False\n)\n\n\n# -----------------------------\n# Best sample per digit by oracle confidence\n# -----------------------------\nbest_imgs = []\nbest_confs = []\n\nfor d in range(N_CLASSES):\n    mask_idx = torch.where(all_labels == d)[0]\n    best_local = torch.argmax(target_conf[mask_idx])\n    best_idx = mask_idx[best_local]\n\n    best_imgs.append(generated[best_idx].detach().cpu())\n    best_confs.append(float(target_conf[best_idx].item()))\n\nplt.figure(figsize=(10, 2.4))\n\nfor d in range(N_CLASSES):\n    plt.subplot(1, N_CLASSES, d + 1)\n    plt.imshow(best_imgs[d][0], cmap=\"gray\")\n    plt.title(f\"{d}\\nC={best_confs[d]:.2f}\")\n    plt.axis(\"off\")\n\nplt.suptitle(\"Best Generated Digit per Class Selected by MNIST Oracle\")\nplt.tight_layout()\nplt.savefig(\"/kaggle/working/best_generated_digits_by_oracle.png\", dpi=300)\nplt.show()\n\ntorch.save(gen.state_dict(), \"/kaggle/working/final_digit_generator.pth\")\n\nprint(\"Saved:\")\nprint(\"/kaggle/working/generated_digit_quality_metrics.csv\")\nprint(\"/kaggle/working/best_generated_digits_by_oracle.png\")\nprint(\"/kaggle/working/final_digit_generator.pth\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T16:57:00.605121Z","iopub.execute_input":"2026-06-09T16:57:00.606137Z","iopub.status.idle":"2026-06-09T16:57:20.357409Z","shell.execute_reply.started":"2026-06-09T16:57:00.606072Z","shell.execute_reply":"2026-06-09T16:57:20.356402Z"}},"outputs":[{"name":"stdout","text":"Oracle Epoch 1/3 | Test Accuracy: 0.9734\nOracle Epoch 2/3 | Test Accuracy: 0.9822\nOracle Epoch 3/3 | Test Accuracy: 0.9879\n\n========== Generated Digit Quality Metrics ==========\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"      Digit  Oracle Accuracy  Mean Oracle Confidence  Mean PSNR  Mean SSIM\n0         0         1.000000                0.997686  12.170021   0.637669\n1         1         1.000000                0.998959  16.002275   0.690841\n2         2         1.000000                0.993161  11.893995   0.557653\n3      