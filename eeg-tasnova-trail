    "# ============================================================\n",
    "# Cell 7 — Parse CustomCap64 raw EEG dataset\n",
    "# ============================================================\n",
    "\n",
    "CAP64_FILE = \"/kaggle/input/datasets/tasnovaislam2008002/mnist-cap-64/MindBigData64_Mnist2022-EEGv0.016.txt\"\n",
    "\n",
    "CAP64_CHANNELS = 64\n",
    "CAP64_LEN = 400\n",
    "\n",
    "def parse_cap64_dataset(filepath):\n",
    "    X_list = []\n",
    "    y_list = []\n",
    "    img_list = []\n",
    "    seen_pairs = set()\n",
    "\n",
    "    with open(filepath, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
    "        for line in tqdm(f, desc=\"Parsing CustomCap64\"):\n",
    "            parts = line.strip().split(\",\")\n",
    "\n",
    "            if len(parts) < 3 + 784 + 1 + (CAP64_CHANNELS * CAP64_LEN):\n",
    "                continue\n",
    "\n",
    "            split_tag = parts[0]\n",
    "            origin = int(parts[1])\n",
    "            label = int(parts[2])\n",
    "\n",
    "            if label < 0 or label > 9:\n",
    "                continue\n",
    "\n",
    "            pair_key = (origin, label)\n",
    "            if pair_key in seen_pairs:\n",
    "                continue\n",
    "            seen_pairs.add(pair_key)\n",
    "\n",
    "            img_start = 3\n",
    "            img_end = img_start + 784\n",
    "\n",
    "            img = np.array(parts[img_start:img_end], dtype=np.float32).reshape(28, 28) / 255.0\n",
    "\n",
    "            eeg_start = img_end + 1\n",
    "            eeg_end = eeg_start + (CAP64_CHANNELS * CAP64_LEN)\n",
    "\n",
    "            eeg = np.array(parts[eeg_start:eeg_end], dtype=np.float32).reshape(CAP64_CHANNELS, CAP64_LEN)\n",
    "\n",
    "            X_list.append(eeg)\n",
    "            y_list.append(label)\n",
    "            img_list.append(img)\n",
    "\n",
    "    X_cap_raw = np.stack(X_list).astype(np.float32)\n",
    "    y_cap = np.array(y_list, dtype=np.int64)\n",
    "    img_cap = np.stack(img_list).astype(np.float32)\n",
    "\n",
    "    return X_cap_raw, y_cap, img_cap\n",
    "\n",
    "\n",
    "X_cap_raw, y_cap, img_cap = parse_cap64_dataset(CAP64_FILE)\n",
    "\n",
    "print(\"X_cap_raw shape:\", X_cap_raw.shape)\n",
    "print(\"y_cap shape    :\", y_cap.shape)\n",
    "print(\"img_cap shape  :\", img_cap.shape)\n",
    "print(\"Class counts   :\", Counter(y_cap))"
   ]
