    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2) Build one clean oracle-selected generated image per digit\n",
    "# ------------------------------------------------------------\n",
    "SAMPLES_PER_DIGIT = 128\n",
    "\n",
    "best_digit_images = []\n",
    "best_digit_conf = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for d in range(N_CLASSES):\n",
    "        labels = torch.full((SAMPLES_PER_DIGIT,), d, dtype=torch.long, device=DEVICE)\n",
