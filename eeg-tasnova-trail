    "# ============================================================\n",
    "# Cell 2 — Parse EP EEG dataset with event ID\n",
    "# ============================================================\n",
    "\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "def parse_ep_dataset(filepath, fixed_len=FIXED_LEN, per_class=PER_CLASS):\n",
    "    channel_set = set(EPOC_CHANNELS)\n",
    "    ch_to_idx = {ch: i for i, ch in enumerate(EPOC_CHANNELS)}\n",
    "\n",
    "    buffer = {}\n",
    "    counts = defaultdict(int)\n",
    "\n",
    "    X_list = []\n",
    "    y_list = []\n",
    "    event_id_list = []\n",
    "\n",
    "    with open(filepath, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
    "        for line in tqdm(f, desc=\"Parsing EP\"):\n",
    "            parts = line.rstrip(\"\\n\").split(\"\\t\", 6)\n",
    "\n",
    "            if len(parts) != 7:\n",
    "                continue\n",
    "\n",
    "            event_id = int(parts[1])\n",
    "            device = parts[2]\n",
    "            channel = parts[3]\n",
    "            label = int(parts[4])\n",
    "            values_str = parts[6]\n",
    "\n",
    "            if device != \"EP\":\n",
    "                continue\n",
    "\n",
    "            if channel not in channel_set:\n",
    "                continue\n",
    "\n",
    "            if label < 0 or label >= N_CLASSES:\n",
    "                continue\n",
    "\n",
    "            if counts[label] >= per_class:\n",
    "                continue\n",
    "\n",
    "            values = np.fromstring(values_str, sep=\",\", dtype=np.float32)\n",
    "\n",
    "            if len(values) >= fixed_len:\n",
    "                values = values[:fixed_len]\n",
    "            else:\n",
    "                values = np.pad(values, (0, fixed_len - len(values)))\n",
    "\n",
    "            if event_id not in buffer:\n",
    "                buffer[event_id] = {\n",
    "                    \"label\": label,\n",
    "                    \"channels\": {}\n",
    "                }\n",
    "\n",
    "            buffer[event_id][\"channels\"][channel] = values\n",
    "\n",
    "            if len(buffer[event_id][\"channels\"]) == N_CHANNELS:\n",
    "                final_label = buffer[event_id][\"label\"]\n",
    "\n",
    "                if counts[final_label] < per_class:\n",
    "                    trial = np.zeros((N_CHANNELS, fixed_len), dtype=np.float32)\n",
    "\n",
    "                    for ch_name, ch_values in buffer[event_id][\"channels\"].items():\n",
    "                        trial[ch_to_idx[ch_name]] = ch_values\n",
    "\n",
    "                    X_list.append(trial)\n",
    "                    y_list.append(final_label)\n",
    "                    event_id_list.append(event_id)\n",
    "\n",
    "                    counts[final_label] += 1\n",
    "\n",
    "                del buffer[event_id]\n",
    "\n",
    "            if all(counts[c] >= per_class for c in range(N_CLASSES)):\n",
    "                break\n",
    "\n",
    "    X_raw = np.stack(X_list).astype(np.float32)\n",
    "    y = np.array(y_list, dtype=np.int64)\n",
    "    event_ids = np.array(event_id_list, dtype=np.int64)\n",
    "\n",
    "    return X_raw, y, event_ids\n",
    "\n",
    "\n",
    "X_raw, y, event_ids = parse_ep_dataset(EP_FILE)\n",
    "\n",
    "print(\"X_raw shape :\", X_raw.shape)\n",
    "print(\"y shape     :\", y.shape)\n",
    "print(\"event_ids   :\", event_ids.shape)\n",
    "print(\"Class counts:\", Counter(y))"
   ]
