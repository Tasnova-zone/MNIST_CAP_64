\n            eeg_start = img_end + 1\n            eeg_end = eeg_start + (CAP64_CHANNELS * CAP64_LEN)\n\n            eeg = np.array(parts[eeg_start:eeg_end], dtype=np.float32).reshape(CAP64_CHANNELS, CAP64_LEN)\n\n            X_list.append(eeg)\n            y_list.append(label)\n            img_list.append(img)\n\n    X_cap_raw = np.stack(X_list).astype(np.float32)\n    y_cap = np.array(y_list, dtype=np.int64)\n    img_cap = np.stack(img_list).astype(np.float32)\n\n    return X_cap_raw, y_cap, img_cap\n\n\nX_cap_raw, y_cap, img_cap = parse_cap64_dataset(CAP64_FILE)\n\nprint(\"X_cap_raw shape:\", X_cap_raw.shape)\nprint(\"y_cap shape    :\", y_cap.shape)\nprint(\"img_cap shape  :\", img_cap.shape)\nprint(\"Class counts   :\", Counter(y_cap))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T14:09:22.953789Z","iopub.execute_input":"2026-06-09T14:09:22.954627Z","iopub.status.idle":"2026-06-09T14:09:33.966303Z","shell.execute_reply.started":"2026-06-09T14:09:22.95459Z","shell.execute_reply":"2026-06-09T14:09:33.965202Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Parsing CustomCap64: 0it [00:00, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"3833758a86354c5bb5f910c63fa2ad67"}},"metadata":{}},{"name":"stdout","text":"X_cap_raw shape: (1161, 64, 400)\ny_cap shape    : (1161,)\nimg_cap shape  : (1161, 28, 28)\nClass counts   : Counter({np.int64(1): 139, np.int64(7): 138, np.int64(4): 120, np.int64(9): 115, np.int64(0): 114, np.int64(2): 114, np.int64(3): 109, np.int64(6): 106, np.int64(5): 104, np.int64(8): 102})\n","output_type":"stream"}],"execution_count":8},{"cell_type":"markdown","source":"# Cell 8 — CustomCap64 raw EEG classification comparison","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 8 — CustomCap64 raw EEG classification comparison\n# ============================================================\n\nfrom sklearn.model_selection import train_test_split\n\nCAP_EPOCHS = 60\nCAP_BATCH = 64\nCAP_FS = 200\n\nidx_cap = np.arange(len(y_cap))\n\ncap_train_idx, cap_test_idx = train_test_split(\n    idx_cap,\n    test_size=0.15,\n    random_state=SEED,\n    stratify=y_cap\n)\n\ndef preprocess_cap_zscore_only(X_input):\n    mean = X_input.mean(axis=-1, keepdims=True)\n    std = X_input.std(axis=-1, keepdims=True) + 1e-6\n    return ((X_input - mean) / std).astype(np.float32)\n\ndef preprocess_cap_bandpass(X_input):\n    b, a = butter(N=4, Wn=[0.5, 40], btype=\"bandpass\", fs=CAP_FS)\n    X_f = filtfilt(b, a, X_input, axis=-1).astype(np.float32)\n    return preprocess_cap_zscore_only(X_f)\n\ndef train_cap_eegnet(X_data, y_data, input_name):\n    X_train = X_data[cap_train_idx]\n    y_train = y_data[cap_train_idx]\n    X_test = X_data[cap_test_idx]\n    y_test = y_data[cap_test_idx]\n\n    train_ds = TensorDataset(\n        torch.tensor(X_train, dtype=torch.float32),\n        torch.tensor(y_train, dtype=torch.long)\n    )\n    test_ds = TensorDataset(\n        torch.tensor(X_test, dtype=torch.float32),\n        torch.tensor(y_test, dtype=torch.long)\n    )\n\n    train_loader = DataLoader(train_ds, batch_size=CAP_BATCH, shuffle=True, num_workers=2, pin_memory=True)\n    test_loader = DataLoader(test_ds, batch_size=CAP_BATCH, shuffle=False, num_workers=2, pin_memory=True)\n\n    model = EEGNetClassifier(n_channels=64, n_times=400, n_classes=10).to(DEVICE)\n    optimizer = torch.optim.AdamW(model.parameters(), lr=7e-4, weight_decay=1e-4)\n    criterion = nn.CrossEntropyLoss()\n\n    best_acc = 0.0\n    best_bal = 0.0\n    best_f1 = 0.0\n    best_state = None\n    best_epoch = 0\n\n    for epoch in range(1, CAP_EPOCHS + 1):\n        model.train()\n\n        for xb, yb in train_loader:\n            xb = xb.to(DEVICE, non_blocking=True)\n            yb = yb.to(DEVICE, non_blocking=True)\n\n            optimizer.zero_grad()\n            loss = criterion(model(xb), yb)\n        