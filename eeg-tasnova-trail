    "# ============================================================\n",
    "# Cell 15D — Prototype-guided Conditional WGAN-GP\n",
    "# ============================================================`\n",
    "\n",
    "torch.cuda.empty_cache()\n",
    "\n",
    "LATENT_DIM = 100\n",
    "WGAN_EPOCHS = 40\n",
    "WGAN_LR_G = 1e-4\n",
    "WGAN_LR_D = 1e-4\n",
    "N_CRITIC = 3\n",
    "\n",
    "LAMBDA_GP = 10.0\n",
    "LAMBDA_PROTO = 8.0\n",
    "LAMBDA_CLS = 1.0\n",
    "LAMBDA_TV = 0.02\n",
    "\n",
    "\n",
    "class ProtoWGANGenerator(nn.Module):\n",
    "    def __init__(self, latent_dim=100, n_classes=10):\n",
    "        super().__init__()\n",
    "\n",
    "        self.label_emb = nn.Embedding(n_classes, latent_dim)\n",
    "\n",
    "        self.fc = nn.Sequential(\n",
    "            nn.Linear(latent_dim * 2, 256 * 7 * 7),\n",
    "            nn.BatchNorm1d(256 * 7 * 7),\n",
    "            nn.ReLU(True)\n",
    "        )\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            nn.ConvTranspose2d(256, 128, 4, 2, 1),\n",
    "            nn.BatchNorm2d(128),\n",
    "            nn.ReLU(True),\n",
    "\n",
    "            nn.ConvTranspose2d(128, 64, 4, 2, 1),\n",
    "            nn.BatchNorm2d(64),\n",
    "            nn.ReLU(True),\n",
    "\n",
    "            nn.Conv2d(64, 1, 3, 1, 1),\n",
    "            nn.Tanh()\n",
    "        )\n",
    "\n",
    "    def forward(self, z, labels):\n",
    "        y = self.label_emb(labels)\n",
    "        x = torch.cat([z, y], dim=1)\n",
    "        x = self.fc(x)\n",
    "        x = x.view(x.size(0), 256, 7, 7)\n",
    "        return self.net(x)\n",
    "\n",
    "\n",
    "class ProjectionCritic(nn.Module):\n",
    "    def __init__(self, n_classes=10):\n",
    "        super().__init__()\n",
    "\n",
    "        self.features = nn.Sequential(\n",
    "            nn.Conv2d(1, 64, 4, 2, 1),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "\n",
    "            nn.Conv2d(64, 128, 4, 2, 1),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "\n",
    "            nn.Conv2d(128, 256, 3, 1, 1),\n",
    "            nn.LeakyReLU(0.2, inplace=True)\n",
    "        )\n",
    "\n",
    "        self.fc = nn.Linear(256 * 7 * 7, 1)\n",
    "        self.label_emb = nn.Embedding(n_classes, 256 * 7 * 7)\n",
    "\n",
    "    def forward(self, img, labels):\n",
    "        feat = self.features(img)\n",
    "        feat = feat.view(feat.size(0), -1)\n",
    "\n",
    "        out = self.fc(feat)\n",
    "        proj = torch.sum(feat * self.label_emb(labels), dim=1, keepdim=True)\n",
    "\n",
    "        return out + proj\n",
    "\n",
    "\n",
    "def gradient_penalty(critic, real_imgs, fake_imgs, labels):\n",
    "    batch_size = real_imgs.size(0)\n",
    "\n",
    "    alpha = torch.rand(batch_size, 1, 1, 1, device=DEVICE)\n",
    "    interpolates = alpha * real_imgs + (1 - alpha) * fake_imgs\n",
    "    interpolates.requires_grad_(True)\n",
    "\n",
    "    critic_scores = critic(interpolates, labels)\n",
    "\n",
    "    gradients = torch.autograd.grad(\n",
    "        outputs=critic_scores,\n",
    "        inputs=interpolates,\n",
    "        grad_outputs=torch.ones_like(critic_scores),\n",
    "        create_graph=True,\n",
    "        retain_graph=True,\n",
    "        only_inputs=True\n",
    "    )[0]\n",
    "\n",
    "    gradients = gradients.view(batch_size, -1)\n",
    "    gp = ((gradients.norm(2, dim=1) - 1) ** 2).mean()\n",
    "\n",
    "    return gp\n",
    "\n",
    "\n",
    "def total_variation_loss(x):\n",
    "    tv_h = torch.mean(torch.abs(x[:, :, 1:, :] - x[:, :, :-1, :]))\n",
    "    tv_w = torch.mean(torch.abs(x[:, :, :, 1:] - x[:, :, :, :-1]))\n",
    "    return tv_h + tv_w\n",
    "\n",
    "\n",
    "def show_proto_wgan(epoch):\n",
    "    G.eval()\n",
    "\n",
    "    with torch.no_grad():\n",
    "        labels = torch.arange(N_CLASSES, device=DEVICE)\n",
    "        z = torch.randn(N_CLASSES, LATENT_DIM, device=DEVICE)\n",
    "        gen_imgs = G(z, labels)\n",
    "        gen_imgs = (gen_imgs + 1) / 2\n",
    "        gen_imgs = gen_imgs.detach().cpu()\n",
    "\n",
    "    plt.figure(figsize=(10, 2))\n",
    "    for d in range(N_CLASSES):\n",
    "        plt.subplot(1, 10, d + 1)\n",
    "        plt.imshow(gen_imgs[d, 0], cmap=\"gray\")\n",
    "        plt.title(str(d))\n",
    "        plt.axis(\"off\")\n",
    "\n",
    "    plt.suptitle(f\"Prototype-guided WGAN-GP Generated Digits | Epoch {epoch}\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    G.train()\n",
    "\n",
    "\n",
    "G = ProtoWGANGenerator(LATENT_DIM, N_CLASSES).to(DEVICE)\n",
    "D = ProjectionCritic(N_CLASSES).to(DEVICE)\n",
    "\n",
    "optimizer_G = torch.optim.Adam(G.parameters(), lr=WGAN_LR_G, betas=(0.5, 0.9))\n",
    "optimizer_D = torch.optim.Adam(D.parameters(), lr=WGAN_LR_D, betas=(0.5, 0.9))\n",
    "\n",
    "G_losses = []\n",
    "D_losses = []\n",
    "\n",
    "step = 0\n",
    "\n",
    "for epoch in range(1, WGAN_EPOCHS + 1):\n",
    "    G.train()\n",
    "    D.train()\n",
    "\n",
    "    epoch_g_loss = 0.0\n",
    "    epoch_d_loss = 0.0\n",
    "    g_steps = 0\n",
    "    d_steps = 0\n",
    "\n",
    "    for real_imgs, labels in mnist_loader:\n",
    "        real_imgs = real_imgs.to(DEVICE, non_blocking=True)\n",
    "        labels = labels.to(DEVICE, non_blocking=True)\n",
    "\n",
    "        batch_size = real_imgs.size(0)\n",
    "\n",
    "        # ---------------------\n",
    "        # Train Critic\n",
    "        # ---------------------\n",
    "        optimizer_D.zero_grad()\n",
    "\n",
    "        z = torch.randn(batch_size, LATENT_DIM, device=DEVICE)\n",
    "        fake_imgs = G(z, labels).detach()\n",
    "\n",
    "        real_score = D(real_imgs, labels).mean()\n",
    "        fake_score = D(fake_imgs, labels).mean()\n",
    "        gp = gradient_penalty(D, real_imgs, fake_imgs, labels)\n",
    "\n",
    "        d_loss = fake_score - real_score + LAMBDA_GP * gp\n",
    "        d_loss.backward()\n",
    "        optimizer_D.step()\n",
    "\n",
    "        epoch_d_loss += d_loss.item()\n",
    "        d_steps += 1\n",
    "\n",
    "        # ---------------------\n",
    "        # Train Generator every N_CRITIC steps\n",
    "        # ---------------------\n",
    "        if step % N_CRITIC == 0:\n",
    "            optimizer_G.zero_grad()\n",
    "\n",
    "            gen_labels = torch.randint(0, N_CLASSES, (batch_size,), device=DEVICE)\n",
    "            z = torch.randn(batch_size, LATENT_DIM, device=DEVICE)\n",
    "\n",
    "            gen_imgs = G(z, gen_labels)\n",
    "\n",
    "            adv_loss = -D(gen_imgs, gen_labels).mean()\n",
    "\n",
    "            target_proto = mnist_class_prototypes[gen_labels]\n",
    "            proto_loss = F.l1_loss(gen_imgs, target_proto)\n",
    "\n",
    "            oracle_input = (gen_imgs + 1) / 2\n",
    "            cls_loss = F.cross_entropy(oracle_model(oracle_input), gen_labels)\n",
    "\n",
    "            tv_loss = total_variation_loss(gen_imgs)\n",
    "\n",
    "            g_loss = (\n",
    "                adv_loss\n",
    "                + LAMBDA_PROTO * proto_loss\n",
    "                + LAMBDA_CLS * cls_loss\n",
    "                + LAMBDA_TV * tv_loss\n",
    "            )\n",
    "\n",
    "            g_loss.backward()\n",
    "            optimizer_G.step()\n",
    "\n",
    "            epoch_g_loss += g_loss.item()\n",
    "            g_steps += 1\n",
    "\n",
    "        step += 1\n",
    "\n",
    "    avg_d_loss = epoch_d_loss / max(1, d_steps)\n",
    "    avg_g_loss = epoch_g_loss / max(1, g_steps)\n",
    "\n",
    "    D_losses.append(avg_d_loss)\n",
    "    G_losses.append(avg_g_loss)\n",
    "\n",
    "    print(\n",
    "        f\"Epoch {epoch:03d}/{WGAN_EPOCHS} | \"\n",
    "        f\"D Loss: {avg_d_loss:.4f} | \"\n",
    "        f\"G Loss: {avg_g_loss:.4f}\"\n",
    "    )\n",
    "\n",
    "    if epoch == 1 or epoch % 5 == 0 or epoch == WGAN_EPOCHS:\n",
    "        show_proto_wgan(epoch)\n",
    "\n",
    "\n",
    "torch.save(G.state_dict(), \"/kaggle/working/prototype_guided_wgan_gp_generator.pth\")\n",
    "torch.save(D.state_dict(), \"/kaggle/working/prototype_guided_wgan_gp_critic.pth\")\n",
    "\n",
    "plt.figure(figsize=(7, 4))\n",
    "plt.plot(G_losses, label=\"Generator Loss\")\n",
    "plt.plot(D_losses, label=\"Critic Loss\")\n",
    "plt.xlabel(\"Epoch\")\n",
    "plt.ylabel(\"Loss\")\n",
    "plt.title(\"Prototype-guided WGAN-GP Training Loss\")\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/prototype_guided_wgan_gp_loss.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "print(\"Saved:\")\n",
    "print(\"/kaggle/working/prototype_guided_wgan_gp_generator.pth\")\n",
    "print(\"/kaggle/working/prototype_guided_wgan_gp_critic.pth\")\n",
    "print(\"/kaggle/working/prototype_guided_wgan_gp_loss.png\")"
