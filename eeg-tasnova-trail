asets/vijayveersingh/1-2m-brain-signal-data/MindBigData-EP-v1.0/EP1.01.txt\"\n\n# -----------------------------\n# EEG configuration\n# -----------------------------\nEPOC_CHANNELS = [\n    \"AF3\", \"F7\", \"F3\", \"FC5\", \"T7\", \"P7\", \"O1\",\n    \"O2\", \"P8\", \"T8\", \"FC6\", \"F4\", \"F8\", \"AF4\"\n]\n\nN_CHANNELS = 14\nFIXED_LEN = 256\nN_CLASSES = 10\nPER_CLASS = 4000\n\nprint(\"Using device :\", DEVICE)\nprint(\"EP file exists:\", os.path.exists(EP_FILE))\nprint(\"EP file path :\", EP_FILE)\nprint(\"Channels     :\", N_CHANNELS)\nprint(\"Fixed length :\", FIXED_LEN)\nprint(\"Per class    :\", PER_CLASS)\nprint(\"Seed         :\", SEED)","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-06-09T13:36:52.443294Z","iopub.execute_input":"2026-06-09T13:36:52.443576Z","iopub.status.idle":"2026-06-09T13:37:02.177535Z","shell.execute_reply.started":"2026-06-09T13:36:52.443538Z","shell.execute_reply":"2026-06-09T13:37:02.176567Z"}},"outputs":[{"name":"stdout","text":"Using device : cuda\nEP file exists: True\nEP file path : /kaggle/input/datasets/vijayveersingh/1-2m-brain-signal-data/MindBigData-EP-v1.0/EP1.01.txt\nChannels     : 14\nFixed length : 256\nPer class    : 4000\nSeed         : 0\n","output_type":"stream"}],"execution_count":1},{"cell_type":"markdown","source":"# Cell 2 — Parse EP EEG dataset with event ID","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 2 — Parse EP EEG dataset with event ID\n# ============================================================\n\nfrom tqdm.auto import tqdm\n\ndef parse_ep_dataset(filepath, fixed_len=FIXED_LEN, per_class=PER_CLASS):\n    channel_set = set(EPOC_CHANNELS)\n    ch_to_idx = {ch: i for i, ch in enumerate(EPOC_CHANNELS)}\n\n    buffer = {}\n    counts = defaultdict(int)\n\n    X_list = []\n    y_list = []\n    event_id_list = []\n\n    with open(filepath, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n        for line in tqdm(f, desc=\"Parsing EP\"):\n            parts = line.rstrip(\"\\n\").split(\"\\t\", 6)\n\n            if len(parts) != 7:\n                continue\n\n            event_id = int(parts[1])\n            device = parts[2]\n            channel = parts[3]\n            label = int(parts[4])\n            values_str = parts[6]\n\n            if device != \"EP\":\n                continue\n\n            if channel not in channel_set:\n                continue\n\n            if label < 0 or label >= N_CLASSES:\n                continue\n\n            if counts[label] >= per_class:\n                continue\n\n            values = np.fromstring(values_str, sep=\",\", dtype=np.float32)\n\n            if len(values) >= fixed_len:\n                values = values[:fixed_len]\n            else:\n                values = np.pad(values, (0, fixed_len - len(values)))\n\n            if event_id not in buffer:\n                buffer[event_id] = {\n                    \"label\": label,\n                    \"channels\": {}\n                }\n\n            buffer[event_id][\"channels\"][channel] = values\n\n            if len(buffer[event_id][\"channels\"]) == N_CHANNELS:\n                final_label = buffer[event_id][\"label\"]\n\n                if counts[final_label] < per_class:\n                    trial = np.zeros((N_CHANNELS, fixed_len), dtype=np.float32)\n\n                    for ch_name, ch_values in buffer[event_id][\"channels\"].items():\n                        trial[ch_to_idx[ch_name]] = ch_values\n\n                    X_list.append(trial)\n                    y_list.append(final_label)\n                    event_id_list.append(event_id)\n\n                    counts[final_label] += 1\n\n                del buffer[event_id]\n\n            if all(counts[c] >= per_class for c in range(N_CLASSES)):\n                break\n\n    X_raw = np.stack(X_list).astype(np.float32)\n    y = np.array(y_list, dtype=np.int64)\n    event_ids = np.array(event_id_list, dtype=np.int64)\n\n    return X_raw, y, event_ids\n\n\nX_raw, y, event_ids = parse_ep_dataset(EP_FILE)\n\nprint(\"X_raw shape :\", X_raw.shape)\nprint(\"y shape     :\", y.shape)\nprint(\"event_ids   :\", event_ids.shape)\nprint(\"Class counts:\", Counter(y))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T13:38:44.238792Z","iopub.execute_input":"2026-06-09T13:38:44.239492Z","iopub.status.idle":"2026-06-09T13:39:17.49438Z","shell.execute_reply.started":"2026-06-09T13:38:44.23946Z","shell.execute_reply":"2026-06-09T13:39:17.493564Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Parsing EP: 0it [00:00, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"d074b8bdc66c43fdb820f7ce6c932c40"}},"metadata":{}},{"name":"stdout","text":"X_raw shape : (40000, 14, 256)\ny shape     : (40000,)\nevent_ids   : (40000,)\nClass counts: Counter({np.int64(6): 4000, np.int64(7): 4000, np.int64(9): 4000, np.int64(0): 4000, np.int64(8): 4000, np.int64(5): 4000, np.int64(3): 4000, np.int64(4): 4000, np.int64(2): 4000, np.int64(1): 4000})\n","output_type":"stream"}],"execution_count":2},{"cell_type":"markdown","source":"# Cell 3 — EEG preprocessing + random and leak-safe temporal split","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 3 — EEG preprocessing + random and leak-safe temporal split\n# ============================================================\n\nFS = 128\nTEST_SIZE = 0.15\n\ndef bandpass_filter_eeg(X_input, fs=FS):\n    b, a = butter(\n        N=4,\n        Wn=[0.5, 40],\n        btype=\"bandpass\",\n        fs=fs\n    )\n    return filtfilt(b, a, X_input, axis=-1).astype(np.float32)\n\n\ndef zscore_per_trial_channel(X_input):\n    mean = X_input.mean(axis=-1, keepdims=True)\n    std = X_input.std(axis=-1, keepdims=True) + 1e-6\n    return ((X_input - mean) / std).astype(np.float32)\n\n\n# Main processed EEG used for sir-style baseline\nX_filt = bandpass_filter_eeg(X_raw)\nX = zscore_per_trial_channel(X_filt)\n\n# Random split\ndef split_random():\n    idx = np.arange(len(y))\n    rng = np.random.default_rng(SEED)\n    rng.shuffle(idx)\n\n    n_test = int(len(idx) * TEST_SIZE)\n    test_idx = idx[:n_test]\n    train_idx = idx[n_test:]\n\n    return (\n        X[train_idx], y[train_idx],\n        X[test_idx], y[test_idx],\n        train_idx, test_idx\n    )\n\n\n# Leak-safe temporal split using event order\ndef split_temporal():\n    sorted_idx = np.argsort(event_ids)\n\n    n_test = int(len(sorted_idx) * TEST_SIZE)\n    train_idx = sorted_idx[:-n_test]\n    test_idx = sorted_idx[-n_test:]\n\n    return (\n        X[train_idx], y[train_idx],\n        X[test_idx], y[test_idx],\n        train_idx, test_idx\n    )\n\n\nXtr_r, ytr_r, Xte_r, yte_r, tr_idx_r, te_idx_r = split_random()\nXtr_t, ytr_t, Xte_t, yte_t, tr_idx_t, te_idx_t = split_temporal()\n\nprint(\"Processed EEG shape:\", X.shape)\nprint(\"Random split:\")\nprint(\"  Train:\", Xtr_r.shape, Counter(ytr_r))\nprint(\"  Test :\", Xte_r.shape, Counter(yte_r))\n\nprint(\"\\nLeak-safe temporal split:\")\nprint(\"  Train:\", Xtr_t.shape, Counter(ytr_t))\nprint(\"  Test :\", Xte_t.shape, Counter(yte_t))\n\nprint(\"\\nProcessed train mean:\", round(float(Xtr_t.mean()), 4))\nprint(\"Processed train std :\", round(float(Xtr_t.std()), 4))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T13:41:19.400331Z","iopub.execute_input":"2026-06-09T13:41:19.400807Z","iopub.status.idle":"2026-06-09T13:41:26.344211Z","shell.execute_reply.started":"2026-06-09T13:41:19.400776Z","shell.execute_reply":"2026-06-09T13:41:26.343444Z"}},"outputs":[{"name":"stdout","text":"Processed EEG shape: (40000, 14, 256)\nRandom split:\n  Train: (34000, 14, 256) Counter({np.int64(1): 3462, np.int64(6): 3430, np.int64(5): 3427, np.int64(2): 3402, np.int64(7): 3398, np.int64(9): 3395, np.int64(3): 3392, np.int64(4): 3390, np.int64(0): 3365, np.int64(8): 3339})\n  Test : (6000, 14, 256) Counter({np.int64(8): 661, np.int64(0): 635, np.int64(4): 610, np.int64(3): 608, np.int64(9): 605, np.int64(7): 602, np.int64(2): 598, np.int64(5): 573, np.int64(6): 570, np.int64(1): 538})\n\nLeak-safe temporal split:\n  Train: (34000, 14, 256) Counter({np.int64(8): 3477, np.int64(5): 3473, np.int64(3): 3446, np.int64(9): 3428, np.int64(6): 3396, np.int64(4): 3392, np.int64(2): 3389, np.int64(0): 3377, np.int64(7): 3315, np.int64(1): 3307})\n  Test : (6000, 14, 256) Counter({np.int64(1): 693, np.int64(7): 685, np.int64(0): 623, np.int64(2): 611, np.int64(4): 608, np.int64(6): 604, np.int64(9): 572, np.int64(3): 554, np.int64(5): 527, np.int64(8): 523})\n\nProcessed train mean: 0.0\nProcessed train std : 1.0\n","output_type":"stream"}],"execution_count":3},{"cell_type":"markdown","source":"# Cell 4 — EEGNet model and reusable training utilities","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 4 — EEGNet model and reusable training utilities\n# ============================================================\n\nBATCH_SIZE = 256\nEEGNET_EPOCHS = 50\nLR = 1e-3\n\ndef make_loaders(X_train, y_train, X_test, y_test, batch_size=BATCH_SIZE):\n    train_ds = TensorDataset(\n        torch.tensor(X_train, dtype=torch.float32),\n        torch.tensor(y_train, dtype=torch.long)\n    )\n    test_ds = TensorDataset(\n        torch.tensor(X_test, dtype=torch.float32),\n        torch.tensor(y_test, dtype=torch.long)\n    )\n\n    train_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True, num_workers=2, pin_memory=True)\n    test_loader = DataLoader(test_ds, batch_size=batch_size, shuffle=False, num_workers=2, pin_memory=True)\n\n    return train_loader, test_loader\n\n\nclass EEGNetClassifier(nn.Module):\n    def __init__(self, n_channels=14, n_times=256, n_classes=10):\n        super().__init__()\n\n        self.temporal = nn.Sequential(\n            nn.Conv2d(1, 16, kernel_size=(1, 31), padding=(0, 15), bias=False),\n            nn.BatchNorm2d(16)\n        )\n\n        self.spatial = nn.Sequential(\n            nn.Conv2d(16, 32, kernel_size=(n_channels, 1), groups=16, bias=False),\n            nn.BatchNorm2d(32),\n            nn.ELU(),\n            nn.AvgPool2d(kernel_size=(1, 4)),\n            nn.Dropout(0.25)\n        )\n\n        self.separable = nn.Sequential(\n            nn.Conv2d(32, 32, kernel_size=(1, 15), padding=(0, 7), groups=32, bias=False),\n            nn.Conv2d(32, 64, kernel_size=(1, 1), bias=False),\n            nn.BatchNorm2d(64),\n            nn.ELU(),\n            nn.AvgPool2d(kernel_size=(1, 8)),\n            nn.Dropout(0.25)\n        )\n\n        with torch.no_grad():\n            dummy = torch.zeros(1, 1, n_channels, n_times)\n            feat = self.separable(self.spatial(self.temporal(dummy)))\n            self.feature_dim = feat.flatten(1).shape[1]\n\n        self.classifier = nn.Linear(self.feature_dim, n_classes)\n\n    def forward(self, x, return_features=False):\n        x = x.unsqueeze(1)\n        x = self.temporal(x)\n        x = self.spatial(x)\n        x = self.separable(x)\n\n        features = x.flatten(1)\n        logits = self.classifier(features)\n\n        if return_features:\n            return logits, features\n\n        return logits\n\n\ndef evaluate_classifier(model, loader):\n    model.eval()\n    all_preds = []\n    all_true = []\n\n    with torch.no_grad():\n        for xb, yb in loader:\n            xb = xb.to(DEVICE, non_blocking=True)\n            logits = model(xb)\n            preds = logits.argmax(dim=1).cpu().numpy()\n\n            all_preds.extend(preds)\n            all_true.extend(yb.numpy())\n\n    acc = accuracy_score(all_true, all_preds)\n    bal_acc = balanced_accuracy_score(all_true, all_preds)\n    macro_f1 = f1_score(all_true, all_preds, average=\"macro\")\n\n    return acc, bal_acc, macro_f1\n\n\ndef train_eegnet(X_train, y_train, X_test, y_test, epochs=EEGNET_EPOCHS):\n    train_loader, test_loader = make_loaders(X_train, y_train, X_test, y_test)\n\n    model = EEGNetClassifier().to(DEVICE)\n    optimizer = torch.optim.Adam(model.parameters(), lr=LR)\n    criterion = nn.CrossEntropyLoss()\n\n    for epoch in range(1, epochs + 1):\n        model.train()\n\n        total_loss = 0\n        correct = 0\n        total = 0\n\n        for xb, yb in train_loader:\n            xb = xb.to(DEVICE, non_blocking=True)\n            yb = yb.to(DEVICE, non_blocking=True)\n\n            optimizer.zero_grad()\n            logits = model(xb)\n            loss = criterion(logits, yb)\n            loss.backward()\n            optimizer.step()\n\n            total_loss += loss.item() * xb.size(0)\n            correct += (logits.argmax(1) == yb).sum().item()\n            total += xb.size(0)\n\n        if epoch == 1 or epoch % 10 == 0:\n            test_acc, _, _ = evaluate_classifier(model, test_loader)\n            print(\n                f\"Epoch {epoch:03d}/{epochs} | \"\n                f\"Train Loss: {total_loss / total:.4f} | \"\n                f\"Train Acc: {correct / total:.4f} | \"\n                f\"Test Acc: {test_acc:.4f}\"\n            )\n\n    test_acc, test_bal, test_f1 = evaluate_classifier(model, test_loader)\n\n    return model, test_acc, test_bal, test_f1\n\n\nprint(\"EEGNet ready.\")\nprint(\"Feature dimension:\", EEGNetClassifier().feature_dim)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T13:42:48.733601Z","iopub.execute_input":"2026-06-09T13:42:48.734036Z","iopub.status.idle":"2026-06-09T13:42:48.942149Z","shell.execute_reply.started":"2026-06-09T13:42:48.734001Z","shell.execute_reply":"2026-06-09T13:42:48.941459Z"}},"outputs":[{"name":"stdout","text":"EEGNet ready.\nFeature dimension: 512\n","output_type":"stream"}],"execution_count":4},{"cell_type":"markdown","source":"# Cell 5 — Baseline EEGNet: random vs leak-safe temporal split","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 5 — Baseline EEGNet: random vs leak-safe temporal split\n# ============================================================\n\nprint(\"Training EEGNet on random split...\")\nmodel_random, acc_random, bal_random, f1_random = train_eegnet(\n    Xtr_r, ytr_r, Xte_r, yte_r, epochs=EEGNET_EPOCHS\n)\n\nprint(\"\\nTraining EEGNet on leak-safe temporal split...\")\nmodel_temporal, acc_temporal, bal_temporal, f1_temporal = train_eegnet(\n    Xtr_t, ytr_t, Xte_t, yte_t, epochs=EEGNET_EPOCHS\n)\n\nbaseline_results = pd.DataFrame([\n    {\n        \"Dataset\": \"EP1.01\",\n        \"Split\": \"Random\",\n        \"Model\": \"EEGNet\",\n        \"Accuracy\": acc_random,\n        \"Balanced Accuracy\": bal_random,\n        \"Macro F1\": f1_random\n    },\n    {\n        \"Dataset\": \"EP1.01\",\n        \"Split\": \"Leak-safe Temporal\",\n        \"Model\": \"EEGNet\",\n        \"Accuracy\": acc_temporal,\n        \"Balanced Accuracy\": bal_temporal,\n        \"Macro F1\": f1_temporal\n    }\n])\n\nprint(\"\\n========== Baseline EEGNet Summary ==========\")\ndisplay(baseline_results)\n\nprint(\"\\nChance baseline for 10 classes: 0.1000\")\nprint(f\"Best baseline accuracy       : {baseline_results['Accuracy'].max():.4f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T13:44:25.5912Z","iopub.execute_input":"2026-06-09T13:44:25.591845Z","iopub.status.idle":"2026-06-09T13:47:22.848728Z","shell.execute_reply.started":"2026-06-09T13:44:25.591786Z","shell.execute_reply":"2026-06-09T13:47:22.84775Z"}},"outputs":[{"name":"stdout","text":"Training EEGNet on random split...\nEpoch 001/50 | Train Loss: 2.3098 | Train Acc: 0.1158 | Test Acc: 0.1290\nEpoch 010/50 | Train Loss: 2.2254 | Train Acc: 0.1791 | Test Acc: 0.1728\nEpoch 020/50 | Train Loss: 2.1939 | Train Acc: 0.1961 | Test Acc: 0.1862\nEpoch 030/50 | Train Loss: 2.1750 | Train 