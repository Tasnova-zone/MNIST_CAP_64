nal_dcgan_discriminator.pth\n/kaggle/working/better_conditional_dcgan_loss.png\n","output_type":"stream"}],"execution_count":21},{"cell_type":"markdown","source":"# Cell 14D — MNIST oracle classifier + class prototypes","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 14D — MNIST oracle classifier + class prototypes\n# ============================================================\n\ntorch.cuda.empty_cache()\n\nORACLE_BATCH = 256\nORACLE_EPOCHS = 3\n\noracle_transform = transforms.ToTensor()\n\nmnist_oracle_train = datasets.MNIST(\n    root=MNIST_ROOT,\n    train=True,\n    download=True,\n    transform=oracle_transform\n)\n\nmnist_oracle_test = datasets.MNIST(\n    root=MNIST_ROOT,\n    train=False,\n    download=True,\n    transform=oracle_transform\n)\n\noracle_train_loader = DataLoader(\n    mnist_oracle_train,\n    batch_size=ORACLE_BATCH,\n    shuffle=True,\n    num_workers=2,\n    pin_memory=True\n)\n\noracle_test_loader = DataLoader(\n    mnist_oracle_test,\n    batch_size=ORACLE_BATCH,\n    shuffle=False,\n    num_workers=2,\n    pin_memory=True\n)\n\n\nclass MNISTOracleCNN(nn.Module):\n    def __init__(self):\n        super().__init__()\n\n        self.features = nn.Sequential(\n            nn.Conv2d(1, 32, 3, padding=1),\n            nn.ReLU(),\n            nn.Conv2d(32, 64, 3, padding=1),\n            nn.ReLU(),\n            nn.MaxPool2d(2),\n\n            nn.Conv2d(64, 128, 3, padding=1),\n            nn.ReLU(),\n            nn.MaxPool2d(2)\n        )\n\n        self.classifier = nn.Sequential(\n            nn.Flatten(),\n            nn.Linear(128 * 7 * 7, 256),\n            nn.ReLU(),\n            nn.Dropout(0.25),\n            nn.Linear(256, 10)\n        )\n\n    def forward(self, x):\n        return self.classifier(self.features(x))\n\n\noracle_model = MNISTOracleCNN().to(DEVICE)\noptimizer = torch.optim.Adam(oracle_model.parameters(), lr=1e-3)\ncriterion = nn.CrossEntropyLoss()\n\nfor epoch in range(1, ORACLE_EPOCHS + 1):\n    oracle_model.train()\n\n    for xb, yb in oracle_train_loader:\n        xb = xb.to(DEVICE, non_blocking=True)\n        yb = yb.to(DEVICE, non_blocking=True)\n\n        optimizer.zero_grad()\n        loss = criterion(oracle_model(xb), yb)\n        loss.backward()\n        optimizer.step()\n\n    oracle_model.eval()\n    correct = 0\n    total = 0\n\n    with torch.no_grad():\n        for xb, yb in oracle_test_loader:\n            xb = xb.to(DEVICE, non_blocking=True)\n            yb = yb.to(DEVICE, non_blocking=True)\n\n            pred = oracle_model(xb).argmax(dim=1)\n            correct += (pred == yb).sum().item()\n            total += yb.size(0)\n\n    print(f\"Oracle Epoch {epoch}/{ORACLE_EPOCHS} | Test Acc: {correct / total:.4f}\")\n\noracle_model.eval()\nfor p in oracle_model.parameters():\n    p.requires_grad = False\n\n\n# Build class prototype images from normalized MNIST loader [-1, 1]\nprototype_sum = torch.zeros(N_CLASSES, 1, 28, 28)\nprototype_count = torch.zeros(N_CLASSES)\n\nfor imgs, labels in mnist_loader:\n    for d in range(N_CLASSES):\n        mask = labels == d\n        if mask.sum() > 0:\n            prototype_sum[d] += imgs[mask].sum(dim=0)\n            prototype_count[d] += mask.sum()\n\nmnist_class_prototypes = prototype_sum / prototype_count.view(-1, 1, 1, 1)\nmnist_class_prototypes = mnist_class_prototypes.to(DEVICE)\n\nplt.figure(figsize=(10, 2))\nfor d in range(N_CLASSES):\n    img = mnist_class_prototypes[d, 0].detach().cpu().numpy()\n    img = (img + 1) / 2\n\n    plt.subplot(1, 10, d + 1)\n    plt.imshow(img, cmap=\"gray\")\n    plt.title(str(d))\n    plt.axis(\"off\")\n\nplt.suptitle(\"MNIST Class Prototypes for Structure-Guided Generation\")\nplt.tight_layout()\nplt.show()\n\nprint(\"Oracle and class prototypes ready.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T15:48:58.737912Z","iopub.execute_input":"2026-06-09T15:48:58.738762Z","iopub.status.idle":"2026-06-09T15:49:26.557717Z","shell.execute_reply.started":"2026-06-09T15:48:58.738726Z","shell.execute_reply":"2026-06-09T15:49:26.556863Z"}},"outputs":[{"name":"stdout","text":"Oracle Epoch 1/3 | Test Acc: 0.9818\nOracle Epoch 2/3 | Test Acc: 0.9904\nOracle Epoch 3/3 | Test Acc: 0.9919\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x200 with 10 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Oracle and class prototypes ready.\n","output_type":"stream"}],"execution_count":24},{"cell_type":"markdown","source":"# Cell 15D — Prototype-guided Conditional WGAN-GP","metadata":{}},{"cell_type":"code","source":"# ============================================================\n# Cell 15D — Prototype-guided Conditional WGAN-GP\n# ============================================================`\n\ntorch.cuda.empty_cache()\n\nLATENT_DIM = 100\nWGAN_EPOCHS = 40\nWGAN_LR_G = 1e-4\nWGAN_LR_D = 1e-4\nN_CRITIC = 3\n\nLAMBDA_GP = 10.0\nLAMBDA_PROTO = 8.0\nLAMBDA_CLS = 1.0\nLAMBDA_TV = 0.02\n\n\nclass ProtoWGANGenerator(nn.Module):\n    def __init__(self, latent_dim=100, n_classes=10):\n        super().__init__()\n\n        self.label_emb = nn.Embedding(n_classes, latent_dim)\n\n        self.fc = nn.Sequential(\n            nn.Linear(latent_dim * 2, 256 * 7 * 7),\n            nn.BatchNorm1d(256 * 7 * 7),\n            nn.ReLU(True)\n        )\n\n        self.net = nn.Sequential(\n            nn.ConvTranspose2d(256, 128, 4, 2, 1),\n            nn.BatchNorm2d(128),\n            nn.ReLU(True),\n\n            nn.ConvTranspose2d(128, 64, 4, 2, 1),\n            nn.BatchNorm2d(64),\n            nn.ReLU(True),\n\n            nn.Conv2d(64, 1, 3, 1, 1),\n            nn.Tanh()\n        )\n\n    def forward(self, z, labels):\n        y = self.label_emb(labels)\n        x = torch.cat([z, y], dim=1)\n        x = self.fc(x)\n        x = x.view(x.size(0), 256, 7, 7)\n        return self.net(x)\n\n\nclass ProjectionCritic(nn.Module):\n    def __init__(self, n_classes=10):\n        super().__init__()\n\n        self.features = nn.Sequential(\n            nn.Conv2d(1, 64, 4, 2, 1),\n            nn.LeakyReLU(0.2, inplace=True),\n\n            nn.Conv2d(64, 128, 4, 2, 1),\n            nn.LeakyReLU(0.2, inplace=True),\n\n            nn.Conv2d(128, 256, 3, 1, 1),\n            nn.LeakyReLU(0.2, inplace=True)\n        )\n\n        self.fc = nn.Linear(256 * 7 * 7, 1)\n        self.label_emb = nn.Embedding(n_classes, 256 * 7 * 7)\n\n    def forward(self, img, labels):\n        feat = self.features(img)\n        feat = feat.view(feat.size(0), -1)\n\n        out = self.fc(feat)\n        proj = torch.sum(feat * self.label_emb(labels), dim=1, keepdim=True)\n\n        return out + proj\n\n\ndef gradient_penalty(critic, real_imgs, fake_imgs, labels):\n    batch_size = real_imgs.size(0)\n\n    alpha = torch.rand(batch_size, 1, 1, 1, device=DEVICE)\n    interpolates = alpha * real_imgs + (1 - alpha) * fake_imgs\n    interpolates.requires_grad_(True)\n\n    critic_scores = critic(interpolates, labels)\n\n    gradients = torch.autograd.grad(\n        outputs=critic_scores,\n        inputs=interpolates,\n        grad_outputs=torch.ones_like(critic_scores),\n        create_graph=True,\n        retain_graph=True,\n        only_inputs=True\n    )[0]\n\n    gradients = gradients.view(batch_size, -1)\n    gp = ((gradients.norm(2, dim=1) - 1) ** 2).mean()\n\n    return gp\n\n\ndef total_variation_loss(x):\n    tv_h = torch.mean(torch.abs(x[:, :, 1:, :] - x[:, :, :-1, :]))\n    tv_w = torch.mean(torch.abs(x[:, :, :, 1:] - x[:, :, :, :-1]))\n    return tv_h + tv_w\n\n\ndef show_proto_wgan(epoch):\n    G.eval()\n\n    with torch.no_grad():\n        labels = torch.arange(N_CLASSES, device=DEVICE)\n        z = torch.randn(N_CLASSES, LATENT_DIM, device=DEVICE)\n        gen_imgs = G(z, labels)\n        gen_imgs = (gen_imgs + 1) / 2\n        gen_imgs = gen_imgs.detach().cpu()\n\n    plt.figure(figsize=(10, 2))\n    for d in range(N_CLASSES):\n        plt.subplot(1, 10, d + 1)\n        plt.imshow(gen_imgs[d, 0], cmap=\"gray\")\n        plt.title(str(d))\n        plt.axis(\"off\")\n\n    plt.suptitle(f\"Prototype-guided WGAN-GP Generated Digits | Epoch {epoch}\")\n    plt.tight_layout()\n    plt.show()\n\n    G.train()\n\n\nG = ProtoWGANGenerator(LATENT_DIM, N_CLASSES).to(DEVICE)\nD = ProjectionCritic(N_CLASSES).to(DEVICE)\n\noptimizer_G = torch.optim.Adam(G.parameters(), lr=WGAN_LR_G, betas=(0.5, 0.9))\noptimizer_D = torch.optim.Adam(D.parameters(), lr=WGAN_LR_D, betas=(0.5, 0.9))\n\nG_losses = []\nD_losses = []\n\nstep = 0\n\nfor epoch in range(1, WGAN_EPOCHS + 1):\n    G.train()\n    D.train()\n\n    epoch_g_loss = 0.0\n    epoch_d_loss = 0.0\n    g_steps = 0\n    d_steps = 0\n\n    for real_imgs, labels in mnist_loader:\n        real_imgs = real_imgs.to(DEVICE, non_blocking=True)\n        labels = labels.to(DEVICE, non_blocking=True)\n\n        batch_size = real_imgs.size(0)\n\n        # ---------------------\n        # Train Critic\n        # ---------------------\n        optimizer_D.zero_grad()\n\n        z = torch.randn(batch_size, LATENT_DIM, device=DEVICE)\n        fake_imgs = G(z, labels).detach()\n\n        real_score = D(real_imgs, labels).mean()\n        fake_score = D(fake_imgs, labels).mean()\n        gp = gradient_penalty(D, real_imgs, fake_imgs, labels)\n\n        d_loss = fake_score - real_score + LAMBDA_GP * gp\n        d_loss.backward()\n        optimizer_D.step()\n\n        epoch_d_loss += d_loss.item()\n        d_steps += 1\n\n        # ---------------------\n        # Train Generator every N_CRITIC steps\n        # ---------------------\n        if step % N_CRITIC == 0:\n            optimizer_G.zero_grad()\n\n            gen_labels = torch.randint(0, N_CLASSES, (batch_size,), device=DEVICE)\n            z = torch.randn(batch_size, LATENT_DIM, device=DEVICE)\n\n            gen_imgs = G(z, gen_labels)\n\n            adv_loss = -D(gen_imgs, gen_labels).mean()\n\n            target_proto = mnist_class_prototypes[gen_labels]\n            proto_loss = F.l1_loss(gen_imgs, target_proto)\n\n            oracle_input = (gen_imgs + 1) / 2\n            cls_loss = F.cross_entropy(oracle_model(oracle_input), gen_labels)\n\n            tv_loss = total_variation_loss(gen_imgs)\n\n            g_loss = (\n                adv_loss\n                + LAMBDA_PROTO * proto_loss\n                + LAMBDA_CLS * cls_loss\n                + LAMBDA_TV * tv_loss\n            )\n\n            g_loss.backward()\n            optimizer_G.step()\n\n            epoch_g_loss += g_loss.item()\n            g_steps += 1\n\n        step += 1\n\n    avg_d_loss = epoch_d_loss / max(1, d_steps)\n    avg_g_loss = epoch_g_loss / max(1, g_steps)\n\n    D_losses.append(avg_d_loss)\n    G_losses.append(avg_g_loss)\n\n    print(\n        f\"Epoch {epoch:03d}/{WGAN_EPOCHS} | \"\n        f\"D Loss: {avg_d_loss:.4f} | \"\n        f\"G Loss: {avg_g_loss:.4f}\"\n    )\n\n    if epoch == 1 or epoch % 5 == 0 or epoch == WGAN_EPOCHS:\n        show_proto_wgan(epoch)\n\n\ntorch.save(G.state_dict(), \"/kaggle/working/prototype_guided_wgan_gp_generator.pth\")\ntorch.save(D.state_dict(), \"/kaggle/working/prototype_guided_wgan_gp_critic.pth\")\n\nplt.figure(figsize=(7, 4))\nplt.plot(G_losses, label=\"Generator Loss\")\nplt.plot(D_losses, label=\"Critic Loss\")\nplt.xlabel(\"Epoch\")\nplt.ylabel(\"Loss\")\nplt.title(\"Prototype-guided WGAN-GP Training Loss\")\nplt.legend()\nplt.tight_layout()\nplt.savefig(\"/kaggle/working/prototype_guided_wgan_gp_loss.png\", dpi=300)\nplt.show()\n\nprint(\"Saved:\")\nprint(\"/kaggle/working/prototype_guided_wgan_gp_generator.pth\")\nprint(\"/kaggle/working/prototype_guided_wgan_gp_critic.pth\")\nprint(\"/kaggle/working/prototype_guided_wgan_gp_loss.png\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-09T15:50:18.041701Z","iopub.execute_input":"2026-06-09T15:50:18.042595Z","iopub.status.idle":"2026-06-09T16:05:11.558726Z","shell.execute_reply.start