    "# ============================================================\n",
    "# Cell 10 — Parse IN, MU, MW datasets with automatic channel detection\n",
    "# ============================================================\n",
    "\n",
    "DEVICE_PER_CLASS = 2000\n",
    "DEVICE_FIXED_LEN = 256\n",
    "\n",
    "DEVICE_FILES = {\n",
    "    \"IN\": \"/kaggle/input/datasets/vijayveersingh/1-2m-brain-signal-data/MindBigData-IN-v1.06/IN.txt\",\n",
    "    \"MU\": \"/kaggle/input/datasets/vijayveersingh/1-2m-brain-signal-data/MindBigData-MU-v1.0/MU.txt\",\n",
    "    \"MW\": \"/kaggle/input/datasets/vijayveersingh/1-2m-brain-signal-data/MindBigData-MW-v1.0/MW.txt\"\n",
    "}\n",
    "\n",
    "def infer_device_channels(filepath, device_name, max_lines=200000):\n",
    "    channels = []\n",
    "    seen = set()\n",
    "    count = 0\n",
    "\n",
    "    with open(filepath, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
    "        for line in f:\n",
    "            parts = line.rstrip(\"\\n\").split(\"\\t\", 6)\n",
    "\n",
    "            if len(parts) != 7:\n",
    "                continue\n",
    "\n",
    "            if parts[2] != device_name:\n",
    "                continue\n",
    "\n",
    "            ch = parts[3]\n",
    "\n",
    "            if ch not in seen:\n",
    "                seen.add(ch)\n",
    "                channels.append(ch)\n",
    "\n",
    "            count += 1\n",
    "\n",
    "            if count >= max_lines:\n",
    "                break\n",
    "\n",
    "    return channels\n",
    "\n",
    "\n",
    "def parse_mindbig_device_auto(filepath, device_name, fixed_len=DEVICE_FIXED_LEN, per_class=DEVICE_PER_CLASS):\n",
    "    channels = infer_device_channels(filepath, device_name)\n",
    "    ch_to_idx = {ch: i for i, ch in enumerate(channels)}\n",
    "    channel_set = set(channels)\n",
    "\n",
    "    buffer = {}\n",
    "    counts = defaultdict(int)\n",
    "\n",
    "    X_list = []\n",
    "    y_list = []\n",
    "    event_list = []\n",
    "\n",
    "    with open(filepath, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
    "        for line in tqdm(f, desc=f\"Parsing {device_name}\"):\n",
    "            parts = line.rstrip(\"\\n\").split(\"\\t\", 6)\n",
    "\n",
    "            if len(parts) != 7:\n",
    "                continue\n",
    "\n",
    "            event_id = int(parts[1])\n",
    "            device = parts[2]\n",
    "            channel = parts[3]\n",
    "            label = int(parts[4])\n",
    "            values_str = parts[6]\n",
    "\n",
    "            if device != device_name:\n",
    "                continue\n",
    "\n",
    "            if channel not in channel_set:\n",
    "                continue\n",
    "\n",
    "            if label < 0 or label >= N_CLASSES:\n",
    "                continue\n",
    "\n",
    "            if counts[label] >= per_class:\n",
    "                continue\n",
    "\n",
    "            values = np.fromstring(values_str, sep=\",\", dtype=np.float32)\n",
    "\n",
    "            if len(values) >= fixed_len:\n",
    "                values = values[:fixed_len]\n",
    "            else:\n",
    "                values = np.pad(values, (0, fixed_len - len(values)))\n",
    "\n",
    "            if event_id not in buffer:\n",
    "                buffer[event_id] = {\n",
    "                    \"label\": label,\n",
    "                    \"channels\": {}\n",
    "                }\n",
    "\n",
    "            buffer[event_id][\"channels\"][channel] = values\n",
    "\n",
    "            if len(buffer[event_id][\"channels\"]) == len(channels):\n",
    "                final_label = buffer[event_id][\"label\"]\n",
    "\n",
    "                if counts[final_label] < per_class:\n",
    "                    trial = np.zeros((len(channels), fixed_len), dtype=np.float32)\n",
    "\n",
    "                    for ch_name, ch_values in buffer[event_id][\"channels\"].items():\n",
    "                        trial[ch_to_idx[ch_name]] = ch_values\n",
    "\n",
    "                    X_list.append(trial)\n",
    "                    y_list.append(final_label)\n",
    "                    event_list.append(event_id)\n",
    "\n",
    "                    counts[final_label] += 1\n",
    "\n",
    "                del buffer[event_id]\n",
    "\n",
    "            if all(counts[c] >= per_class for c in range(N_CLASSES)):\n",
    "                break\n",
    "\n",
    "    X_device = np.stack(X_list).astype(np.float32)\n",
    "    y_device = np.array(y_list, dtype=np.int64)\n",
    "    event_device = np.array(event_list, dtype=np.int64)\n",
    "\n",
    "    return X_device, y_device, event_device, channels\n",
    "\n",
    "\n",
    "device_data = {}\n",
    "\n",
    "for device_name, filepath in DEVICE_FILES.items():\n",
    "    X_dev, y_dev, event_dev, channels = parse_mindbig_device_auto(\n",
    "        filepath=filepath,\n",
    "        device_name=device_name\n",
    "    )\n",
    "\n",
    "    device_data[device_name] = {\n",
    "        \"X\": X_dev,\n",
    "        \"y\": y_dev,\n",
    "        \"event_ids\": event_dev,\n",
    "        \"channels\": channels\n",
    "    }\n",
    "\n",
    "    print(f\"\\n{device_name} dataset ready\")\n",
    "    print(\"Channels    :\", channels)\n",
    "    print(\"X shape     :\", X_dev.shape)\n",
    "    print(\"y shape     :\", y_dev.shape)\n",
    "    print(\"Class counts:\", Counter(y_dev))"
   ]
