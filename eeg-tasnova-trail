obals() and isinstance(globals()[name], nn.Module):\n        candidate = globals()[name].to(DEVICE)\n        candidate.eval()\n\n        try:\n            xb_test = torch.tensor(Xte_t[:2], dtype=torch.float32).to(DEVICE)\n            with torch.no_grad():\n                out = candidate(xb_test)\n\n            if out.ndim == 2 and out.shape[1] == N_CLASSES:\n                eeg_model = candidate\n                eeg_model_name = name\n                break\n\n        except:\n            pass\n\nif eeg_model is None:\n    raise RuntimeError(\"No trained EEG classifier found. Please check the EEGNet model variable name.\")\n\nprint(\"Using EEG classifier:\", eeg_model_name)\n\n\n# ------------------------------------------------------------\n# Select one test EEG sample from each true digit class\n# ------------------------------------------------------------\ndemo_indices = []\n\nfor d in range(N_CLASSES):\n    idx = np.where(yte_t == d)[0]\n    demo_indices.append(idx[0])\n\nX_demo = torch.tensor(Xte_t[demo_indices], dtype=torch.float32).to(DEVICE)\ny_true_demo = torch.tensor(yte_t[demo_indices], dtype=torch.long).to(DEVICE)\n\n\n# ------------------------------------------------------------\n# EEG classification\n# ------------------------------------------------------------\neeg_model.eval()\n\nwith torch.no_grad():\n    eeg_logits = eeg_model(X_demo)\n    eeg_probs = torch.softmax(eeg_logits, dim=1)\n    y_pred_demo = eeg_probs.argmax(dim=1)\n    eeg_conf_demo = eeg_probs.max(dim=1).values\n\n\n# ------------------------------------------------------------\n# Generate best image for each label using oracle confidence\n# ------------------------------------------------------------\ndef generate_best_images(label_tensor, candidates_per_label=32):\n    gen.eval()\n    oracle.eval()\n\n    n = label_tensor.size(0)\n\n    repeated_labels = label_tensor.repeat_interleave(candidates_per_label)\n    z = torch.randn(n * candidates_per_label, Z_DIM, device=DEVICE)\n\n    with torch.no_grad():\n        imgs = gen(z, repeated_labels)\n        imgs = ((imgs + 1.0) / 2.0).clamp(0, 1)\n\n        oracle_logits = oracle(imgs)\n        oracle_probs = torch.softmax(oracle_logits, dim=1)\n\n        target_conf = oracle_probs.gather(\n            1,\n            repeated_labels.view(-1, 1)\n        ).squeeze(1)\n\n    imgs = imgs.view(n, candidates_per_label, 1, 28, 28)\n    target_conf = target_conf.view(n, candidates_per_label)\n\n    best_idx = target_conf.argmax(dim=1)\n\n    best_imgs = []\n    best_confs = []\n\n    for i in range(n):\n        best_imgs.append(imgs[i, best_idx[i]])\n        best_confs.append(target_conf[i, best_idx[i]])\n\n    best_imgs = torch.stack(best_imgs)\n    best_confs = torch.stack(best_confs)\n\n    return best_imgs, best_confs\n\n\ntrue_label_imgs, true_label_gen_conf = generate_best_images(y_true_demo)\npred_label_imgs, pred_label_gen_conf = generate_best_images(y_pred_demo)\n\n\n# ------------------------------------------------------------\n# Oracle check on generated images\n# ------------------------------------------------------------\nwith torch.no_grad():\n    true_gen_probs = torch.softmax(oracle(true_label_imgs), dim=1)\n    pred_gen_probs = torch.softmax(oracle(pred_label_imgs), dim=1)\n\n    true_gen_oracle_pred = true_gen_probs.argmax(dim=1)\n    pred_gen_oracle_pred = pred_gen_probs.argmax(dim=1)\n\n    true_gen_oracle_conf = true_gen_probs.max(dim=1).values\n    pred_gen_oracle_conf = pred_gen_probs.max(dim=1).values\n\n\n# ------------------------------------------------------------\n# Result table\n# ------------------------------------------------------------\ndemo_df = pd.DataFrame({\n    \"Sample\": np.arange(N_CLASSES),\n    \"True EEG Label\": y_true_demo.detach().cpu().numpy(),\n    \"EEG Predicted Label\": y_pred_demo.detach().cpu().numpy(),\n    \"EEG Confidence\": eeg_conf_demo.detach().cpu().numpy(),\n    \"Oracle Pred on True-Label Generated Image\": true_gen_oracle_pred.detach().cpu().numpy(),\n    \"Oracle Conf True-Label Image\": true_gen_oracle_conf.detach().cpu().numpy(),\n    \"Oracle Pred on EEG-Predicted Generated Image\": pred_gen_oracle_pred.detach().cpu().numpy(),\n    \"Oracle Conf EEG-Predicted Image\": pred_gen_oracle_conf.detach().cpu().numpy()\n})\n\nprint(\"\\n========== EEG-to-Image Demonstration Table ==========\")\ndisplay(demo_df)\n\ndemo_df.to_csv(\"/kaggle/working/eeg_to_image_demo_table.csv\", index=False)\n\n\n# ------------------------------------------------------------\n# Visualization: true-label generation vs EEG-predicted generation\n# ------------------------------------------------------------\nplt.figure(figsize=(14, 4))\n\nfor i in range(N_CLASSES):\n    plt.subplot(2, N_CLASSES, i + 1)\n    plt.imshow(true_label_imgs[i, 0].detach().cpu(), cmap=\"gray\")\n    plt.title(f\"T={int(y_true_demo[i])}\")\n    plt.axis(\"off\")\n\n    plt.subplot(2, N_CLASSES, i + 1 + N_CLASSES)\n    plt.imshow(pred_label_imgs[i, 0].detach().cpu(), cmap=\"gray\")\n    plt.title(f\"P={int(y_pred_demo[i])}\")\n    plt.axis(\"off\")\n\nplt.suptitle(\"EEG-to-Image Generation: True-Label Upper Bound vs EEG-Predicted Pipeline\")\nplt.tight_layout()\nplt.savefig(\"/kaggle/working/eeg_to_image_true_vs_predicted_generation.png\", dpi=300)\nplt.show()\n\n\n# ------------------------------------------------------------\n# Summary\n# ------------------------------------------------------------\ndemo_eeg_acc = (y_pred_demo == y_true_demo).float().mean().item()\ntrue_gen_acc = (true_gen_oracle_pred == y_true_demo).float().mean().item()\npred_gen_acc = (pred_gen_oracle_pred == y_pred_demo).float().mean().item()\n\nprint(\"\\n========== Demo Summary ==========\")\nprint(f\"Demo EEG classification accuracy              : {demo_eeg_acc:.4f}\")\nprint(f\"True-label generation oracle consistency      : {true_gen_acc:.4f}\")\nprint(f\"EEG-predicted generation oracle consistency   : {pred_gen_acc:.4f}\")\n\nprint(\"\\nSaved:\")\nprint(\"/kaggle/working/