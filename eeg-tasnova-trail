    "# ============================================================\n",
    "# Cell 15 Final — Sir-style Conditional DCGAN for MNIST digit generation\n",
    "# ============================================================\n",
    "\n",
    "torch.cuda.empty_cache()\n",
    "\n",
    "Z_DIM = 100\n",
    "GAN_EPOCHS = 30\n",
    "GAN_BATCH = 128\n",
    "\n",
    "class SirStyleGenerator(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.emb = nn.Embedding(N_CLASSES, N_CLASSES)\n",
    "\n",
    "        self.fc = nn.Linear(Z_DIM + N_CLASSES, 128 * 7 * 7)\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            nn.BatchNorm2d(128),\n",
    "            nn.ReLU(True),\n",
    "\n",
    "            nn.ConvTranspose2d(128, 64, 4, 2, 1),\n",
    "            nn.BatchNorm2d(64),\n",
    "            nn.ReLU(True),\n",
    "\n",
    "            nn.ConvTranspose2d(64, 1, 4, 2, 1),\n",
    "            nn.Tanh()\n",
    "        )\n",
    "\n",
    "    def forward(self, z, labels):\n",
    "        x = torch.cat([z, self.emb(labels)], dim=1)\n",
    "        x = self.fc(x)\n",
    "        x = x.view(-1, 128, 7, 7)\n",
    "        return self.net(x)\n",
    "\n",
    "\n",
    "class SirStyleDiscriminator(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.emb = nn.Embedding(N_CLASSES, 28 * 28)\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Conv2d(2, 64, 4, 2, 1),\n",
    "            nn.LeakyReLU(0.2, True),\n",
    "\n",
    "            nn.Conv2d(64, 128, 4, 2, 1),\n",
    "            nn.BatchNorm2d(128),\n",
    "            nn.LeakyReLU(0.2, True),\n",
    "\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(128 * 7 * 7, 1)\n",
    "        )\n",
    "\n",
    "    def forward(self, img, labels):\n",
    "        label_map = self.emb(labels).view(-1, 1, 28, 28)\n",
    "        x = torch.cat([img, label_map], dim=1)\n",
    "        return self.net(x)\n",
    "\n",
    "\n",
    "gen = SirStyleGenerator().to(DEVICE)\n",
    "dis = SirStyleDiscriminator().to(DEVICE)\n",
    "\n",
    "opt_G = torch.optim.Adam(gen.parameters(), lr=2e-4, betas=(0.5, 0.999))\n",
    "opt_D = torch.optim.Adam(dis.parameters(), lr=2e-4, betas=(0.5, 0.999))\n",
    "\n",
    "bce = nn.BCEWithLogitsLoss()\n",
    "\n",
    "fixed_z = torch.randn(N_CLASSES, Z_DIM, device=DEVICE)\n",
    "fixed_labels = torch.arange(N_CLASSES, device=DEVICE)\n",
    "\n",
    "def show_generated_digits(epoch):\n",
    "    gen.eval()\n",
    "    with torch.no_grad():\n",
    "        samples = gen(fixed_z, fixed_labels)\n",
    "        samples = (samples + 1) / 2\n",
    "        samples = samples.detach().cpu()\n",
    "\n",
    "    plt.figure(figsize=(10, 2))\n",
    "    for d in range(N_CLASSES):\n",
    "        plt.subplot(1, N_CLASSES, d + 1)\n",
    "        plt.imshow(samples[d, 0], cmap=\"gray\")\n",
    "        plt.title(str(d))\n",
    "        plt.axis(\"off\")\n",
    "\n",
    "    plt.suptitle(f\"Sir-style Conditional DCGAN | Epoch {epoch}\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    gen.train()\n",
    "\n",
    "\n",
    "G_losses = []\n",
    "D_losses = []\n",
    "\n",
    "for ep in range(1, GAN_EPOCHS + 1):\n",
    "    gen.train()\n",
    "    dis.train()\n",
    "\n",
    "    total_g_loss = 0.0\n",
    "    total_d_loss = 0.0\n",
    "    total_batches = 0\n",
    "\n",
    "    for real, labels in mnist_loader:\n",
    "        real = real.to(DEVICE, non_blocking=True)\n",
    "        labels = labels.to(DEVICE, non_blocking=True)\n",
    "\n",
    "        bs = real.size(0)\n",
    "\n",
    "        ones = torch.ones(bs, 1, device=DEVICE)\n",
    "        zeros = torch.zeros(bs, 1, device=DEVICE)\n",
    "\n",
    "        # Train Discriminator\n",
    "        z = torch.randn(bs, Z_DIM, device=DEVICE)\n",
    "        fake = gen(z, labels)\n",
    "\n",
    "        d_real = bce(dis(real, labels), ones)\n",
    "        d_fake = bce(dis(fake.detach(), labels), zeros)\n",
    "        d_loss = d_real + d_fake\n",
    "\n",
    "        opt_D.zero_grad()\n",
    "        d_loss.backward()\n",
    "        opt_D.step()\n",
    "\n",
    "        # Train Generator\n",
    "        g_loss = bce(dis(fake, labels), ones)\n",
    "\n",
    "        opt_G.zero_grad()\n",
    "        g_loss.backward()\n",
    "        opt_G.step()\n",
    "\n",
    "        total_d_loss += d_loss.item()\n",
    "        total_g_loss += g_loss.item()\n",
    "        total_batches += 1\n",
    "\n",
    "    avg_d = total_d_loss / total_batches\n",
    "    avg_g = total_g_loss / total_batches\n",
    "\n",
    "    D_losses.append(avg_d)\n",
    "    G_losses.append(avg_g)\n",
    "\n",
    "    print(f\"Epoch {ep:03d}/{GAN_EPOCHS} | D Loss: {avg_d:.4f} | G Loss: {avg_g:.4f}\")\n",
    "\n",
    "    if ep == 1 or ep % 5 == 0 or ep == GAN_EPOCHS:\n",
    "        show_generated_digits(ep)\n",
    "\n",
    "\n",
    "torch.save(gen.state_dict(), \"/kaggle/working/sir_style_conditional_dcgan_generator.pth\")\n",
    "torch.save(dis.state_dict(), \"/kaggle/working/sir_style_conditional_dcgan_discriminator.pth\")\n",
    "\n",
    "plt.figure(figsize=(7, 4))\n",
    "plt.plot(G_losses, label=\"Generator Loss\")\n",
    "plt.plot(D_losses, label=\"Discriminator Loss\")\n",
    "plt.xlabel(\"Epoch\")\n",
    "plt.ylabel(\"Loss\")\n",
    "plt.title(\" Conditional DCGAN Training Loss\")\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/sir_style_conditional_dcgan_loss.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "print(\"Saved:\")\n",
    "print(\"/kaggle/working/sir_style_conditional_dcgan_generator.pth\")\n",
    "print(\"/kaggle/working/sir_style_conditional_dcgan_discriminator.pth\")\n",
    "print(\"/kaggle/working/sir_style_conditional_dcgan_loss.png\")"
   ]
