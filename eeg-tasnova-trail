    "# =========================================================\n",
    "# Cell 15 NEW v3 — Warm-up + discriminator, with best-generator restore\n",
    "# =========================================================\n",
    "\n",
    "import copy\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "N_CLASSES = 10\n",
    "Z_DIM = 100\n",
    "\n",
    "if \"gan_loader\" not in globals() or gan_loader is None:\n",
    "    raise ValueError(\"gan_loader not found. Run Cell 13B first.\")\n",
    "\n",
    "xb_check, yb_check = next(iter(gan_loader))\n",
    "print(\"Using gan_loader\")\n",
    "print(\"Batch:\", xb_check.shape, yb_check.shape)\n",
    "print(\"Range:\", xb_check.min().item(), xb_check.max().item())\n",
    "\n",
    "\n",
    "class StableCondGenerator(nn.Module):\n",
    "    def __init__(self, z_dim=100, n_classes=10, emb_dim=50):\n",
    "        super().__init__()\n",
    "        self.label_emb = nn.Embedding(n_classes, emb_dim)\n",
    "\n",
    "        self.fc = nn.Sequential(\n",
    "            nn.Linear(z_dim + emb_dim, 256 * 7 * 7),\n",
    "            nn.BatchNorm1d(256 * 7 * 7),\n",
    "            nn.ReLU(True)\n",
    "        )\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Unflatten(1, (256, 7, 7)),\n",
    "            nn.ConvTranspose2d(256, 128, 4, 2, 1, bias=False),\n",
    "            nn.BatchNorm2d(128),\n",
    "            nn.ReLU(True),\n",
    "            nn.ConvTranspose2d(128, 64, 4, 2, 1, bias=False),\n",
    "            nn.BatchNorm2d(64),\n",
    "            nn.ReLU(True),\n",
    "            nn.Conv2d(64, 1, 3, 1, 1),\n",
    "            nn.Tanh()\n",
    "        )\n",
    "\n",
    "    def forward(self, z, labels):\n",
    "        y = self.label_emb(labels)\n",
    "        x = torch.cat([z, y], dim=1)\n",
    "        x = self.fc(x)\n",
    "        return self.net(x)\n",
    "\n",
    "\n",
    "class StableCondDiscriminator(nn.Module):\n",
    "    def __init__(self, n_classes=10):\n",
    "        super().__init__()\n",
    "        self.label_emb = nn.Embedding(n_classes, 28 * 28)\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Conv2d(2, 64, 4, 2, 1),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "            nn.Conv2d(64, 128, 4, 2, 1),\n",
    "            nn.BatchNorm2d(128),\n",
    "            nn.LeakyReLU(0.2, inplace=True),\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(128 * 7 * 7, 1),\n",
    "            nn.Sigmoid()\n",
    "        )\n",
    "\n",
    "    def forward(self, imgs, labels):\n",
    "        label_map = self.label_emb(labels).view(-1, 1, 28, 28)\n",
    "        x = torch.cat([imgs, label_map], dim=1)\n",
    "        return self.net(x).view(-1)\n",
    "\n",
    "\n",
    "gen = StableCondGenerator(z_dim=Z_DIM, n_classes=N_CLASSES).to(DEVICE)\n",
    "disc = StableCondDiscriminator(n_classes=N_CLASSES).to(DEVICE)\n",
    "\n",
    "opt_g = torch.optim.Adam(gen.parameters(), lr=1.5e-4, betas=(0.5, 0.999))\n",
    "opt_d = torch.optim.Adam(disc.parameters(), lr=3e-5, betas=(0.5, 0.999))\n",
    "\n",
    "bce = nn.BCELoss()\n",
    "\n",
    "WARMUP_EPOCHS = 15\n",
    "GAN_EPOCHS = 10\n",
    "TOTAL_EPOCHS = WARMUP_EPOCHS + GAN_EPOCHS\n",
    "\n",
    "fixed_noise = torch.randn(N_CLASSES, Z_DIM, device=DEVICE)\n",
    "fixed_labels = torch.arange(N_CLASSES, device=DEVICE)\n",
    "\n",
    "g_losses = []\n",
    "d_losses = []\n",
    "\n",
    "best_state = copy.deepcopy(gen.state_dict())\n",
    "best_visual_epoch = 0\n",
    "best_score = -1.0\n",
    "\n",
    "\n",
    "def visual_score(fake_01):\n",
    "    score = 0.0\n",
    "    for i in range(N_CLASSES):\n",
    "        img = fake_01[i, 0]\n",
    "        score += img.mean().item()\n",
    "    return score\n",
    "\n",
    "\n",
    "def show_generated(epoch, note=\"\"):\n",
    "    global best_state, best_score, best_visual_epoch\n",
    "\n",
    "    gen.eval()\n",
    "    with torch.no_grad():\n",
    "        fake = gen(fixed_noise, fixed_labels)\n",
    "        fake_01 = ((fake + 1.0) / 2.0).clamp(0, 1)\n",
    "        score = visual_score(fake_01)\n",
    "\n",
    "        if score > best_score and epoch <= WARMUP_EPOCHS:\n",
    "            best_score = score\n",
    "            best_visual_epoch = epoch\n",
    "            best_state = copy.deepcopy(gen.state_dict())\n",
    "\n",
    "    fake_np = fake_01.detach().cpu().numpy()\n",
    "\n",
    "    plt.figure(figsize=(12, 2.4))\n",
    "    for i in range(N_CLASSES):\n",
    "        plt.subplot(1, N_CLASSES, i + 1)\n",
    "        plt.imshow(fake_np[i, 0], cmap=\"gray\")\n",
    "        plt.title(str(i))\n",
    "        plt.axis(\"off\")\n",
    "\n",
    "    plt.suptitle(f\"Generator Output | Epoch {epoch} {note}\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    gen.train()\n",
    "\n",
    "\n",
    "print(\"Starting GAN training...\")\n",
    "print(\"Phase 1: generator only =\", WARMUP_EPOCHS, \"epochs\")\n",
    "print(\"Phase 2: discriminator works, generator protected =\", GAN_EPOCHS, \"epochs\")\n",
    "\n",
    "\n",
    "for epoch in range(1, TOTAL_EPOCHS + 1):\n",
    "\n",
    "    epoch_g_loss = 0.0\n",
    "    epoch_d_loss = 0.0\n",
    "    batch_count = 0\n",
    "\n",
    "    for real_imgs, labels in gan_loader:\n",
    "        real_imgs = real_imgs.to(DEVICE)\n",
    "        labels = labels.to(DEVICE)\n",
    "\n",
    "        bs = real_imgs.size(0)\n",
    "\n",
    "        # -----------------------------\n",
    "        # Phase 1: Generator only\n",
    "        # -----------------------------\n",
    "        if epoch <= WARMUP_EPOCHS:\n",
    "            z = torch.randn(bs, Z_DIM, device=DEVICE)\n",
    "            fake_imgs = gen(z, labels)\n",
    "\n",
    "            g_loss = 0.85 * F.l1_loss(fake_imgs, real_imgs) + 0.15 * F.mse_loss(fake_imgs, real_imgs)\n",
    "\n",
    "            opt_g.zero_grad()\n",
    "            g_loss.backward()\n",
    "            opt_g.step()\n",
    "\n",
    "            d_loss_value = 0.0\n",
    "\n",
    "        # -----------------------------\n",
    "        # Phase 2: Discriminator works\n",
    "        # Generator is protected by strong shape loss\n",
    "        # -----------------------------\n",
    "        else:\n",
    "            real_targets = torch.full((bs,), 0.9, device=DEVICE)\n",
    "            fake_targets = torch.zeros(bs, device=DEVICE)\n",
    "\n",
    "            # Train discriminator\n",
    "            z = torch.randn(bs, Z_DIM, device=DEVICE)\n",
    "            with torch.no_grad():\n",
    "                fake_imgs = gen(z, labels)\n",
    "\n",
    "            real_score = disc(real_imgs, labels)\n",
    "            fake_score = disc(fake_imgs, labels)\n",
    "\n",
    "            d_loss = 0.5 * (\n",
    "                bce(real_score, real_targets) +\n",
    "                bce(fake_score, fake_targets)\n",
    "            )\n",
    "\n",
    "            opt_d.zero_grad()\n",
    "            d_loss.backward()\n",
    "            opt_d.step()\n",
    "\n",
    "            # Very light generator update\n",
    "            z = torch.randn(bs, Z_DIM, device=DEVICE)\n",
    "            fake_imgs = gen(z, labels)\n",
    "\n",
    "            fake_score_for_g = disc(fake_imgs, labels)\n",
    "\n",
    "            adv_loss = bce(fake_score_for_g, real_targets)\n",
    "            shape_loss = F.l1_loss(fake_imgs, real_imgs)\n",
    "\n",
    "            g_loss = 0.05 * adv_loss + 1.00 * shape_loss\n",
    "\n",
    "            opt_g.zero_grad()\n",
    "            g_loss.backward()\n",
    "            opt_g.step()\n",
    "\n",
