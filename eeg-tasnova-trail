    "# ============================================================\n",
    "# Cell 16B — Perceptual similarity between generated digits and real MNIST\n",
    "# ============================================================\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from torchvision import datasets, transforms\n",
    "\n",
    "torch.cuda.empty_cache()\n",
    "\n",
    "gen.eval()\n",
    "oracle.eval()\n",
    "\n",
    "DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "MNIST_ROOT = \"/kaggle/working/mnist_data\"\n",
    "N_CLASSES = 10\n",
    "REF_PER_DIGIT = 300\n",
    "GEN_CANDIDATES = 128\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1) Load real MNIST images in [0, 1] range\n",
    "# ------------------------------------------------------------\n",
    "mnist_real_dataset = datasets.MNIST(\n",
    "    root=MNIST_ROOT,\n",
    "    train=True,\n",
    "    download=True,\n",
    "    transform=transforms.ToTensor()\n",
    ")\n",
    "\n",
    "ref_imgs = []\n",
    "ref_labels = []\n",
    "count_per_digit = {d: 0 for d in range(N_CLASSES)}\n",
    "\n",
    "for img, label in mnist_real_dataset:\n",
    "    if count_per_digit[label] < REF_PER_DIGIT:\n",
    "        ref_imgs.append(img)\n",
    "        ref_labels.append(label)\n",
    "        count_per_digit[label] += 1\n",
    "\n",
    "    if all(count_per_digit[d] >= REF_PER_DIGIT for d in range(N_CLASSES)):\n",
    "        break\n",
    "\n",
    "ref_imgs = torch.stack(ref_imgs).to(DEVICE)\n",
    "ref_labels = torch.tensor(ref_labels, dtype=torch.long).to(DEVICE)\n",
    "\n",
    "print(\"Real MNIST reference images:\", ref_imgs.shape)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2) Feature extractor from trained MNIST oracle\n",
    "# ------------------------------------------------------------\n",
    "conv_layers = [m for m in oracle.modules() if isinstance(m, nn.Conv2d)]\n",
    "\n",
    "if len(conv_layers) == 0:\n",
    "    raise RuntimeError(\"No convolution layer found in oracle model.\")\n",
    "\n",
    "feature_layer = conv_layers[-1]\n",
    "\n",
    "def extract_oracle_features(model, images, batch_size=256):\n",
    "    model.eval()\n",
    "    all_features = []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for start in range(0, images.size(0), batch_size):\n",
    "            batch = images[start:start + batch_size].to(DEVICE)\n",
    "            captured = []\n",
    "\n",
    "            def hook_fn(module, inp, out):\n",
    "                captured.append(out.detach())\n",
    "\n",
    "            handle = feature_layer.register_forward_hook(hook_fn)\n",
    "            _ = model(batch)\n",
    "            handle.remove()\n",
    "\n",
    "            feat = captured[0]\n",
    "            feat = feat.view(feat.size(0), -1)\n",
    "            feat = F.normalize(feat, dim=1)\n",
    "\n",
    "            all_features.append(feat.cpu())\n",
    "\n",
    "    return torch.cat(all_features, dim=0)\n",
    "\n",
    "\n",
    "ref_features = extract_oracle_features(oracle, ref_imgs)\n",
    "print(\"Reference feature shape:\", ref_features.shape)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3) Generate best image per digit using oracle confidence\n",
    "# ------------------------------------------------------------\n",
    "best_gen_imgs = []\n",
    "best_gen_conf = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for d in range(N_CLASSES):\n",
    "        labels = torch.full((GEN_CANDIDATES,), d, dtype=torch.long, device=DEVICE)\n",
    "        z = torch.randn(GEN_CANDIDATES, Z_DIM, device=DEVICE)\n",
    "\n",
    "        imgs = gen(z, labels)\n",
    "        imgs_01 = ((imgs + 1.0) / 2.0).clamp(0, 1)\n",
    "\n",
    "        probs = torch.softmax(oracle(imgs_01), dim=1)\n",
    "        target_conf = probs[:, d]\n",
    "\n",
    "        best_idx = target_conf.argmax()\n",
    "\n",
    "        best_gen_imgs.append(imgs_01[best_idx].detach().cpu())\n",
    "        best_gen_conf.append(float(target_conf[best_idx].item()))\n",
    "\n",
    "best_gen_imgs = torch.stack(best_gen_imgs).to(DEVICE)\n",
    "gen_features = extract_oracle_features(oracle, best_gen_imgs)\n",
    "\n",
    "print(\"Generated image feature shape:\", gen_features.shape)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 4) Perceptual similarity with closest real MNIST image\n",
    "# ------------------------------------------------------------\n",
    "nearest_real_imgs = []\n",
    "perceptual_scores = []\n",
    "perceptual_distances = []\n",
    "prototype_scores = []\n",
    "\n",
    "for d in range(N_CLASSES):\n",
    "    digit_mask = (ref_labels.cpu() == d)\n",
    "    digit_indices = torch.where(digit_mask)[0]\n",
    "\n",
    "    digit_ref_features = ref_features[digit_indices]\n",
    "\n",
    "    gen_feat = gen_features[d].unsqueeze(0)\n",
    "\n",
    "    # nearest real MNIST image in oracle-feature space\n",
    "    sims = torch.matmul(gen_feat, digit_ref_features.T).squeeze(0)\n",
    "    best_ref_local_idx = sims.argmax().item()\n",
    "    best_score = sims[best_ref_local_idx].item()\n",
    "\n",
    "    best_ref_global_idx = digit_indices[best_ref_local_idx].item()\n",
    "    nearest_real_imgs.append(ref_imgs[best_ref_global_idx].detach().cpu())\n",
    "\n",
    "    # class prototype feature similarity\n",
    "    prototype_feat = digit_ref_features.mean(dim=0, keepdim=True)\n",
    "    prototype_feat = F.normalize(prototype_feat, dim=1)\n",
    "    prototype_score = torch.matmul(gen_feat, prototype_feat.T).item()\n",
    "\n",
    "    perceptual_scores.append(best_score)\n",
    "    perceptual_distances.append(1.0 - best_score)\n",
    "    prototype_scores.append(prototype_score)\n",
    "\n",
    "\n",
    "perceptual_df = pd.DataFrame({\n",
    "    \"Digit\": list(range(N_CLASSES)),\n",
    "    \"Nearest MNIST Perceptual Score\": perceptual_scores,\n",
    "    \"Nearest MNIST Perceptual Distance\": perceptual_distances,\n",
    "    \"Prototype Perceptual Score\": prototype_scores,\n",
    "    \"Generator Oracle Confidence\": best_gen_conf\n",
    "})\n",
    "\n",
    "overall_row = pd.DataFrame([{\n",
    "    \"Digit\": \"Overall\",\n",
    "    \"Nearest MNIST Perceptual Score\": np.mean(perceptual_scores),\n",
    "    \"Nearest MNIST Perceptual Distance\": np.mean(perceptual_distances),\n",
    "    \"Prototype Perceptual Score\": np.mean(prototype_scores),\n",
    "    \"Generator Oracle Confidence\": np.mean(best_gen_conf)\n",
    "}])\n",
    "\n",
    "perceptual_df = pd.concat([perceptual_df, overall_row], ignore_index=True)\n",
    "\n",
    "print(\"\\n========== Perceptual Similarity Result ==========\")\n",
    "display(perceptual_df)\n",
    "\n",
    "perceptual_df.to_csv(\n",
    "    \"/kaggle/working/generated_vs_real_mnist_perceptual_scores.csv\",\n",
    "    index=False\n",
    ")\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 5) Visualization: generated image vs nearest real MNIST image\n",
    "# ------------------------------------------------------------\n",
    "plt.figure(figsize=(13, 3.8))\n",
    "\n",
    "for d in range(N_CLASSES):\n",
    "    plt.subplot(2, N_CLASSES, d + 1)\n",
    "    plt.imshow(best_gen_imgs[d, 0].detach().cpu(), cmap=\"gray\")\n",
    "    plt.title(f\"Gen {d}\", fontsize=10)\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "    plt.subplot(2, N_CLASSES, d + 1 + N_CLASSES)\n",
    "    plt.imshow(nearest_real_imgs[d][0], cmap=\"gray\")\n",
    "    plt.title(f\"Real {d}\\nS={perceptual_scores[d]:.3f}\", fontsize=9)\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "plt.suptitle(\"Generated Digit vs Closest Real MNIST Digit in Perceptual Feature Space\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/generated_vs_real_mnist_perceptual_comparison.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 6) Perceptual score bar chart\n",
    "# ------------------------------------------------------------\n",
    "plt.figure(figsize=(9, 4.5))\n",
    "plt.bar([str(d) for d in range(N_CLASSES)], perceptual_scores)\n",
    "plt.ylim(0, 1.05)\n",
    "plt.xlabel(\"Digit Class\")\n",
    "plt.ylabel(\"Perceptual Similarity Score\")\n",
    "plt.title(\"Perceptual Similarity Between Generated Digits and Real MNIST Digits\")\n",
    "\n",
    "for i, v in enumerate(perceptual_scores):\n",
    "    plt.text(i, v + 0.015, f\"{v:.3f}\", ha=\"center\", fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/generated_vs_real_mnist_perceptual_score_bar.png\", dpi=300)\n",
    "plt.show()\n",
    "\n",
    "\n",
    "print(\"Saved:\")\n",
    "print(\"/kaggle/working/generated_vs_real_mnist_perceptual_scores.csv\")\n",
    "print(\"/kaggle/working/generated_vs_real_mnist_perceptual_comparison.png\")\n",
    "print(\"/kaggle/working/generated_vs_real_mnist_perceptual_score_bar.png\")"
   ]
