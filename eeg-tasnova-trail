    "# ============================================================\n",
    "# Cell 15B — Train Better Conditional DCGAN\n",
    "# ============================================================\n",
    "\n",
    "GAN_EPOCHS = 60\n",
    "GAN_LR = 2e-4\n",
    "\n",
    "optimizer_G = torch.optim.Adam(G.parameters(), lr=GAN_LR, betas=(0.5, 0.999))\n",
    "optimizer_D = torch.optim.Adam(D.parameters(), lr=GAN_LR, betas=(0.5, 0.999))\n",
    "\n",
    "adversarial_loss = nn.BCEWithLogitsLoss()\n",
    "\n",
    "G_losses = []\n",
    "D_losses = []\n",
    "\n",
    "def show_generated_digits(epoch):\n",
    "    G.eval()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        gen_imgs = G(fixed_noise, fixed_labels)\n",
    "        gen_imgs = (gen_imgs + 1) / 2\n",
    "        gen_imgs = gen_imgs.detach().cpu()\n",
    "    \n",
    "    plt.figure(figsize=(10, 2))\n",
    "    for i in range(N_CLASSES):\n",
    "        plt.subplot(1, N_CLASSES, i + 1)\n",
    "        plt.imshow(gen_imgs[i, 0], cmap=\"gray\")\n",
    "        plt.title(str(i))\n",
    "        plt.axis(\"off\")\n",
    "    \n",
    "    plt.suptitle(f\"Better Conditional DCGAN Generated Digits | Epoch {epoch}\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    G.train()\n",
    "\n",
    "\n",
    "for epoch in range(1, GAN_EPOCHS + 1):\n",
    "    epoch_g_loss = 0.0\n",
    "    epoch_d_loss = 0.0\n",
    "    total_batches = 0\n",
    "    \n",
    "    for real_imgs, labels in mnist_loader:\n",
    "        real_imgs = real_imgs.to(DEVICE, non_blocking=True)\n",
    "        labels = labels.to(DEVICE, non_blocking=True)\n",
    "        \n",
    "        batch_size = real_imgs.size(0)\n",
    "        \n",
    "        real_targets = torch.ones(batch_size, 1, device=DEVICE) * 0.9\n",
    "        fake_targets = torch.zeros(batch_size, 1, device=DEVICE)\n",
    "        \n",
    "        # ---------------------\n",
    "        # Train Discriminator\n",
    "        # ---------------------\n",
    "        optimizer_D.zero_grad()\n",
    "        \n",
    "        real_logits = D(real_imgs, labels)\n",
    "        real_loss = adversarial_loss(real_logits, real_targets)\n",
    "        \n",
    "        z = torch.randn(batch_size, LATENT_DIM, device=DEVICE)\n",
    "        fake_imgs = G(z, labels)\n",
    "        \n",
    "        fake_logits = D(fake_imgs.detach(), labels)\n",
    "        fake_loss = adversarial_loss(fake_logits, fake_targets)\n",
    "        \n",
    "        d_loss = (real_loss + fake_loss) / 2\n",
    "        d_loss.backward()\n",
    "        optimizer_D.step()\n",
    "        \n",
    "        # ---------------------\n",
    "        # Train Generator\n",
    "        # ---------------------\n",
    "        optimizer_G.zero_grad()\n",
    "        \n",
    "        z = torch.randn(batch_size, LATENT_DIM, device=DEVICE)\n",
    "        sampled_labels = torch.randint(0, N_CLASSES, (batch_size,), device=DEVICE)\n",
    "        \n",
    "        gen_imgs = G(z, sampled_labels)\n",
    "        gen_logits = D(gen_imgs, sampled_labels)\n",
    "        \n",
    "        g_loss = adversarial_loss(gen_logits, real_targets)\n",
    "        g_loss.backward()\n",
    "        optimizer_G.step()\n",
    "        \n",
    "        epoch_g_loss += g_loss.item()\n",
    "        epoch_d_loss += d_loss.item()\n",
    "        total_batches += 1\n",
    "    \n",
    "    avg_g_loss = epoch_g_loss / total_batches\n",
    "    avg_d_loss = epoch_d_loss / total_batches\n",
    "    \n",
    "    G_losses.append(avg_g_loss)\n",
    "    D_losses.append(avg_d_loss)\n",
    "    \n",
    "    print(\n",
    "        f\"Epoch {epoch:03d}/{GAN_EPOCHS} | \"\n",
    "        f\"D Loss: {avg_d_loss:.4f} | \"\n",
    "        f\"G Loss: {avg_g_loss:.4f}\"\n",
    "    )\n",
    "    \n",
    "    if epoch == 1 or epoch % 10 == 0 or epoch == GAN_EPOCHS:\n",
    "        show_generated_digits(epoch)\n",
    "\n",
    "\n",
    "torch.save(G.state_dict(), \"/kaggle/working/better_conditional_dcgan_generator.pth\")\n",
    "torch.save(D.state_dict(), \"/kaggle/working/better_conditional_dcgan_discriminator.pth\")\n",
    "\n",
    "plt.figure(figsize=(7, 4))\n",
    "plt.plot(G_losses, label=\"Generator Loss\")\n",
    "plt.plot(D_losses, label=\"Discriminator Loss\")\n",
    "plt.xlabel(\"Epoch\")\n",
    "plt.ylabel(\"Loss\")\n",
    "plt.title(\"Better Conditional DCGAN Training Loss\")\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/better_conditional_dcgan_loss.png\", dpi=300)\n",
    "plt.show()\n",
