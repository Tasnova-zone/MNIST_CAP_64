_f1 = f1_score(all_true, all_pred, average=\"macro\")\n\nprint(\"Full test EEG classification:\")\nprint(\"Accuracy          :\", round(full_eeg_acc, 4))\nprint(\"Balanced Accuracy :\", round(full_eeg_bal, 4))\nprint(\"Macro F1          :\", round(full_eeg_f1, 4))\n\n\n# ------------------------------------------------------------\n# 2) Build one clean oracle-selected generated image per digit\n# ------------------------------------------------------------\nSAMPLES_PER_DIGIT = 128\n\nbest_digit_images = []\nbest_digit_conf = []\n\nwith torch.no_grad():\n    for d in range(N_CLASSES):\n        labels = torch.full((SAMPLES_PER_DIGIT,), d, dtype=torch.long, device=DEVICE)\n        z = torch.randn(SAMPLES_PER_DIGIT, Z_DIM, device=DEVICE)\n\n        imgs = gen(z, labels)\n        imgs = ((imgs + 1.0) / 2.0).clamp(0, 1)\n\n        probs = torch.softmax(oracle(imgs), dim=1)\n        target_conf = probs[:, d]\n\n        best_idx = target_conf.argmax()\n\n        best_digit_images.append(imgs[best_idx].detach().cpu())\n        best_digit_conf.append(float(target_conf[best_idx].item()))\n\nbest_digit_images = torch.stack(best_digit_images)\n\nplt.figure(figsize=(10, 2.4))\nfor d in range(N_CLASSES):\n    plt.subplot(1, N_CLASSES, d + 1)\n    plt.imshow(best_digit_images[d, 0], cmap=\"gray\")\n    plt.title(f\"{d}\\nC={best_digit_conf[d]:.2f}\")\n    plt.axis(\"off\")\n\nplt.suptitle(\"Final Oracle-selected Generated Digit Template per Class\")\nplt.tight_layout()\nplt.savefig(\"/kaggle/working/final_oracle_selected_generated_digits.png\", dpi=300)\nplt.show()\n\n\n# ------------------------------------------------------------\n# 3) End-to-end EEG-to-image consistency\n# ------------------------------------------------------------\npred_tensor = torch.tensor(all_pred, dtype=torch.long)\ngenerated_from_pred = best_digit_images[pred_tensor].to(DEVICE)\n\nwith torch.no_grad():\n    oracle_logits = oracle(generated_from_pred)\n    oracle_probs = torch.softmax(oracle_logits, dim=1)\n\n    gen_oracle_pred = oracle_probs.argmax(dim=1).cpu().numpy()\n    gen_oracle_conf = oracle_probs.max(dim=1).values.cpu().numpy()\n\ngeneration_follows_pred_acc = accuracy_score(all_pred, gen_oracle_pred)\nend_to_end_true_acc = accuracy_score(all_true, gen_oracle_pred)\n\nsummary_df = pd.DataFrame([{\n    \"EEG Test Accuracy\": full_eeg_acc,\n    \"EEG Balanced Accuracy\": full_eeg_bal,\n    \"EEG Macro F1\": full_eeg_f1,\n    \"Generation Follows EEG-Predicted Label Accuracy\": generation_follows_pred_acc,\n    \"End-to-End EEG-to-Image True Label Accuracy\": end_to_end_true_acc,\n    \"Mean EEG Prediction Confidence\": float(np.mean(all_conf)),\n    \"Mean Generated Image Oracle Confidence\": float(np.mean(gen_oracle_conf))\n}])\n\nprint(\"\\n========== Final EEG-to-Image Evaluation Summary ==========\")\ndisplay(summary_df)\n\nsummary_df.to_csv(\"/kaggle/working/final_eeg_to_image_evaluation_summary.csv\", index=False)\n\n\n# ------------------------------------------------------------\n# 4) Demo gallery from full test set\n# ------------------------------------------------------------\ndemo_n = 20\ndemo_idx = np.linspace(0, len(all_true) - 1, demo_n, dtype=int)\n\nplt.figure(figsize=(16, 4))\n\nfor col, idx in enumerate(demo_idx):\n    true_label = int(all_true[idx])\n    pred_label = int(all_pred[idx])\n\n    plt.subplot(2, demo_n, col + 1)\n    plt.text(\n        0.5, 0.5,\n        f\"EEG\\nT={true_label}\\nP={pred_label}\",\n        ha=\"center\",\n        va=\"center\",\n        fontsize=9\n    )\n    plt.axis(\"off\")\n\n    plt.subplot(2, demo_n, col + 1 + demo_n)\n    plt.imshow(best_digit_images[pred_label, 0], cmap=\"gray\")\n    plt.title(f\"Gen {pred_label}\", fontsize=8)\n    plt.axis(\"off\")\n\nplt.suptitle(\"Full Test Examples: EEG True Label, EEG Prediction, and Generated Digit\")\nplt.tight_layout()\nplt.savefig(\"/kaggle/working/full_test_eeg_to_image_demo_gallery.png\", dpi=300)\nplt.show()\n\n\nprint(\"Saved:\")\nprint(\"/kaggle/working/