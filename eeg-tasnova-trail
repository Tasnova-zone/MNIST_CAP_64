    "# ============================================================\n",
    "# Cell 17 — EEG true-label and EEG-predicted-label generation demo\n",
    "# ============================================================\n",
    "\n",
    "torch.cuda.empty_cache()\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Find trained EEG classifier automatically\n",
    "# ------------------------------------------------------------\n",
    "eeg_model = None\n",
    "eeg_model_name = None\n",
    "\n",
    "for name in [\"best_eeg_model\", \"tuned_model\", \"final_eeg_model\", \"eeg_model\", \"model\"]:\n",
    "    if name in globals() and isinstance(globals()[name], nn.Module):\n",
    "        candidate = globals()[name].to(DEVICE)\n",
    "        candidate.eval()\n",
    "\n",
    "        try:\n",
    "            xb_test = torch.tensor(Xte_t[:2], dtype=torch.float32).to(DEVICE)\n",
    "            with torch.no_grad():\n",
    "                out = candidate(xb_test)\n",
    "\n",
    "            if out.ndim == 2 and out.shape[1] == N_CLASSES:\n",
    "                eeg_model = candidate\n",
    "                eeg_model_name = name\n",
    "                break\n",
    "\n",
    "        except:\n",
    "            pass\n",
    "\n",
    "if eeg_model is None:\n",
    "    raise RuntimeError(\"No trained EEG classifier found. Please check the EEGNet model variable name.\")\n",
    "\n",
    "print(\"Using EEG classifier:\", eeg_model_name)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Select one test EEG sample from each true digit class\n",
    "# ------------------------------------------------------------\n",
    "demo_indices = []\n",
    "\n",
    "for d in range(N_CLASSES):\n",
    "    idx = np.where(yte_t == d)[0]\n",
    "    demo_indices.append(idx[0])\n",
    "\n",
    "X_demo = torch.tensor(Xte_t[demo_indices], dtype=torch.float32).to(DEVICE)\n",
    "y_true_demo = torch.tensor(yte_t[demo_indices], dtype=torch.long).to(DEVICE)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# EEG classification\n",
    "# ------------------------------------------------------------\n",
    "eeg_model.eval()\n",
    "\n",
    "with torch.no_grad():\n",
    "    eeg_logits = eeg_model(X_demo)\n",
    "    eeg_probs = torch.softmax(eeg_logits, dim=1)\n",
    "    y_pred_demo = eeg_probs.argmax(dim=1)\n",
    "    eeg_conf_demo = eeg_probs.max(dim=1).values\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Generate best image for each label using oracle confidence\n",
    "# ------------------------------------------------------------\n",
    "def generate_best_images(label_tensor, candidates_per_label=32):\n",
    "    gen.eval()\n",
    "    oracle.eval()\n",
    "\n",
    "    n = label_tensor.size(0)\n",
    "\n",
    "    repeated_labels = label_tensor.repeat_interleave(candidates_per_label)\n",
    "    z = torch.randn(n * candidates_per_label, Z_DIM, device=DEVICE)\n",
    "\n",
    "    with torch.no_grad():\n",
    "        imgs = gen(z, repeated_labels)\n",
    "        imgs = ((imgs + 1.0) / 2.0).clamp(0, 1)\n",
    "\n",
    "        oracle_logits = oracle(imgs)\n",
    "        oracle_probs = torch.softmax(oracle_logits, dim=1)\n",
    "\n",
    "        target_conf = oracle_probs.gather(\n",
    "            1,\n",
    "            repeated_labels.view(-1, 1)\n",
    "        ).squeeze(1)\n",
    "\n",
    "    imgs = imgs.view(n, candidates_per_label, 1, 28, 28)\n",
    "    target_conf = target_conf.view(n, candidates_per_label)\n",
    "\n",
    "    best_idx = target_conf.argmax(dim=1)\n",
    "\n",
    "    best_imgs = []\n",
    "    best_confs = []\n",
    "\n",
    "    for i in range(n):\n",
    "        best_imgs.append(imgs[i, best_idx[i]])\n",
    "        best_confs.append(target_conf[i, best_idx[i]])\n",
    "\n",
    "    best_imgs = torch.stack(best_imgs)\n",
    "    best_confs = torch.stack(best_confs)\n",
    "\n",
    "    return best_imgs, best_confs\n",
    "\n",
    "\n",
    "true_label_imgs, true_label_gen_conf = generate_best_images(y_true_demo)\n",
    "pred_label_imgs, pred_label_gen_conf = generate_best_images(y_pred_demo)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Oracle check on generated images\n",
    "# ------------------------------------------------------------\n",
    "with torch.no_grad():\n",
    "    true_gen_probs = torch.softmax(oracle(true_label_imgs), dim=1)\n",
    "    pred_gen_probs = torch.softmax(oracle(pred_label_imgs), dim=1)\n",
    "\n",
    "    true_gen_oracle_pred = true_gen_probs.argmax(dim=1)\n",
    "    pred_gen_oracle_pred = pred_gen_probs.argmax(dim=1)\n",
    "\n",
    "    true_gen_oracle_conf = true_gen_probs.max(dim=1).values\n",
    "    pred_gen_oracle_conf = pred_gen_probs.max(dim=1).values\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Result table\n",
    "# ------------------------------------------------------------\n",
    "demo_df = pd.DataFrame({\n",
    "    \"Sample\": np.arange(N_CLASSES),\n",
    "    \"True EEG Label\": y_true_demo.detach().cpu().numpy(),\n",
    "    \"EEG Predicted Label\": y_pred_demo.detach().cpu().numpy(),\n",
    "    \"EEG Confidence\": eeg_conf_demo.detach().cpu().numpy(),\n",
    "    \"Oracle Pred on True-Label Generated Image\": true_gen_oracle_pred.detach().cpu().numpy(),\n",
    "    \"Oracle Conf True-Label Image\": true_gen_oracle_conf.detach().cpu().numpy(),\n",
    "    \"Oracle Pred on EEG-Predicted Generated Image\": pred_gen_oracle_pred.detach().cpu().numpy(),\n",
    "    \"Oracle Conf EEG-Predicted Image\": pred_gen_oracle_conf.detach().cpu().numpy()\n",
    "})\n",
    "\n",
    "print(\"\\n========== EEG-to-Image Demonstration Table ==========\")\n",
    "display(demo_df)\n",
    "\n",
    "demo_df.to_csv(\"/kaggle/working/eeg_to_image_demo_table.csv\", index=False)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Visualization: true-label generation vs EEG-predicted generation\n",
    "# ------------------------------------------------------------\n",
    "plt.figure(figsize=(14, 4))\n",
    "\n",
    "for i in range(N_CLASSES):\n",
    "    plt.subplot(2, N_CLASSES, i + 1)\n",
    "    plt.imshow(true_label_imgs[i, 0].detach().cpu(), cmap=\"gray\")\n",
    "    plt.title(f\"T={int(y_true_demo[i])}\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "    plt.subplot(2, N_CLASSES, i + 1 + N_CLASSES)\n",
