    "# ============================================================\n",
    "# Cell 4 — EEGNet model and reusable training utilities\n",
    "# ============================================================\n",
    "\n",
    "BATCH_SIZE = 256\n",
    "EEGNET_EPOCHS = 50\n",
    "LR = 1e-3\n",
    "\n",
    "def make_loaders(X_train, y_train, X_test, y_test, batch_size=BATCH_SIZE):\n",
    "    train_ds = TensorDataset(\n",
    "        torch.tensor(X_train, dtype=torch.float32),\n",
    "        torch.tensor(y_train, dtype=torch.long)\n",
    "    )\n",
    "    test_ds = TensorDataset(\n",
    "        torch.tensor(X_test, dtype=torch.float32),\n",
    "        torch.tensor(y_test, dtype=torch.long)\n",
    "    )\n",
    "\n",
    "    train_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True, num_workers=2, pin_memory=True)\n",
    "    test_loader = DataLoader(test_ds, batch_size=batch_size, shuffle=False, num_workers=2, pin_memory=True)\n",
    "\n",
    "    return train_loader, test_loader\n",
    "\n",
    "\n",
    "class EEGNetClassifier(nn.Module):\n",
    "    def __init__(self, n_channels=14, n_times=256, n_classes=10):\n",
    "        super().__init__()\n",
    "\n",
    "        self.temporal = nn.Sequential(\n",
    "            nn.Conv2d(1, 16, kernel_size=(1, 31), padding=(0, 15), bias=False),\n",
    "            nn.BatchNorm2d(16)\n",
    "        )\n",
    "\n",
    "        self.spatial = nn.Sequential(\n",
    "            nn.Conv2d(16, 32, kernel_size=(n_channels, 1), groups=16, bias=False),\n",
    "            nn.BatchNorm2d(32),\n",
    "            nn.ELU(),\n",
    "            nn.AvgPool2d(kernel_size=(1, 4)),\n",
    "            nn.Dropout(0.25)\n",
    "        )\n",
    "\n",
    "        self.separable = nn.Sequential(\n",
    "            nn.Conv2d(32, 32, kernel_size=(1, 15), padding=(0, 7), groups=32, bias=False),\n",
    "            nn.Conv2d(32, 64, kernel_size=(1, 1), bias=False),\n",
    "            nn.BatchNorm2d(64),\n",
    "            nn.ELU(),\n",
    "            nn.AvgPool2d(kernel_size=(1, 8)),\n",
    "            nn.Dropout(0.25)\n",
    "        )\n",
    "\n",
    "        with torch.no_grad():\n",
    "            dummy = torch.zeros(1, 1, n_channels, n_times)\n",
    "            feat = self.separable(self.spatial(self.temporal(dummy)))\n",
    "            self.feature_dim = feat.flatten(1).shape[1]\n",
    "\n",
    "        self.classifier = nn.Linear(self.feature_dim, n_classes)\n",
    "\n",
    "    def forward(self, x, return_features=False):\n",
    "        x = x.unsqueeze(1)\n",
    "        x = self.temporal(x)\n",
    "        x = self.spatial(x)\n",
    "        x = self.separable(x)\n",
    "\n",
    "        features = x.flatten(1)\n",
    "        logits = self.classifier(features)\n",
    "\n",
    "        if return_features:\n",
    "            return logits, features\n",
    "\n",
    "        return logits\n",
    "\n",
    "\n",
    "def evaluate_classifier(model, loader):\n",
    "    model.eval()\n",
    "    all_preds = []\n",
    "    all_true = []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for xb, yb in loader:\n",
    "            xb = xb.to(DEVICE, non_blocking=True)\n",
    "            logits = model(xb)\n",
    "            preds = logits.argmax(dim=1).cpu().numpy()\n",
    "\n",
    "            all_preds.extend(preds)\n",
    "            all_true.extend(yb.numpy())\n",
    "\n",
    "    acc = accuracy_score(all_true, all_preds)\n",
    "    bal_acc = balanced_accuracy_score(all_true, all_preds)\n",
    "    macro_f1 = f1_score(all_true, all_preds, average=\"macro\")\n",
    "\n",
    "    return acc, bal_acc, macro_f1\n",
    "\n",
    "\n",
    "def train_eegnet(X_train, y_train, X_test, y_test, epochs=EEGNET_EPOCHS):\n",
    "    train_loader, test_loader = make_loaders(X_train, y_train, X_test, y_test)\n",
    "\n",
