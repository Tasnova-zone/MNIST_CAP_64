    "import os\n",
    "import glob\n",
    "import random\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from collections import Counter\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "\n",
    "# =========================\n",
    "# Reproducibility\n",
    "# =========================\n",
    "SEED = 42\n",
    "random.seed(SEED)\n",
    "np.random.seed(SEED)\n",
    "torch.manual_seed(SEED)\n",
    "torch.cuda.manual_seed_all(SEED)\n",
    "\n",
    "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "print(\"Using device:\", DEVICE)\n",
    "\n",
    "# =========================\n",
    "# Paths\n",
    "# =========================\n",
    "DATA_DIR = \"/kaggle/working/processed_mnist_cap64_baseline_corrected\"\n",
    "\n",
    "# =========================\n",
    "# Dataset class\n",
    "# =========================\n",
    "class EEGDigitDataset(Dataset):\n",
    "    def __init__(self, root_dir, split):\n",
    "        self.files = sorted(glob.glob(os.path.join(root_dir, split, \"*\", \"*.npz\")))\n",
    "        self.split = split\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.files)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        data = np.load(self.files[idx])\n",
    "\n",
    "        eeg = data[\"eeg\"].astype(np.float32)          # shape: 64, 400\n",
    "        label = int(data[\"label\"])\n",
    "\n",
    "        eeg = torch.tensor(eeg, dtype=torch.float32)\n",
    "        label = torch.tensor(label, dtype=torch.long)\n",
    "\n",
    "        return eeg, label\n",
    "\n",
    "train_dataset = EEGDigitDataset(DATA_DIR, \"train\")\n",
    "val_dataset   = EEGDigitDataset(DATA_DIR, \"val\")\n",
    "test_dataset  = EEGDigitDataset(DATA_DIR, \"test\")\n",
    "\n",
    "print(\"Train samples:\", len(train_dataset))\n",
    "print(\"Val samples:\", len(val_dataset))\n",
    "print(\"Test samples:\", len(test_dataset))\n",
    "\n",
    "# Label check\n",
    "train_labels = []\n",
    "for _, label in train_dataset:\n",
    "    train_labels.append(int(label))\n",
    "\n",
    "print(\"Train label counts:\", Counter(train_labels))\n",
    "\n",
    "# =========================\n",
    "# DataLoaders\n",
    "# =========================\n",
    "BATCH_SIZE = 32\n",
    "\n",
    "train_loader = DataLoader(\n",
    "    train_dataset,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    shuffle=True,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "val_loader = DataLoader(\n",
    "    val_dataset,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    shuffle=False,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "test_loader = DataLoader(\n",
    "    test_dataset,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    shuffle=False,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# EEGNet-style classifier\n",
    "# Input: B, 64, 400\n",
    "# =========================\n",
    "class EEGNetClassifier(nn.Module):\n",
    "    def __init__(self, num_classes=10):\n",
    "        super().__init__()\n",
    "\n",
    "        self.net = nn.Sequential(\n",
    "            # B, 1, 64, 400\n",
    "            nn.Conv2d(1, 16, kernel_size=(1, 25), padding=(0, 12), bias=False),\n",
    "            nn.BatchNorm2d(16),\n",
    "\n",
    "            # spatial filtering across 64 EEG channels\n",
    "            nn.Conv2d(16, 32, kernel_size=(64, 1), groups=16, bias=False),\n",
    "            nn.BatchNorm2d(32),\n",
    "            nn.ELU(),\n",
    "            nn.AvgPool2d(kernel_size=(1, 4)),\n",
    "            nn.Dropout(0.50),\n",
    "\n",
    "            # temporal feature extraction\n",
    "            nn.Conv2d(32, 64, kernel_size=(1, 15), padding=(0, 7), bias=False),\n",
    "            nn.BatchNorm2d(64),\n",
    "            nn.ELU(),\n",
    "            nn.AvgPool2d(kernel_size=(1, 5)),\n",
    "            nn.Dropout(0.50)\n",
    "        )\n",
    "\n",
    "        self.classifier = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(64 * 1 * 20, 128),\n",
    "            nn.ELU(),\n",
    "            nn.Dropout(0.50),\n",
    "            nn.Linear(128, num_classes)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = x.unsqueeze(1)   # B, 1, 64, 400\n",
    "        x = self.net(x)\n",
    "        x = self.classifier(x)\n",
    "        return x\n",
    "\n",
    "model = EEGNetClassifier(num_classes=10).to(DEVICE)\n",
    "\n",
    "# Test forward pass\n",
    "sample_eeg, sample_label = next(iter(train_loader))\n",
    "sample_eeg = sample_eeg.to(DEVICE)\n",
    "\n",
    "with torch.no_grad():\n",
    "    sample_out = model(sample_eeg)\n",
    "\n",
    "print(\"Input EEG batch:\", sample_eeg.shape)\n",
    "print(\"Output logits:\", sample_out.shape)\n",
    "\n",
    "# =========================\n",
    "# Training setup\n",
    "# =========================\n",
    "criterion = nn.CrossEntropyLoss(label_smoothing=0.05)\n",
    "\n",
    "optimizer = torch.optim.AdamW(\n",
    "    model.parameters(),\n",
    "    lr=1e-3,\n",
    "    weight_decay=1e-3\n",
    ")\n",
    "\n",
    "scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
    "    optimizer,\n",
    "    mode=\"max\",\n",
    "    factor=0.5,\n",
    "    patience=5\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# Train / evaluate functions\n",
    "# =========================\n",
    "def train_one_epoch(model, loader):\n",
    "    model.train()\n",
    "\n",
    "    total_loss = 0\n",
    "    correct = 0\n",
    "    total = 0\n",
    "\n",
    "    for eeg, labels in loader:\n",
    "        eeg = eeg.to(DEVICE)\n",
    "        labels = labels.to(DEVICE)\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "\n",
    "        outputs = model(eeg)\n",
    "        loss = criterion(outputs, labels)\n",
    "\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "\n",
    "        total_loss += loss.item() * eeg.size(0)\n",
    "\n",
    "        preds = outputs.argmax(dim=1)\n",
    "        correct += (preds == labels).sum().item()\n",
    "        total += labels.size(0)\n",
    "\n",
    "    avg_loss = total_loss / total\n",
    "    acc = correct / total * 100\n",
    "\n",
    "    return avg_loss, acc\n",
    "\n",
    "\n",
    "def evaluate(model, loader):\n",
    "    model.eval()\n",
    "\n",
    "    total_loss = 0\n",
    "    correct = 0\n",
    "    total = 0\n",
    "\n",
    "    all_preds = []\n",
    "    all_labels = []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for eeg, labels in loader:\n",
    "            eeg = eeg.to(DEVICE)\n",
    "            labels = labels.to(DEVICE)\n",
    "\n",
    "            outputs = model(eeg)\n",
    "            loss = criterion(outputs, labels)\n",
    "\n",
    "            total_loss += loss.item() * eeg.size(0)\n",
    "\n",
    "            preds = outputs.argmax(dim=1)\n",
    "            correct += (preds == labels).sum().item()\n",
    "            total += labels.size(0)\n",
    "\n",
    "            all_preds.extend(preds.cpu().numpy())\n",
    "            all_labels.extend(labels.cpu().numpy())\n",
    "\n",
    "    avg_loss = total_loss / total\n",
    "    acc = correct / total * 100\n",
    "\n",
    "    return avg_loss, acc, all_labels, all_preds\n",
    "\n",
    "# =========================\n",
    "# Training loop with early stopping\n",
    "# =========================\n",
    "EPOCHS = 60\n",
    "PATIENCE = 12\n",
    "\n",
    "best_val_acc = 0\n",
    "best_model_path = \"/kaggle/working/best_baseline_corrected_eeg_classifier.pth\"\n",
    "patience_counter = 0\n",
    "\n",
    "history = {\n",
    "    \"train_loss\": [],\n",
    "    \"val_loss\": [],\n",
    "    \"train_acc\": [],\n",
    "    \"val_acc\": []\n",
    "}\n",
    "\n",
    "for epoch in range(EPOCHS):\n",
    "    train_loss, train_acc = train_one_epoch(model, train_loader)\n",
    "    val_loss, val_acc, _, _ = evaluate(model, val_loader)\n",
    "\n",
    "    scheduler.step(val_acc)\n",
    "\n",
    "    history[\"train_loss\"].append(train_loss)\n",
    "    history[\"val_loss\"].append(val_loss)\n",
    "    history[\"train_acc\"].append(train_acc)\n",
    "    history[\"val_acc\"].append(val_acc)\n",
    "\n",
    "    print(\n",
    "        f\"Epoch [{epoch+1:02d}/{EPOCHS}] \"\n",
