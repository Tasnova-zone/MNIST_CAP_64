    "import os\n",
    "import csv\n",
    "import json\n",
    "import shutil\n",
    "import numpy as np\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "DATA_PATH = \"/kaggle/input/datasets/tasnovaislam2008002/mnist-cap-64/MindBigData64_Mnist2022-EEGv0.016.txt\"\n",
    "\n",
    "OUT_DIR = \"/kaggle/working/processed_mnist_cap64\"\n",
    "\n",
    "# পুরোনো processed folder থাকলে delete করে fresh বানাবে\n",
    "if os.path.exists(OUT_DIR):\n",
    "    shutil.rmtree(OUT_DIR)\n",
    "\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "for split in [\"train\", \"val\", \"test\"]:\n",
    "    for label in range(10):\n",
    "        os.makedirs(os.path.join(OUT_DIR, split, str(label)), exist_ok=True)\n",
    "\n",
    "samples = []\n",
    "\n",
    "with open(DATA_PATH, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
    "    for line_id, line in enumerate(f):\n",
    "        parts = line.strip().split(\",\")\n",
    "\n",
    "        if len(parts) != 26388:\n",
    "            continue\n",
    "\n",
    "        source_split = parts[0]          # TRAIN\n",
    "        original_index = int(parts[1])   # original MNIST index\n",
    "        label = int(parts[2])            # digit label or -1\n",
    "\n",
    "        # black screen বাদ\n",
    "        if label == -1:\n",
    "            continue\n",
    "\n",
    "        # image: 784 values\n",
    "        image = np.array(parts[3:3+784], dtype=np.float32).reshape(28, 28)\n",
    "\n",
    "        # timestamp\n",
    "        timestamp = float(parts[3+784])\n",
    "\n",
    "        # EEG: 25600 values = 64 channels × 400 timepoints\n",
    "        eeg_start = 3 + 784 + 1\n",
    "        eeg = np.array(parts[eeg_start:], dtype=np.float32).reshape(64, 400)\n",
    "\n",
    "        samples.append({\n",
    "            \"line_id\": line_id,\n",
    "            \"source_split\": source_split,\n",
    "            \"original_index\": original_index,\n",
    "            \"label\": label,\n",
    "            \"timestamp\": timestamp,\n",
    "            \"image\": image,\n",
    "            \"eeg\": eeg\n",
    "        })\n",
    "\n",
    "print(\"Total digit samples loaded:\", len(samples))\n",
    "\n",
    "labels = np.array([s[\"label\"] for s in samples])\n",
    "\n",
    "# 70% train, 15% val, 15% test\n",
    "idx_all = np.arange(len(samples))\n",
    "\n",
    "train_idx, temp_idx = train_test_split(\n",
    "    idx_all,\n",
    "    test_size=0.30,\n",
    "    random_state=42,\n",
    "    stratify=labels\n",
    ")\n",
    "\n",
    "temp_labels = labels[temp_idx]\n",
    "\n",
    "val_idx, test_idx = train_test_split(\n",
    "    temp_idx,\n",
    "    test_size=0.50,\n",
    "    random_state=42,\n",
    "    stratify=temp_labels\n",
    ")\n",
    "\n",
    "split_map = {}\n",
    "\n",
    "for i in train_idx:\n",
    "    split_map[i] = \"train\"\n",
    "\n",
    "for i in val_idx:\n",
    "    split_map[i] = \"val\"\n",
    "\n",
    "for i in test_idx:\n",
    "    split_map[i] = \"test\"\n",
    "\n",
    "metadata_rows = []\n",
    "\n",
    "for i, sample in enumerate(samples):\n",
    "    split = split_map[i]\n",
    "    label = sample[\"label\"]\n",
    "\n",
    "    filename = f\"sample_{i:05d}_label_{label}.npz\"\n",
    "    save_path = os.path.join(OUT_DIR, split, str(label), filename)\n",
    "\n",
    "    np.savez_compressed(\n",
    "        save_path,\n",
    "        eeg=sample[\"eeg\"],\n",
    "        image=sample[\"image\"],\n",
    "        label=label,\n",
    "        original_index=sample[\"original_index\"],\n",
    "        timestamp=sample[\"timestamp\"],\n",
    "        line_id=sample[\"line_id\"]\n",
    "    )\n",
    "\n",
    "    metadata_rows.append({\n",
    "        \"sample_id\": i,\n",
    "        \"split\": split,\n",
    "        \"label\": label,\n",
    "        \"file_path\": save_path,\n",
    "        \"original_index\": sample[\"original_index\"],\n",
    "        \"timestamp\": sample[\"timestamp\"],\n",
    "        \"line_id\": sample[\"line_id\"]\n",
    "    })\n",
    "\n",
    "metadata_path = os.path.join(OUT_DIR, \"metadata.csv\")\n",
    "\n",
    "with open(metadata_path, \"w\", newline=\"\") as f:\n",
    "    writer = csv.DictWriter(f, fieldnames=metadata_rows[0].keys())\n",
    "    writer.writeheader()\n",
    "    writer.writerows(metadata_rows)\n",
    "\n",
    "summary = {\n",
    "    \"total_digit_samples\": len(samples),\n",
    "    \"train\": len(train_idx),\n",
    "    \"val\": len(val_idx),\n",
    "    \"test\": len(test_idx),\n",
    "    \"eeg_shape\": [64, 400],\n",
    "    \"image_shape\": [28, 28],\n",
    "    \"black_screen_samples_excluded\": 1166\n",
    "}\n",
    "\n",
    "with open(os.path.join(OUT_DIR, \"summary.json\"), \"w\") as f:\n",
    "    json.dump(summary, f, indent=4)\n",
    "\n",
    "print(\"Processed dataset saved at:\", OUT_DIR)\n",
    "print(\"Train samples:\", len(train_idx))\n",
    "print(\"Val samples:\", len(val_idx))\n",
    "print(\"Test samples:\", len(test_idx))\n",
    "print(\"Metadata saved:\", metadata_path)"
   ]
  },
