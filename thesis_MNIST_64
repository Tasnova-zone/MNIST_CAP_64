    "import torch\n",
    "import torch.nn as nn\n",
    "\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(\"Using device:\", device)\n",
    "\n",
    "class EEG2ImageBaseline(nn.Module):\n",
    "    def __init__(self, latent_dim=256):\n",
    "        super().__init__()\n",
    "        \n",
    "        # EEG Encoder: input = (batch, 64, 400)\n",
    "        self.encoder = nn.Sequential(\n",
    "            nn.Conv1d(64, 128, kernel_size=7, padding=3),\n",
    "            nn.BatchNorm1d(128),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool1d(2),   # 400 -> 200\n",
    "            \n",
    "            nn.Conv1d(128, 256, kernel_size=5, padding=2),\n",
    "            nn.BatchNorm1d(256),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool1d(2),   # 200 -> 100\n",
    "            \n",
    "            nn.Conv1d(256, 256, kernel_size=3, padding=1),\n",
    "            nn.BatchNorm1d(256),\n",
    "            nn.ReLU(),\n",
    "            \n",
    "            nn.AdaptiveAvgPool1d(16)  # output: (batch, 256, 16)\n",
    "        )\n",
    "        \n",
    "        self.fc_encoder = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(256 * 16, latent_dim),\n",
    "            nn.ReLU()\n",
    "        )\n",
    "        \n",
    "        # Image Decoder: latent vector -> 28x28 image\n",
    "        self.fc_decoder = nn.Sequential(\n",
    "            nn.Linear(latent_dim, 128 * 7 * 7),\n",
    "            nn.ReLU()\n",
    "        )\n",
    "        \n",
    "        self.decoder = nn.Sequential(\n",
    "            nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1),  # 7 -> 14\n",
    "            nn.BatchNorm2d(64),\n",
    "            nn.ReLU(),\n",
    "            \n",
    "            nn.ConvTranspose2d(64, 32, kernel_size=4, stride=2, padding=1),   # 14 -> 28\n",
    "            nn.BatchNorm2d(32),\n",
    "            nn.ReLU(),\n",
    "            \n",
    "            nn.Conv2d(32, 1, kernel_size=3, padding=1),\n",
    "            nn.Sigmoid()  # image range 0 to 1\n",
    "        )\n",
    "        \n",
    "    def forward(self, eeg):\n",
    "        x = self.encoder(eeg)\n",
    "        z = self.fc_encoder(x)\n",
    "        x = self.fc_decoder(z)\n",
    "        x = x.view(-1, 128, 7, 7)\n",
    "        img = self.decoder(x)\n",
    "        return img\n",
    "\n",
    "model = EEG2ImageBaseline(latent_dim=256).to(device)\n",
    "\n",
    "# Test one forward pass\n",
    "batch = next(iter(train_loader))\n",
    "eeg = batch[\"eeg\"].to(device)\n",
    "target_img = batch[\"image\"].to(device)\n",
    "\n",
    "with torch.no_grad():\n",
    "    pred_img = model(eeg)\n",
    "\n",
    "print(\"Input EEG shape:\", eeg.shape)\n",
    "print(\"Target image shape:\", target_img.shape)\n",
    "print(\"Predicted image shape:\", pred_img.shape)\n",
    "print(\"Predicted image min/max:\", pred_img.min().item(), pred_img.max().item())\n",
    "\n",
    "total_params = sum(p.numel() for p in model.parameters())\n",
    "trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "\n",
    "print(\"Total parameters:\", total_params)\n",
    "print(\"Trainable parameters:\", trainable_params)"
