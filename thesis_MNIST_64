    "import torch\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Try importing SSIM\n",
    "try:\n",
    "    from skimage.metrics import structural_similarity as ssim\n",
    "    SSIM_AVAILABLE = True\n",
    "except:\n",
    "    SSIM_AVAILABLE = False\n",
    "    print(\"skimage not available, SSIM will be skipped.\")\n",
    "\n",
    "# =========================\n",
    "# Load best model\n",
    "# =========================\n",
    "best_model_path = \"/kaggle/working/best_eeg2image_baseline.pth\"\n",
    "\n",
    "model.load_state_dict(torch.load(best_model_path, map_location=device))\n",
    "model.to(device)\n",
    "model.eval()\n",
    "\n",
    "print(\"Loaded best model from:\", best_model_path)\n",
    "\n",
    "# =========================\n",
    "# Evaluation function\n",
    "# =========================\n",
    "all_mse = []\n",
    "all_mae = []\n",
    "all_psnr = []\n",
    "all_ssim = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for batch in test_loader:\n",
    "        eeg = batch[\"eeg\"].to(device)\n",
    "        target = batch[\"image\"].to(device)\n",
    "        \n",
    "        pred = model(eeg)\n",
    "        pred = torch.clamp(pred, 0.0, 1.0)\n",
    "        \n",
    "        # Per-image MSE and MAE\n",
    "        mse_per_img = F.mse_loss(pred, target, reduction=\"none\").mean(dim=[1, 2, 3])\n",
    "        mae_per_img = F.l1_loss(pred, target, reduction=\"none\").mean(dim=[1, 2, 3])\n",
    "        \n",
    "        psnr_per_img = 10 * torch.log10(1.0 / (mse_per_img + 1e-8))\n",
    "        \n",
    "        all_mse.extend(mse_per_img.cpu().numpy())\n",
    "        all_mae.extend(mae_per_img.cpu().numpy())\n",
    "        all_psnr.extend(psnr_per_img.cpu().numpy())\n",
    "        \n",
    "        # SSIM calculation\n",
    "        if SSIM_AVAILABLE:\n",
    "            pred_np = pred.cpu().numpy()\n",
    "            target_np = target.cpu().numpy()\n",
    "            \n",
    "            for i in range(pred_np.shape[0]):\n",
    "                pred_img = pred_np[i, 0]\n",
    "                target_img = target_np[i, 0]\n",
    "                ssim_val = ssim(target_img, pred_img, data_range=1.0)\n",
    "                all_ssim.append(ssim_val)\n",
    "\n",
    "# =========================\n",
    "# Print metrics\n",
    "# =========================\n",
    "print(\"\\n========== Test Evaluation ==========\")\n",
