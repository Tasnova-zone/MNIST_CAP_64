    "import random\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "try:\n",
    "    from skimage.metrics import structural_similarity as ssim\n",
    "    SSIM_AVAILABLE = True\n",
    "except:\n",
    "    SSIM_AVAILABLE = False\n",
    "\n",
    "# =========================\n",
    "# Load best model again\n",
    "# =========================\n",
    "best_model_path = \"/kaggle/working/best_eeg2image_baseline.pth\"\n",
    "model.load_state_dict(torch.load(best_model_path, map_location=device))\n",
    "model.to(device)\n",
    "model.eval()\n",
    "\n",
    "print(\"Best model loaded.\")\n",
    "\n",
    "# =========================\n",
    "# Random visualization from test dataset\n",
    "# =========================\n",
    "num_show = 10\n",
    "random_indices = random.sample(range(len(test_dataset)), min(num_show, len(test_dataset)))\n",
    "\n",
    "real_imgs = []\n",
    "pred_imgs = []\n",
    "labels = []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for idx in random_indices:\n",
    "        sample = test_dataset[idx]\n",
    "        \n",
    "        eeg = sample[\"eeg\"].unsqueeze(0).to(device)\n",
    "        real_img = sample[\"image\"].unsqueeze(0).to(device)\n",
    "        label = sample[\"label\"].item()\n",
    "        \n",
    "        pred_img = model(eeg)\n",
    "        pred_img = torch.clamp(pred_img, 0.0, 1.0)\n",
    "        \n",
    "        real_imgs.append(real_img.cpu()[0, 0])\n",
    "        pred_imgs.append(pred_img.cpu()[0, 0])\n",
    "        labels.append(label)\n",
    "\n",
    "plt.figure(figsize=(16, 4))\n",
    "\n",
    "for i in range(len(labels)):\n",
    "    plt.subplot(2, len(labels), i + 1)\n",
    "    plt.imshow(real_imgs[i], cmap=\"gray\")\n",
    "    plt.title(f\"Real: {labels[i]}\")\n",
    "    plt.axis(\"off\")\n",
    "    \n",
    "    plt.subplot(2, len(labels), i + 1 + len(labels))\n",
    "    plt.imshow(pred_imgs[i], cmap=\"gray\")\n",
    "    plt.title(\"Generated\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "plt.suptitle(\"Random Test Samples: Real vs Generated\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# =========================\n",
    "# Per-class evaluation\n",
    "# =========================\n",
    "class_metrics = {i: {\"mse\": [], \"mae\": [], \"psnr\": [], \"ssim\": []} for i in range(10)}\n",
    "\n",
    "with torch.no_grad():\n",
    "    for batch in test_loader:\n",
    "        eeg = batch[\"eeg\"].to(device)\n",
    "        target = batch[\"image\"].to(device)\n",
    "        label_batch = batch[\"label\"].cpu().numpy()\n",
    "        \n",
    "        pred = model(eeg)\n",
    "        pred = torch.clamp(pred, 0.0, 1.0)\n",
    "        \n",
    "        mse_per_img = F.mse_loss(pred, target, reduction=\"none\").mean(dim=[1, 2, 3])\n",
    "        mae_per_img = F.l1_loss(pred, target, reduction=\"none\").mean(dim=[1, 2, 3])\n",
    "        psnr_per_img = 10 * torch.log10(1.0 / (mse_per_img + 1e-8))\n",
    "        \n",
    "        pred_np = pred.cpu().numpy()\n",
    "        target_np = target.cpu().numpy()\n",
    "        \n",
    "        for i, label in enumerate(label_batch):\n",
    "            label = int(label)\n",
    "            class_metrics[label][\"mse\"].append(float(mse_per_img[i].cpu()))\n",
    "            class_metrics[label][\"mae\"].append(float(mae_per_img[i].cpu()))\n",
    "            class_metrics[label][\"psnr\"].append(float(psnr_per_img[i].cpu()))\n",
    "            \n",
    "            if SSIM_AVAILABLE:\n",
    "                ssim_val = ssim(target_np[i, 0], pred_np[i, 0], data_range=1.0)\n",
    "                class_metrics[label][\"ssim\"].append(float(ssim_val))\n",
    "\n",
    "print(\"\\n========== Per-Class Test Metrics ==========\")\n",
    "\n",
    "for label in range(10):\n",
    "    if len(class_metrics[label][\"mse\"]) == 0:\n",
    "        continue\n",
    "        \n",
    "    print(f\"\\nLabel {label}\")\n",
    "    print(f\"Samples : {len(class_metrics[label]['mse'])}\")\n",
    "    print(f\"MSE     : {np.mean(class_metrics[label]['mse']):.6f}\")\n",
    "    print(f\"MAE     : {np.mean(class_metrics[label]['mae']):.6f}\")\n",
    "    print(f\"PSNR    : {np.mean(class_metrics[label]['psnr']):.4f} dB\")\n",
    "    \n",
    "    if SSIM_AVAILABLE:\n",
    "        print(f\"SSIM    : {np.mean(class_metrics[label]['ssim']):.4f}\")"
   ]
