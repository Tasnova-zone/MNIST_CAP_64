    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch.utils.data import DataLoader\n",
    "from tqdm import tqdm\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "# =========================\n",
    "# Device\n",
    "# =========================\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(\"Using device:\", device)\n",
    "\n",
    "# =========================\n",
    "# Dataloaders\n",
    "# =========================\n",
    "BATCH_SIZE = 32\n",
    "\n",
    "train_loader_cls = DataLoader(\n",
    "    train_dataset,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    shuffle=True,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "val_loader_cls = DataLoader(\n",
    "    val_dataset,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    shuffle=False,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "test_loader_cls = DataLoader(\n",
    "    test_dataset,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    shuffle=False,\n",
    "    num_workers=2,\n",
    "    pin_memory=True\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# EEG Encoder + Classifier\n",
    "# Input: EEG shape = (batch, 64, 400)\n",
    "# Output: 10 digit classes\n",
    "# =========================\n",
    "class EEGClassifier(nn.Module):\n",
    "    def __init__(self, num_channels=64, num_classes=10):\n",
    "        super().__init__()\n",
    "\n",
    "        self.features = nn.Sequential(\n",
    "            nn.Conv1d(num_channels, 128, kernel_size=7, padding=3),\n",
    "            nn.BatchNorm1d(128),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool1d(2),   # 400 -> 200\n",
    "\n",
    "            nn.Conv1d(128, 256, kernel_size=5, padding=2),\n",
    "            nn.BatchNorm1d(256),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool1d(2),   # 200 -> 100\n",
    "\n",
    "            nn.Conv1d(256, 256, kernel_size=3, padding=1),\n",
    "            nn.BatchNorm1d(256),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool1d(2),   # 100 -> 50\n",
    "\n",
    "            nn.Conv1d(256, 512, kernel_size=3, padding=1),\n",
    "            nn.BatchNorm1d(512),\n",
    "            nn.ReLU(),\n",
    "\n",
    "            nn.AdaptiveAvgPool1d(1)\n",
    "        )\n",
    "\n",
    "        self.classifier = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Dropout(0.4),\n",
    "            nn.Linear(512, 256),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(256, num_classes)\n",
    "        )\n",
    "\n",
    "    def forward(self, eeg):\n",
    "        x = self.features(eeg)\n",
    "        logits = self.classifier(x)\n",
    "        return logits\n",
    "\n",
    "\n",
    "cls_model = EEGClassifier().to(device)\n",
    "\n",
    "criterion = nn.CrossEntropyLoss()\n",
    "optimizer = torch.optim.AdamW(cls_model.parameters(), lr=1e-3, weight_decay=1e-4)\n",
    "\n",
    "scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
    "    optimizer,\n",
    "    mode=\"max\",\n",
    "    factor=0.5,\n",
    "    patience=5\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# Train / Eval functions\n",
    "# =========================\n",
    "def run_epoch(model, loader, optimizer=None):\n",
    "    is_train = optimizer is not None\n",
    "\n",
    "    if is_train:\n",
    "        model.train()\n",
    "    else:\n",
    "        model.eval()\n",
    "\n",
    "    total_loss = 0.0\n",
    "    total_correct = 0\n",
    "    total_samples = 0\n",
    "\n",
    "    all_preds = []\n",
    "    all_labels = []\n",
    "\n",
    "    for batch in tqdm(loader, leave=False):\n",
    "        eeg = batch[\"eeg\"].to(device).float()\n",
    "        labels = batch[\"label\"].to(device).long()\n",
    "\n",
    "        if is_train:\n",
    "            optimizer.zero_grad()\n",
    "\n",
    "        with torch.set_grad_enabled(is_train):\n",
    "            logits = model(eeg)\n",
    "            loss = criterion(logits, labels)\n",
    "\n",
    "            if is_train:\n",
    "                loss.backward()\n",
    "                optimizer.step()\n",
    "\n",
    "        preds = torch.argmax(logits, dim=1)\n",
    "\n",
    "        total_loss += loss.item() * eeg.size(0)\n",
    "        total_correct += (preds == labels).sum().item()\n",
    "        total_samples += eeg.size(0)\n",
    "\n",
    "        all_preds.extend(preds.detach().cpu().numpy())\n",
    "        all_labels.extend(labels.detach().cpu().numpy())\n",
    "\n",
    "    avg_loss = total_loss / total_samples\n",
    "    avg_acc = total_correct / total_samples\n",
    "\n",
    "    return avg_loss, avg_acc, np.array(all_preds), np.array(all_labels)\n",
    "\n",
    "\n",
    "# =========================\n",
    "# Training loop\n",
    "# =========================\n",
    "EPOCHS = 50\n",
    "best_val_acc = 0.0\n",
    "best_path = \"/kaggle/working/best_eeg_classifier.pth\"\n",
    "\n",
    "train_losses = []\n",
    "val_losses = []\n",
    "train_accs = []\n",
    "val_accs = []\n",
    "\n",
    "for epoch in range(1, EPOCHS + 1):\n",
    "    train_loss, train_acc, _, _ = run_epoch(cls_model, train_loader_cls, optimizer)\n",
    "    val_loss, val_acc, _, _ = run_epoch(cls_model, val_loader_cls, optimizer=None)\n",
    "\n",
    "    scheduler.step(val_acc)\n",
    "\n",
    "    train_losses.append(train_loss)\n",
    "    val_losses.append(val_loss)\n",
    "    train_accs.append(train_acc)\n",
    "    val_accs.append(val_acc)\n",
    "\n",
    "    if val_acc > best_val_acc:\n",
    "        best_val_acc = val_acc\n",
    "        torch.save(cls_model.state_dict(), best_path)\n",
    "\n",
    "    print(\n",
    "        f\"Epoch [{epoch:02d}/{EPOCHS}] \"\n",
    "        f\"Train Loss: {train_loss:.4f} | Train Acc: {train_acc*100:.2f}% | \"\n",
    "        f\"Val Loss: {val_loss:.4f} | Val Acc: {val_acc*100:.2f}%\"\n",
    "    )\n",
    "\n",
    "print(\"\\nTraining finished.\")\n",
    "print(\"Best validation accuracy:\", best_val_acc * 100)\n",
    "print(\"Best classifier saved at:\", best_path)\n",
    "\n",
    "# =========================\n",
    "# Plot loss and accuracy\n",
    "# =========================\n",
    "plt.figure(figsize=(7, 4))\n",
    "plt.plot(train_losses, label=\"Train Loss\")\n",
    "plt.plot(val_losses, label=\"Validation Loss\")\n",
    "plt.xlabel(\"Epoch\")\n",
    "plt.ylabel(\"Loss\")\n",
    "plt.title(\"EEG Classifier Loss\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "plt.figure(figsize=(7, 4))\n",
    "plt.plot(np.array(train_accs) * 100, label=\"Train Accuracy\")\n",
    "plt.plot(np.array(val_accs) * 100, label=\"Validation Accuracy\")\n",
    "plt.xlabel(\"Epoch\")\n",
    "plt.ylabel(\"Accuracy (%)\")\n",
    "plt.title(\"EEG Classifier Accuracy\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
