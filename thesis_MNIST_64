    "import os\n",
    "import glob\n",
    "import numpy as np\n",
    "import torch\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "\n",
    "PROCESSED_DIR = \"/kaggle/working/processed_mnist_cap64\"\n",
    "\n",
    "class EEGMNISTDataset(Dataset):\n",
    "    def __init__(self, root_dir, split=\"train\", normalize_eeg=True):\n",
    "        self.split_dir = os.path.join(root_dir, split)\n",
    "        self.normalize_eeg = normalize_eeg\n",
    "        \n",
    "        self.files = []\n",
    "        for label in range(10):\n",
    "            label_dir = os.path.join(self.split_dir, str(label))\n",
    "            self.files.extend(sorted(glob.glob(os.path.join(label_dir, \"*.npz\"))))\n",
    "        \n",
    "        if len(self.files) == 0:\n",
    "            raise RuntimeError(f\"No .npz files found in {self.split_dir}\")\n",
    "    \n",
    "    def __len__(self):\n",
    "        return len(self.files)\n",
    "    \n",
    "    def __getitem__(self, idx):\n",
    "        data = np.load(self.files[idx])\n",
    "        \n",
    "        eeg = data[\"eeg\"].astype(np.float32)       # shape: (64, 400)\n",
    "        image = data[\"image\"].astype(np.float32)   # shape: (28, 28)\n",
    "        label = int(data[\"label\"])\n",
    "        \n",
    "        # EEG per-channel normalization\n",
    "        if self.normalize_eeg:\n",
    "            mean = eeg.mean(axis=1, keepdims=True)\n",
    "            std = eeg.std(axis=1, keepdims=True) + 1e-6\n",
    "            eeg = (eeg - mean) / std\n",
    "        \n",
    "        # image normalize: 0-255 -> 0-1\n",
    "        image = image / 255.0\n",
    "        \n",
    "        # add channel dimension for CNN/GAN: (1, 28, 28)\n",
    "        image = np.expand_dims(image, axis=0)\n",
    "        \n",
    "        return {\n",
    "            \"eeg\": torch.tensor(eeg, dtype=torch.float32),\n",
    "            \"image\": torch.tensor(image, dtype=torch.float32),\n",
    "            \"label\": torch.tensor(label, dtype=torch.long),\n",
    "            \"file\": self.files[idx]\n",
    "        }\n",
    "\n",
    "# Create datasets\n",
    "train_dataset = EEGMNISTDataset(PROCESSED_DIR, split=\"train\")\n",
    "val_dataset   = EEGMNISTDataset(PROCESSED_DIR, split=\"val\")\n",
    "test_dataset  = EEGMNISTDataset(PROCESSED_DIR, split=\"test\")\n",
    "\n",
    "# Create dataloaders\n",
    "train_loader = DataLoader(train_dataset, batch_size=16, shuffle=True)\n",
    "val_loader   = DataLoader(val_dataset, batch_size=16, shuffle=False)\n",
    "test_loader  = DataLoader(test_dataset, batch_size=16, shuffle=False)\n",
    "\n",
    "# Check one batch\n",
    "batch = next(iter(train_loader))\n",
    "\n",
    "print(\"Train samples:\", len(train_dataset))\n",
    "print(\"Val samples:\", len(val_dataset))\n",
    "print(\"Test samples:\", len(test_dataset))\n",
    "print()\n",
    "print(\"EEG batch shape:\", batch[\"eeg\"].shape)\n",
    "print(\"Image batch shape:\", batch[\"image\"].shape)\n",
    "print(\"Label batch shape:\", batch[\"label\"].shape)\n",
    "print(\"Labels:\", batch[\"label\"])\n",
    "print()\n",
    "print(\"EEG min/max:\", batch[\"eeg\"].min().item(), batch[\"eeg\"].max().item())\n",
    "print(\"Image min/max:\", batch[\"image\"].min().item(), batch[\"image\"].max().item())"
