    "import os\n",
    "import json\n",
    "import random\n",
    "import numpy as np\n",
    "from collections import defaultdict, Counter\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "# =========================\n",
    "# Find txt file automatically\n",
    "# =========================\n",
    "base_path = \"/kaggle/input\"\n",
    "txt_files = []\n",
    "\n",
    "for root, dirs, files in os.walk(base_path):\n",
    "    for f in files:\n",
    "        if f.endswith(\".txt\"):\n",
    "            txt_files.append(os.path.join(root, f))\n",
    "\n",
    "print(\"Found txt files:\")\n",
    "for f in txt_files:\n",
    "    print(f)\n",
    "\n",
    "TXT_PATH = txt_files[0]\n",
    "print(\"\\nUsing:\", TXT_PATH)\n",
    "\n",
    "# =========================\n",
    "# Constants from file format\n",
    "# =========================\n",
    "IMG_PIXELS = 784\n",
    "N_CHANNELS = 64\n",
    "TIME_POINTS = 400\n",
    "EEG_POINTS = N_CHANNELS * TIME_POINTS\n",
    "\n",
    "OUT_DIR = \"/kaggle/working/processed_mnist_cap64_baseline_corrected\"\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "# =========================\n",
    "# Parse one line\n",
    "# Format:\n",
    "# dataset, origin, digit_event, 784 image pixels, timestamp, 25600 EEG values\n",
    "# =========================\n",
    "def parse_line(line, line_id):\n",
    "    parts = line.strip().split(\",\")\n",
    "\n",
    "    split_name = parts[0]\n",
    "    original_idx = int(parts[1])\n",
    "    label = int(parts[2])\n",
    "\n",
    "    image_start = 3\n",
    "    image_end = image_start + IMG_PIXELS\n",
    "\n",
    "    image = np.array(parts[image_start:image_end], dtype=np.float32).reshape(28, 28)\n",
    "\n",
    "    timestamp = float(parts[image_end])\n",
    "\n",
    "    eeg_start = image_end + 1\n",
    "    eeg_end = eeg_start + EEG_POINTS\n",
    "\n",
    "    eeg = np.array(parts[eeg_start:eeg_end], dtype=np.float32).reshape(N_CHANNELS, TIME_POINTS)\n",
    "\n",
    "    return {\n",
    "        \"line_id\": line_id,\n",
    "        \"split_name\": split_name,\n",
    "        \"original_idx\": original_idx,\n",
    "        \"label\": label,\n",
    "        \"image\": image,\n",
    "        \"timestamp\": timestamp,\n",
    "        \"eeg\": eeg\n",
    "    }\n",
    "\n",
    "# =========================\n",
    "# Load all rows\n",
    "# =========================\n",
    "all_rows = []\n",
    "\n",
    "with open(TXT_PATH, \"r\") as f:\n",
    "    for line_id, line in enumerate(f):\n",
    "        if line.strip():\n",
    "            row = parse_line(line, line_id)\n",
    "            all_rows.append(row)\n",
    "\n",
    "print(\"Total rows:\", len(all_rows))\n",
    "\n",
    "digit_rows = [r for r in all_rows if r[\"label\"] != -1]\n",
    "black_rows = [r for r in all_rows if r[\"label\"] == -1]\n",
    "\n",
    "print(\"Digit rows:\", len(digit_rows))\n",
    "print(\"Black-screen rows:\", len(black_rows))\n",
    "\n",
    "print(\"\\nDigit label counts:\")\n",
    "print(Counter([r[\"label\"] for r in digit_rows]))\n",
    "\n",
    "# =========================\n",
    "# Baseline correction\n",
    "# For each digit row, use nearest previous black-screen EEG\n",
    "# corrected EEG = digit EEG - black EEG\n",
    "# =========================\n",
    "processed_samples = []\n",
    "last_black = None\n",
    "skipped = 0\n",
    "\n",
    "for row in all_rows:\n",
    "    if row[\"label\"] == -1:\n",
    "        last_black = row\n",
    "    else:\n",
    "        if last_black is None:\n",
    "            skipped += 1\n",
    "            continue\n",
    "\n",
    "        eeg_corrected = row[\"eeg\"] - last_black[\"eeg\"]\n",
    "\n",
    "        # Per-channel normalization after baseline correction\n",
    "        mean = eeg_corrected.mean(axis=1, keepdims=True)\n",
    "        std = eeg_corrected.std(axis=1, keepdims=True) + 1e-6\n",
    "        eeg_corrected = (eeg_corrected - mean) / std\n",
    "\n",
    "        image = row[\"image\"] / 255.0\n",
    "\n",
    "        processed_samples.append({\n",
    "            \"eeg\": eeg_corrected.astype(np.float32),\n",
    "            \"image\": image.astype(np.float32),\n",
    "            \"label\": row[\"label\"],\n",
    "            \"original_idx\": row[\"original_idx\"],\n",
    "            \"timestamp\": row[\"timestamp\"],\n",
    "            \"line_id\": row[\"line_id\"],\n",
    "            \"baseline_line_id\": last_black[\"line_id\"]\n",
    "        })\n",
    "\n",
    "print(\"\\nProcessed digit samples:\", len(processed_samples))\n",
    "print(\"Skipped digit samples:\", skipped)\n",
    "\n",
    "# =========================\n",
    "# Stratified train/val/test split\n",
    "# =========================\n",
    "labels = np.array([s[\"label\"] for s in processed_samples])\n",
    "indices = np.arange(len(processed_samples))\n",
    "\n",
    "train_idx, temp_idx = train_test_split(\n",
    "    indices,\n",
    "    test_size=0.30,\n",
    "    random_state=42,\n",
    "    stratify=labels\n",
    ")\n",
    "\n",
    "temp_labels = labels[temp_idx]\n",
    "\n",
    "val_idx, test_idx = train_test_split(\n",
    "    temp_idx,\n",
    "    test_size=0.50,\n",
    "    random_state=42,\n",
    "    stratify=temp_labels\n",
    ")\n",
    "\n",
    "split_dict = {\n",
    "    \"train\": train_idx,\n",
    "    \"val\": val_idx,\n",
    "    \"test\": test_idx\n",
    "}\n",
    "\n",
    "# =========================\n",
    "# Save samples into folder/class structure\n",
    "# =========================\n",
    "metadata = []\n",
    "\n",
    "for split_name, split_indices in split_dict.items():\n",
    "    for idx in split_indices:\n",
    "        sample = processed_samples[idx]\n",
    "        label = sample[\"label\"]\n",
    "\n",
    "        class_dir = os.path.join(OUT_DIR, split_name, str(label))\n",
    "        os.makedirs(class_dir, exist_ok=True)\n",
    "\n",
    "        filename = f\"sample_{idx:05d}_label_{label}.npz\"\n",
    "        save_path = os.path.join(class_dir, filename)\n",
    "\n",
    "        np.savez_compressed(\n",
    "            save_path,\n",
    "            eeg=sample[\"eeg\"],\n",
    "            image=sample[\"image\"],\n",
    "            label=sample[\"label\"],\n",
    "            original_idx=sample[\"original_idx\"],\n",
    "            timestamp=sample[\"timestamp\"],\n",
    "            line_id=sample[\"line_id\"],\n",
    "            baseline_line_id=sample[\"baseline_line_id\"]\n",
    "        )\n",
    "\n",
    "        metadata.append({\n",
    "            \"path\": save_path,\n",
    "            \"split\": split_name,\n",
    "            \"label\": int(label),\n",
    "            \"original_idx\": int(sample[\"original_idx\"]),\n",
    "            \"timestamp\": float(sample[\"timestamp\"]),\n",
    "            \"line_id\": int(sample[\"line_id\"]),\n",
    "            \"baseline_line_id\": int(sample[\"baseline_line_id\"])\n",
    "        })\n",
    "\n",
    "metadata_path = os.path.join(OUT_DIR, \"metadata.json\")\n",
    "with open(metadata_path, \"w\") as f:\n",
    "    json.dump(metadata, f, indent=4)\n",
    "\n",
    "summary = {\n",
    "    \"total_digit_samples\": len(processed_samples),\n",
    "    \"train\": len(train_idx),\n",
    "    \"val\": len(val_idx),\n",
    "    \"test\": len(test_idx),\n",
    "    \"eeg_shape\": [N_CHANNELS, TIME_POINTS],\n",
    "    \"image_shape\": [28, 28],\n",
    "    \"method\": \"digit EEG minus nearest previous black-screen EEG, then per-channel z-score normalization\"\n",
    "}\n",
    "\n",
    "summary_path = os.path.join(OUT_DIR, \"summary.json\")\n",
    "with open(summary_path, \"w\") as f:\n",
    "    json.dump(summary, f, indent=4)\n",
    "\n",
    "print(\"\\nSaved baseline-corrected dataset at:\", OUT_DIR)\n",
    "print(\"Train:\", len(train_idx))\n",
    "print(\"Val:\", len(val_idx))\n",
    "print(\"Test:\", len(test_idx))\n",
    "print(\"Metadata:\", metadata_path)\n",
    "print(\"Summary:\", summary_path)\n",
    "\n",
    "# =========================\n",
    "# Check split label counts\n",
    "# =========================\n",
    "for split_name, split_indices in split_dict.items():\n",
    "    print(\"\\n\" + \"=\"*40)\n",
    "    print(\"SPLIT:\", split_name)\n",
    "    print(\"=\"*40)\n",
    "\n",
    "    split_labels = [processed_samples[i][\"label\"] for i in split_indices]\n",
    "    counts = Counter(split_labels)\n",
    "\n",
    "    for lab in range(10):\n",
    "        print(f\"Label {lab}: {counts[lab]}\")\n",
    "\n",
    "    print(f\"Total {split_name}:\", len(split_indices))"
   ]
